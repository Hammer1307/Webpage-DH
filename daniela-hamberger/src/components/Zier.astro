---
// Zier-Ornament im Stil der Marke: zarte goldene Linie mit kleinem Motiv in der Mitte.
// Varianten: 'blatt' (Standard), 'herz', 'ranke'.
interface Props { variant?: 'blatt' | 'herz' | 'ranke'; }
const { variant = 'blatt' } = Astro.props;
---
<div class="zier" aria-hidden="true">
  <span class="zier-line"></span>
  {variant === 'herz' ? (
    <svg class="zier-icon" viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="1.4">
      <path d="M12 20s-6.5-4.35-9-8.5C1.5 9 2.5 5.5 6 5.5c2 0 3 1.3 3.6 2.3.4.6.8.6 1.2 0C11.4 6.8 12.4 5.5 14.4 5.5c3.5 0 4.5 3.5 3 6-2.5 4.15-9 8.5-9 8.5z" stroke-linecap="round" stroke-linejoin="round"/>
    </svg>
  ) : variant === 'ranke' ? (
    <svg class="zier-icon" viewBox="0 0 48 24" width="40" height="20" fill="none" stroke="currentColor" stroke-width="1.2">
      <path d="M4 12c6 0 8-5 12-5s4 10 8 10 6-10 12-10 6 5 8 5" stroke-linecap="round"/>
      <path d="M16 7c-1.4-1-3.4-1-4.6.4M32 7c1.4-1 3.4-1 4.6.4" stroke-linecap="round"/>
    </svg>
  ) : (
    <svg class="zier-icon" viewBox="0 0 28 24" width="22" height="18" fill="none" stroke="currentColor" stroke-width="1.3">
      <path d="M14 4c-1.6 2.4-1.6 6.4 0 9.5 1.6-3.1 1.6-7.1 0-9.5z" stroke-linejoin="round"/>
      <path d="M14 13.5c2.6-.4 5.4-2.2 6.8-4.7-2.9-.3-5.4 1.6-6.8 4.7z" stroke-linejoin="round"/>
      <path d="M14 13.5c-2.6-.4-5.4-2.2-6.8-4.7 2.9-.3 5.4 1.6 6.8 4.7z" stroke-linejoin="round"/>
      <path d="M14 13.5V20" stroke-linecap="round"/>
    </svg>
  )}
  <span class="zier-line"></span>
</div>

<style>
  .zier {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.85rem;
    margin: 0.7rem auto 0.3rem;
    color: var(--color-clay, #B97F5A);
  }
  .zier-line {
    height: 1px;
    width: clamp(2.5rem, 8vw, 5rem);
    background: linear-gradient(to right, transparent, currentColor);
    opacity: 0.55;
  }
  .zier-line:last-child { transform: scaleX(-1); }
  .zier-icon { flex: none; opacity: 0.85; }
</style>

