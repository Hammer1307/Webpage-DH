---
// Zier-Ornament im Stil der Marke: feine goldene Linie mit klar erkennbarem Motiv in der Mitte.
// Varianten: 'blatt' (Standard), 'herz', 'ranke'.
interface Props { variant?: 'blatt' | 'herz' | 'ranke'; }
const { variant = 'blatt' } = Astro.props;
---
<div class="zier" aria-hidden="true">
  <span class="zier-line"></span>
  {variant === 'herz' ? (
    <svg class="zier-icon" viewBox="0 0 28 26" width="22" height="20" fill="none" stroke="currentColor" stroke-width="1.3">
      <path d="M14 23C14 23 3.5 16.5 3.5 9.2 3.5 5.6 6.1 3 9.4 3c2.2 0 3.8 1.2 4.6 2.9C14.8 4.2 16.4 3 18.6 3 21.9 3 24.5 5.6 24.5 9.2 24.5 16.5 14 23 14 23z" stroke-linecap="round" stroke-linejoin="round"/>
    </svg>
  ) : variant === 'ranke' ? (
    <svg class="zier-icon zier-icon-wide" viewBox="0 0 96 26" width="84" height="22" fill="none" stroke="currentColor" stroke-width="1.2">
      <!-- zentrale Knospe/Blatt -->
      <path d="M48 6c-2.4 3-2.4 8.5 0 11.5 2.4-3 2.4-8.5 0-11.5z" fill="currentColor" fill-opacity="0.14" stroke-linejoin="round"/>
      <path d="M48 17.5V23" stroke-linecap="round"/>
      <!-- geschwungene Ranke links -->
      <path d="M44 13C36 13 31 8 22 9c4 .4 6 3 6.5 5.5M44 13c-7 1.5-12 .5-18-2.5" stroke-linecap="round"/>
      <!-- kleine Blätter links -->
      <path d="M28.5 14.5c-1.6.2-3.2-.6-4-2.1 1.7-.5 3.4.3 4 2.1z" fill="currentColor" fill-opacity="0.2" stroke-linejoin="round"/>
      <!-- geschwungene Ranke rechts (gespiegelt) -->
      <path d="M52 13C60 13 65 8 74 9c-4 .4-6 3-6.5 5.5M52 13c7 1.5 12 .5 18-2.5" stroke-linecap="round"/>
      <path d="M67.5 14.5c1.6.2 3.2-.6 4-2.1-1.7-.5-3.4.3-4 2.1z" fill="currentColor" fill-opacity="0.2" stroke-linejoin="round"/>
    </svg>
  ) : (
    <svg class="zier-icon" viewBox="0 0 30 26" width="24" height="21" fill="none" stroke="currentColor" stroke-width="1.25">
      <!-- klar erkennbares Blatt mit Mittelrippe -->
      <path d="M15 3C9 6 6 11 6 17c0 .8.1 1.6.3 2.4C12 19 17 15 19.5 9.5 17.8 7 16.4 5 15 3z" fill="currentColor" fill-opacity="0.13" stroke-linejoin="round"/>
      <path d="M24 6c-3 .3-6 1.6-8.4 3.8C13.4 11.8 11.8 14.6 11 18c4.4-.4 8.4-2.6 11-6 1-1.6 1.7-3.6 2-6z" fill="currentColor" fill-opacity="0.13" stroke-linejoin="round"/>
      <path d="M8 20C11 15 15 11 21 8.5" stroke-linecap="round"/>
    </svg>
  )}
  <span class="zier-line"></span>
</div>

<style>
  .zier {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 1rem;
    margin: 0.9rem auto 0.5rem;
    color: var(--color-clay, #B97F5A);
  }
  .zier-line {
    height: 1px;
    width: clamp(2.5rem, 8vw, 5rem);
    background: linear-gradient(to right, transparent, currentColor);
    opacity: 0.75;
  }
  .zier-line:last-child { transform: scaleX(-1); }
  .zier-icon { flex: none; opacity: 1; }
  /* Die breite Ranke ersetzt die seitlichen Linien teilweise — Linien dann kürzer */
  .zier:has(.zier-icon-wide) .zier-line { width: clamp(1.5rem, 5vw, 3rem); }
</style>
