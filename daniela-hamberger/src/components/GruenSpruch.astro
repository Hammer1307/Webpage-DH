---
// Dunkelgrüne Akzentfläche mit goldenem Schreibschrift-Spruch und Herz.
// Im Stil der Marken-Grafiken (LinkedIn/Werbung).
// Props: spruch (Pflicht), zusatz (optional, kleinerer Untertext).
interface Props { spruch: string; zusatz?: string; }
const { spruch, zusatz } = Astro.props;
---
<div class="gruen-spruch">
  <svg class="gs-herz" viewBox="0 0 28 26" width="30" height="28" fill="none" stroke="currentColor" stroke-width="1.4" aria-hidden="true">
    <path d="M14 23C14 23 3.5 16.5 3.5 9.2 3.5 5.6 6.1 3 9.4 3c2.2 0 3.8 1.2 4.6 2.9C14.8 4.2 16.4 3 18.6 3 21.9 3 24.5 5.6 24.5 9.2 24.5 16.5 14 23 14 23z" stroke-linecap="round" stroke-linejoin="round"/>
  </svg>
  <p class="gs-spruch">{spruch}</p>
  {zusatz && <p class="gs-zusatz">{zusatz}</p>}
</div>

<style>
  .gruen-spruch {
    background: var(--color-sage-deep);
    border-radius: var(--radius-l, 18px);
    padding: clamp(1.6rem, 4vw, 2.6rem) clamp(1.4rem, 4vw, 3rem);
    text-align: center;
    margin: clamp(1.5rem, 4vw, 2.5rem) auto;
    max-width: 46rem;
    box-shadow: var(--shadow-lift, 0 12px 30px rgba(0,0,0,0.12));
  }
  .gs-herz { color: var(--color-clay-pale, #ead7c5); opacity: 0.9; margin-bottom: 0.6rem; }
  .gs-spruch {
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 500;
    color: var(--color-clay-pale, #ead7c5);
    font-size: clamp(1.5rem, 4vw, 2rem);
    line-height: 1.35;
    margin: 0;
  }
  .gs-zusatz {
    font-family: var(--font-display);
    font-style: italic;
    color: var(--color-cream);
    opacity: 0.85;
    font-size: 1.02rem;
    margin: 0.7rem auto 0;
    max-width: 36ch;
  }
</style>
