---
import { SITE, CONTACT, FOOTER_NAV, SOCIAL } from '@/data/site';
const year = new Date().getFullYear();
---
<footer class="site-footer">
  <div class="container">
    <div class="footer-top">
      <div class="footer-brand">
        <p class="brand-mark">Daniela Britta Hamberger</p>
        <p class="brand-line">Fokus Schöner Leben</p>
        <p class="brand-tagline">
          Innere Ordnung. <span class="script">Neue Klarheit.</span> Freude am Leben.
        </p>

        <div class="newsletter">
          <h3 class="newsletter-title">Impulsbrief abonnieren</h3>
          <p class="newsletter-text">
            Gelegentliche Impulse zu innerer Ordnung, Wertschätzung und gelingendem Miteinander — direkt in dein Postfach. Du kannst dich jederzeit abmelden.
          </p>
          <a href="/kontakt#impulsbrief" class="btn btn-secondary">Anmelden</a>
        </div>
      </div>

      <nav class="footer-nav" aria-label="Footer-Navigation">
        <div class="nav-col">
          <h4>Angebot</h4>
          <ul>
            {FOOTER_NAV.angebot.map((item) => (
              <li><a href={item.href}>{item.label}</a></li>
            ))}
          </ul>
        </div>

        <div class="nav-col">
          <h4>Entdecken</h4>
          <ul>
            {FOOTER_NAV.wissen.map((item) => (
              <li><a href={item.href}>{item.label}</a></li>
            ))}
          </ul>
        </div>

        <div class="nav-col">
          <h4>Service</h4>
          <ul>
            {FOOTER_NAV.rechtliches.map((item) => (
              <li><a href={item.href}>{item.label}</a></li>
            ))}
          </ul>
        </div>

        <div class="nav-col">
          <h4>Praxis</h4>
          <address class="address">
            {CONTACT.street}<br />
            {CONTACT.postalCode} {CONTACT.city}<br />
            {CONTACT.country}
          </address>
          <a class="contact-link" href={`mailto:${CONTACT.email}`}>{CONTACT.email}</a>
          <div class="social">
            <a href={SOCIAL.linkedin} target="_blank" rel="noopener noreferrer" aria-label="LinkedIn">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                <path d="M20.45 20.45h-3.56v-5.57c0-1.33-.03-3.04-1.85-3.04-1.86 0-2.14 1.45-2.14 2.95v5.66H9.34V9h3.42v1.56h.05c.48-.9 1.64-1.85 3.37-1.85 3.6 0 4.27 2.37 4.27 5.46v6.28zM5.34 7.43a2.07 2.07 0 1 1 0-4.14 2.07 2.07 0 0 1 0 4.14zm1.78 13.02H3.56V9h3.56v11.45zM22.22 0H1.77C.79 0 0 .77 0 1.72v20.56C0 23.23.79 24 1.77 24h20.45c.98 0 1.78-.77 1.78-1.72V1.72C24 .77 23.2 0 22.22 0z"/>
              </svg>
            </a>
            <a href={SOCIAL.instagram} target="_blank" rel="noopener noreferrer" aria-label="Instagram">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                <path d="M12 2.16c3.2 0 3.58.01 4.85.07 1.17.05 1.8.25 2.23.41.56.22.96.48 1.38.9.42.42.68.82.9 1.38.16.42.36 1.06.41 2.23.06 1.26.07 1.65.07 4.85 0 3.2-.01 3.58-.07 4.85-.05 1.17-.25 1.8-.41 2.23-.22.56-.48.96-.9 1.38-.42.42-.82.68-1.38.9-.42.16-1.06.36-2.23.41-1.26.06-1.65.07-4.85.07-3.2 0-3.58-.01-4.85-.07-1.17-.05-1.8-.25-2.23-.41-.56-.22-.96-.48-1.38-.9-.42-.42-.68-.82-.9-1.38-.16-.42-.36-1.06-.41-2.23-.06-1.27-.07-1.65-.07-4.85 0-3.2.01-3.58.07-4.85.05-1.17.25-1.8.41-2.23.22-.56.48-.96.9-1.38.42-.42.82-.68 1.38-.9.42-.16 1.06-.36 2.23-.41C8.42 2.17 8.8 2.16 12 2.16zM12 0C8.74 0 8.33.01 7.05.07 5.78.13 4.9.33 4.14.63a5.85 5.85 0 0 0-2.13 1.38A5.85 5.85 0 0 0 .63 4.14c-.3.76-.5 1.64-.56 2.91C.01 8.33 0 8.74 0 12c0 3.26.01 3.67.07 4.95.06 1.27.26 2.15.56 2.91.31.8.72 1.47 1.38 2.13.66.66 1.34 1.07 2.13 1.38.76.3 1.64.5 2.91.56C8.33 23.99 8.74 24 12 24c3.26 0 3.67-.01 4.95-.07 1.27-.06 2.15-.26 2.91-.56a5.85 5.85 0 0 0 2.13-1.38 5.85 5.85 0 0 0 1.38-2.13c.3-.76.5-1.64.56-2.91.06-1.28.07-1.69.07-4.95 0-3.26-.01-3.67-.07-4.95-.06-1.27-.26-2.15-.56-2.91a5.85 5.85 0 0 0-1.38-2.13A5.85 5.85 0 0 0 19.86.63c-.76-.3-1.64-.5-2.91-.56C15.67.01 15.26 0 12 0zm0 5.84a6.16 6.16 0 1 0 0 12.32 6.16 6.16 0 0 0 0-12.32zM12 16a4 4 0 1 1 0-8 4 4 0 0 1 0 8zm6.4-11.84a1.44 1.44 0 1 0 0 2.88 1.44 1.44 0 0 0 0-2.88z"/>
              </svg>
            </a>
          </div>
        </div>
      </nav>
    </div>

    <div class="footer-meta">
      <p class="disclaimer">
        Die Angebote auf dieser Website ersetzen keine medizinische, psychotherapeutische oder psychiatrische Behandlung. Mentoring und Coaching sind keine Therapie. Bei psychischen Erkrankungen oder Krisen wende dich bitte an eine Ärztin, einen Arzt oder eine zugelassene Psychotherapeutin bzw. einen Psychotherapeuten.
      </p>

      <div class="footer-bottom">
        <p>© {year} Daniela Britta Hamberger</p>
        <ul class="meta-nav">
          <li><a href="/impressum">Impressum</a></li>
          <li><a href="/datenschutz">Datenschutz</a></li>
          <li><a href="/kontakt">Kontakt</a></li>
        </ul>
      </div>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    background: var(--color-ink);
    color: var(--color-cream-deep);
    padding: clamp(3rem, 7vw, 6rem) 0 2rem;
    margin-top: var(--space-2xl);
    position: relative;
  }

  .site-footer::before {
    content: '';
    position: absolute;
    inset: 0 0 auto 0;
    height: 1px;
    background: linear-gradient(90deg, transparent, var(--color-sage-soft), transparent);
    opacity: 0.4;
  }

  .footer-top {
    display: grid;
    grid-template-columns: 1.2fr 2fr;
    gap: clamp(2.5rem, 6vw, 5rem);
    padding-bottom: var(--space-xl);
    border-bottom: 1px solid rgba(245, 239, 230, 0.1);
  }

  .footer-brand .brand-mark {
    font-family: var(--font-display);
font-size: var(--step-2);
    color: var(--color-cream);
    letter-spacing: -0.01em;
  }

  .footer-brand .brand-line {
    font-size: 0.78rem;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--color-sage-pale);
    margin-top: 0.4rem;
    font-weight: 500;
  }

  .footer-brand .brand-tagline {
    margin-top: 1.25rem;
    font-family: var(--font-display);
font-size: var(--step-1);
    color: var(--color-cream-deep);
    line-height: 1.3;
    max-width: 22ch;
  }

  .footer-brand .script {
    color: var(--color-sage-pale);
    display: block;
  }

  .newsletter {
    margin-top: var(--space-l);
    padding-top: var(--space-m);
    border-top: 1px solid rgba(245, 239, 230, 0.08);
  }

  .newsletter-title {
    font-family: var(--font-body);
    font-size: 0.78rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--color-sage-pale);
    margin-bottom: 0.75rem;
    font-weight: 600;
  }

  .newsletter-text {
    font-size: 0.92rem;
    color: var(--color-cream-deep);
    margin-bottom: 1.25rem;
    line-height: 1.55;
    opacity: 0.8;
  }

  .newsletter .btn-secondary {
    background: transparent;
    color: var(--color-cream);
    border-color: var(--color-sage-soft);
  }

  .newsletter .btn-secondary:hover {
    background: var(--color-cream);
    color: var(--color-ink);
    border-color: var(--color-cream);
  }

  .footer-nav {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(11rem, 1fr));
    gap: 2.5rem 1.75rem;
  }

  .nav-col h4 {
    font-family: var(--font-body);
    font-size: 0.7rem;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--color-sage-pale);
    margin-bottom: 1.1rem;
    font-weight: 600;
  }

  .nav-col ul {
    display: flex;
    flex-direction: column;
    gap: 0.65rem;
  }

  .nav-col a, .contact-link {
    font-size: 0.92rem;
    color: var(--color-cream-deep);
    opacity: 0.78;
    transition: opacity var(--transition), color var(--transition);
  }

  .nav-col a:hover, .contact-link:hover {
    opacity: 1;
    color: var(--color-cream);
  }

  .address {
    font-style: normal;
    font-size: 0.9rem;
    line-height: 1.7;
    color: var(--color-cream-deep);
    opacity: 0.78;
    margin-bottom: 0.85rem;
  }

  .contact-link {
    display: block;
    margin-bottom: 1.25rem;
  }

  .social {
    display: flex;
    gap: 0.75rem;
  }

  .social a {
    display: grid;
    place-items: center;
    width: 38px;
    height: 38px;
    border: 1px solid rgba(245, 239, 230, 0.18);
    border-radius: var(--radius-pill);
    color: var(--color-cream-deep);
    opacity: 0.7;
    transition: all var(--transition);
  }

  .social a:hover {
    background: var(--color-sage);
    border-color: var(--color-sage);
    color: var(--color-cream);
    opacity: 1;
    transform: translateY(-2px);
  }

  .footer-meta {
    padding-top: var(--space-l);
  }

  .disclaimer {
    font-size: 0.78rem;
    line-height: 1.6;
    color: var(--color-cream-deep);
    opacity: 0.55;
    max-width: 65ch;
    margin: 0 auto var(--space-l);
    text-align: center;
  }

  .footer-bottom {
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: 1rem;
    font-size: 0.82rem;
    color: var(--color-cream-deep);
    opacity: 0.6;
  }

  .meta-nav {
    display: flex;
    gap: 1.5rem;
    flex-wrap: wrap;
  }

  .meta-nav a:hover { opacity: 1; color: var(--color-cream); }

  @media (max-width: 760px) {
    .footer-top { grid-template-columns: 1fr; }
    .footer-bottom { justify-content: center; text-align: center; }
  }
</style>
