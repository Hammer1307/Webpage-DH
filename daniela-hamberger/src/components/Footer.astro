---
import { SITE, VENUE, FOOTER_NAV, SOCIAL } from '@/data/site';
const year = new Date().getFullYear();
---
<footer class="site-footer">
  <div class="container">
    <div class="footer-top">
      <div class="footer-brand">
        <p class="brand-mark">Daniela Britta Hamberger</p>
        <p class="brand-line">Mentorin mit pädagogischer Expertise für Bewusstsein, innere Stabilität und gelingendes Miteinander.</p>
        <p class="brand-tagline">
          <span class="script">Fokus Schöner Leben</span> — Innere Ordnung. Neue Klarheit. Freude am Leben.
        </p>

        <div class="venue">
          <h4>Online und vor Ort in Wiesbaden und Idstein</h4>
          <p>
            Meine Begleitungen und Formate finden je nach Anliegen online, telefonisch, bei dir bzw. euch vor Ort oder in stimmigen Räumlichkeiten statt — unter anderem im Seminarraum Schöne Aussichten in Wiesbaden.
          </p>
          <address>
            <strong>{VENUE.name}</strong><br />
            {VENUE.street}<br />
            {VENUE.postalCode} {VENUE.city}
          </address>
          <p class="venue-note">Termine und Formate werden ausschließlich über Daniela Britta Hamberger abgestimmt.</p>
        </div>

        <div class="newsletter">
          <a href="/kontakt" class="btn btn-secondary">Gespräch buchen</a>
        </div>
      </div>

      <nav class="footer-nav" aria-label="Footer-Navigation">
        <div class="nav-col">
          <h4>Angebot</h4>
          <ul>{FOOTER_NAV.angebot.map((item) => (<li><a href={item.href}>{item.label}</a></li>))}</ul>
        </div>
        <div class="nav-col">
          <h4>Entdecken</h4>
          <ul>{FOOTER_NAV.wissen.map((item) => (<li><a href={item.href}>{item.label}</a></li>))}</ul>
        </div>
        <div class="nav-col">
          <h4>Service</h4>
          <ul>{FOOTER_NAV.rechtliches.map((item) => (<li><a href={item.href}>{item.label}</a></li>))}</ul>
        </div>
        <div class="nav-col">
          <h4>Kontakt</h4>
          <p class="contact-line"><button type="button" class="footer-contact-link" data-modal-open="nachricht">E-Mail schreiben</button></p>
          <div class="social">
            <a href={SOCIAL.linkedin} target="_blank" rel="noopener noreferrer" aria-label="LinkedIn">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M20.45 20.45h-3.56v-5.57c0-1.33-.03-3.04-1.85-3.04-1.86 0-2.14 1.45-2.14 2.95v5.66H9.34V9h3.42v1.56h.05c.48-.9 1.64-1.85 3.37-1.85 3.6 0 4.27 2.37 4.27 5.46v6.28zM5.34 7.43a2.07 2.07 0 1 1 0-4.14 2.07 2.07 0 0 1 0 4.14zm1.78 13.02H3.56V9h3.56v11.45zM22.22 0H1.77C.79 0 0 .77 0 1.72v20.56C0 23.23.79 24 1.77 24h20.45c.98 0 1.78-.77 1.78-1.72V1.72C24 .77 23.2 0 22.22 0z"/></svg>
            </a>
            <a href={SOCIAL.instagram} target="_blank" rel="noopener noreferrer" aria-label="Instagram">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 2.16c3.2 0 3.58.01 4.85.07 1.17.05 1.8.25 2.23.41.56.22.96.48 1.38.9.42.42.68.82.9 1.38.16.42.36 1.06.41 2.23.06 1.26.07 1.65.07 4.85 0 3.2-.01 3.58-.07 4.85-.05 1.17-.25 1.8-.41 2.23-.22.56-.48.96-.9 1.38-.42.42-.82.68-1.38.9-.42.16-1.06.36-2.23.41-1.26.06-1.65.07-4.85.07-3.2 0-3.58-.01-4.85-.07-1.17-.05-1.8-.25-2.23-.41-.56-.22-.96-.48-1.38-.9-.42-.42-.68-.82-.9-1.38-.16-.42-.36-1.06-.41-2.23-.06-1.27-.07-1.65-.07-4.85 0-3.2.01-3.58.07-4.85.05-1.17.25-1.8.41-2.23.22-.56.48-.96.9-1.38.42-.42.82-.68 1.38-.9.42-.16 1.06-.36 2.23-.41C8.42 2.17 8.8 2.16 12 2.16zM12 0C8.74 0 8.33.01 7.05.07 5.78.13 4.9.33 4.14.63a5.85 5.85 0 0 0-2.13 1.38A5.85 5.85 0 0 0 .63 4.14c-.3.76-.5 1.64-.56 2.91C.01 8.33 0 8.74 0 12c0 3.26.01 3.67.07 4.95.06 1.27.26 2.15.56 2.91.31.8.72 1.47 1.38 2.13.66.66 1.34 1.07 2.13 1.38.76.3 1.64.5 2.91.56C8.33 23.99 8.74 24 12 24c3.26 0 3.67-.01 4.95-.07 1.27-.06 2.15-.26 2.91-.56a5.85 5.85 0 0 0 2.13-1.38 5.85 5.85 0 0 0 1.38-2.13c.3-.76.5-1.64.56-2.91.06-1.28.07-1.69.07-4.95 0-3.26-.01-3.67-.07-4.95-.06-1.27-.26-2.15-.56-2.91a5.85 5.85 0 0 0-1.38-2.13A5.85 5.85 0 0 0 19.86.63c-.76-.3-1.64-.5-2.91-.56C15.67.01 15.26 0 12 0zm0 5.84a6.16 6.16 0 1 0 0 12.32 6.16 6.16 0 0 0 0-12.32zM12 16a4 4 0 1 1 0-8 4 4 0 0 1 0 8zm6.4-11.84a1.44 1.44 0 1 0 0 2.88 1.44 1.44 0 0 0 0-2.88z"/></svg>
            </a>
          </div>
        </div>
      </nav>
    </div>

    <div class="footer-meta">
      <p class="disclaimer">
        <strong>Wichtiger Hinweis:</strong> Meine Arbeit versteht sich als ganzheitliche Begleitung zur persönlichen Klärung, Stabilisierung und bewussten Entwicklung. Sie ersetzt keine ärztliche, psychotherapeutische oder heilkundliche Diagnose oder Behandlung. Mentoring und Coaching sind keine Therapie. Bei psychischen Erkrankungen oder Krisen wende dich bitte an eine Ärztin, einen Arzt oder eine zugelassene Psychotherapeutin bzw. einen zugelassenen Psychotherapeuten.
      </p>
      <div class="footer-bottom">
        <p>© {year} Daniela Britta Hamberger</p>
        <ul class="meta-nav">
          <li><a href="/wichtiger-hinweis">Wichtiger Hinweis</a></li>
          <li><a href="/impressum">Impressum</a></li>
          <li><a href="/datenschutz">Datenschutz</a></li>
        </ul>
      </div>
    </div>
  </div>
</footer>

<style>
  .site-footer { background: var(--color-ink); color: var(--color-cream-deep); padding: clamp(3rem, 7vw, 6rem) 0 2rem; margin-top: var(--space-2xl); position: relative; }
  .site-footer::before { content: ''; position: absolute; inset: 0 0 auto 0; height: 1px; background: linear-gradient(90deg, transparent, var(--color-sage-soft), transparent); opacity: 0.4; }
  .footer-top { display: grid; grid-template-columns: 1.3fr 2fr; gap: clamp(2.5rem, 6vw, 5rem); padding-bottom: var(--space-xl); border-bottom: 1px solid rgba(245, 239, 230, 0.1); }
  @media (max-width: 960px) { .footer-top { grid-template-columns: 1fr; } }

  .footer-brand .brand-mark { font-family: var(--font-display); font-size: 1.5rem; line-height: 1.15; color: var(--color-cream); margin-bottom: 0.5rem; }
  .footer-brand .brand-line { color: rgba(245, 239, 230, 0.75); font-size: 0.92rem; line-height: 1.5; margin-bottom: 0.75rem; max-width: 38ch; }
  .footer-brand .brand-tagline { color: rgba(245, 239, 230, 0.7); font-size: 0.95rem; margin-bottom: 1.75rem; }
  .footer-brand .script { color: var(--color-clay-pale); font-style: italic; }

  .venue { background: rgba(245, 239, 230, 0.05); border-left: 2px solid var(--color-clay); padding: 1rem 1.25rem; border-radius: 0 var(--radius-s) var(--radius-s) 0; margin-bottom: 1.5rem; }
  .venue h4 { color: var(--color-clay-pale); font-family: var(--font-body); font-size: 0.75rem; text-transform: uppercase; letter-spacing: 0.15em; font-weight: 600; margin-bottom: 0.5rem; }
  .venue p { color: rgba(245, 239, 230, 0.78); font-size: 0.85rem; line-height: 1.55; margin-bottom: 0.75rem; }
  .venue address { font-style: normal; color: rgba(245, 239, 230, 0.9); font-size: 0.88rem; line-height: 1.6; margin-bottom: 0.5rem; }
  .venue strong { color: var(--color-cream); font-weight: 500; }
  .venue-note { font-size: 0.78rem; font-style: italic; color: rgba(245, 239, 230, 0.6); margin: 0; }

  .footer-nav { display: grid; grid-template-columns: repeat(4, 1fr); gap: 1.5rem; }
  @media (max-width: 700px) { .footer-nav { grid-template-columns: 1fr 1fr; } }

  .nav-col h4 { color: var(--color-clay-pale); font-family: var(--font-body); font-size: 0.75rem; text-transform: uppercase; letter-spacing: 0.15em; font-weight: 600; margin-bottom: 1rem; }
  .nav-col ul li { margin-bottom: 0.5rem; }
  .nav-col a { color: rgba(245, 239, 230, 0.75); font-size: 0.88rem; transition: color var(--transition); }
  .nav-col a:hover { color: var(--color-clay-pale); }
  .contact-line { margin-bottom: 0.4rem; font-size: 0.88rem; color: rgba(245, 239, 230, 0.75); }
  .contact-line a { color: rgba(245, 239, 230, 0.75); }
  .footer-contact-link {
    background: none;
    border: none;
    padding: 0;
    margin: 0;
    font: inherit;
    color: rgba(245, 239, 230, 0.75);
    text-decoration: underline;
    cursor: pointer;
  }
  .footer-contact-link:hover { color: var(--color-paper, #fff); }

  .social { display: flex; gap: 0.85rem; margin-top: 1rem; color: var(--color-clay-pale); }
  .social a { display: inline-flex; color: var(--color-clay-pale); opacity: 0.85; transition: opacity var(--transition); }
  .social a:hover { opacity: 1; }

  .footer-meta { padding-top: 2rem; }
  .disclaimer { background: rgba(245, 239, 230, 0.06); border-left: 2px solid var(--color-clay); padding: 1.25rem 1.5rem; border-radius: 0 var(--radius-s) var(--radius-s) 0; color: rgba(245, 239, 230, 0.78); font-size: 0.84rem; line-height: 1.6; max-width: none; margin-bottom: 1.5rem; }
  .disclaimer strong { color: var(--color-clay-pale); font-weight: 500; }
  .footer-bottom { display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 1rem; font-size: 0.82rem; color: rgba(245, 239, 230, 0.6); }
  .footer-bottom p { color: rgba(245, 239, 230, 0.6); margin: 0; }
  .meta-nav { display: flex; gap: 1.5rem; }
  .meta-nav a { color: rgba(245, 239, 230, 0.7); }
  .meta-nav a:hover { color: var(--color-clay-pale); }
</style>
