---
import { SITE, CONTACT, SOCIAL } from '@/data/site';
const year = new Date().getFullYear();
---
<footer class="site-footer">
  <div class="container">
    <div class="footer-top">
      <div class="footer-brand">
        <p class="brand-name">{SITE.name}</p>
        <p class="brand-tag">{SITE.brand}</p>
        <p class="brand-motto">{SITE.motto}</p>
      </div>

      <div class="footer-nav">
        <div class="nav-col">
          <h4>Angebot</h4>
          <ul>
            <li><a href="/1-zu-1-begleitung">1:1 Begleitung</a></li>
            <li><a href="/klarheitsreset">KlarheitsReset</a></li>
            <li><a href="/teams-workshops">Teams &amp; Workshops</a></li>
            <li><a href="/teambalance">TeamBalance</a></li>
            <li><a href="/publikationen-materialien">Publikationen</a></li>
          </ul>
        </div>

        <div class="nav-col">
          <h4>Entdecken</h4>
          <ul>
            <li><a href="/ueber-mich">Über mich</a></li>
            <li><a href="/vision-stiftung">Vision &amp; Stiftung</a></li>
            <li><a href="/stimmen-erfahrungen">Stimmen</a></li>
            <li><a href="/impulse">Fokus Impulse</a></li>
          </ul>
        </div>

        <div class="nav-col">
          <h4>Kontakt</h4>
          <address>
            {CONTACT.street}<br />
            {CONTACT.postalCode} {CONTACT.city}<br />
            {CONTACT.country}
          </address>
          <p class="contact-line">
            <a href={`mailto:${CONTACT.email}`}>{CONTACT.email}</a>
          </p>
          <p class="contact-line">
            <a href={`tel:${CONTACT.phone.replace(/\s/g, '')}`}>{CONTACT.phone}</a>
          </p>
          <div class="social">
            <a href={SOCIAL.instagram} target="_blank" rel="noopener noreferrer" aria-label="Instagram">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                <path d="M12 2.16c3.2 0 3.58.01 4.85.07 1.17.05 1.8.25 2.23.41.56.22.96.48 1.38.9.42.42.68.82.9 1.38.16.42.36 1.06.41 2.23.06 1.26.07 1.65.07 4.85 0 3.2-.01 3.58-.07 4.85-.05 1.17-.25 1.8-.41 2.23-.22.56-.48.96-.9 1.38-.42.42-.82.68-1.38.9-.42.16-1.06.36-2.23.41-1.26.06-1.65.07-4.85.07-3.2 0-3.58-.01-4.85-.07-1.17-.05-1.8-.25-2.23-.41-.56-.22-.96-.48-1.38-.9-.42-.42-.68-.82-.9-1.38-.16-.42-.36-1.06-.41-2.23-.06-1.27-.07-1.65-.07-4.85 0-3.2.01-3.58.07-4.85.05-1.17.25-1.8.41-2.23.22-.56.48-.96.9-1.38.42-.42.82-.68 1.38-.9.42-.16 1.06-.36 2.23-.41C8.42 2.17 8.8 2.16 12 2.16zM12 0C8.74 0 8.33.01 7.05.07 5.78.13 4.9.33 4.14.63a5.85 5.85 0 0 0-2.13 1.38A5.85 5.85 0 0 0 .63 4.14c-.3.76-.5 1.64-.56 2.91C.01 8.33 0 8.74 0 12c0 3.26.01 3.67.07 4.95.06 1.27.26 2.15.56 2.91.31.8.72 1.47 1.38 2.13.66.66 1.34 1.07 2.13 1.38.76.3 1.64.5 2.91.56C8.33 23.99 8.74 24 12 24c3.26 0 3.67-.01 4.95-.07 1.27-.06 2.15-.26 2.91-.56a5.85 5.85 0 0 0 2.13-1.38 5.85 5.85 0 0 0 1.38-2.13c.3-.76.5-1.64.56-2.91.06-1.28.07-1.69.07-4.95 0-3.26-.01-3.67-.07-4.95-.06-1.27-.26-2.15-.56-2.91a5.85 5.85 0 0 0-1.38-2.13A5.85 5.85 0 0 0 19.86.63c-.76-.3-1.64-.5-2.91-.56C15.67.01 15.26 0 12 0zm0 5.84a6.16 6.16 0 1 0 0 12.32 6.16 6.16 0 0 0 0-12.32zM12 16a4 4 0 1 1 0-8 4 4 0 0 1 0 8zm6.4-11.84a1.44 1.44 0 1 0 0 2.88 1.44 1.44 0 0 0 0-2.88z"/>
              </svg>
            </a>
            <a href={SOCIAL.linkedin} target="_blank" rel="noopener noreferrer" aria-label="LinkedIn">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                <path d="M20.45 20.45h-3.56v-5.57c0-1.33-.03-3.04-1.85-3.04-1.86 0-2.14 1.45-2.14 2.95v5.66H9.34V9h3.42v1.56h.05c.48-.9 1.64-1.85 3.37-1.85 3.6 0 4.27 2.37 4.27 5.46v6.28zM5.34 7.43a2.07 2.07 0 1 1 0-4.14 2.07 2.07 0 0 1 0 4.14zm1.78 13.02H3.56V9h3.56v11.45zM22.22 0H1.77C.79 0 0 .77 0 1.72v20.56C0 23.23.79 24 1.77 24h20.45c.98 0 1.78-.77 1.78-1.72V1.72C24 .77 23.2 0 22.22 0z"/>
              </svg>
            </a>
          </div>
        </div>
      </div>
    </div>

    <hr class="footer-divider" />

    <div class="footer-disclaimer">
      <p>
        <strong>Wichtiger Hinweis:</strong> Die Angebote auf dieser Website ersetzen keine
        medizinische, psychotherapeutische oder psychiatrische Behandlung. Mentoring und
        Coaching sind keine Therapie. Bei psychischen Erkrankungen oder Krisen wende dich
        bitte an eine Ärztin, einen Arzt oder eine zugelassene Psychotherapeutin bzw. einen
        zugelassenen Psychotherapeuten.
      </p>
    </div>

    <div class="footer-meta">
      <p class="copy">© {year} {SITE.name} · {SITE.brand}</p>
      <nav class="meta-nav" aria-label="Rechtliches">
        <a href="/impressum">Impressum</a>
        <a href="/datenschutz">Datenschutz</a>
        <a href="/kontakt">Kontakt</a>
      </nav>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    background: var(--color-bordeaux);
    color: var(--color-cream);
    padding-block: clamp(3rem, 6vw, 5rem);
    margin-top: 0;
  }
  .footer-top {
    display: grid;
    grid-template-columns: 1.2fr 2fr;
    gap: clamp(2rem, 5vw, 4rem);
    align-items: start;
  }
  @media (max-width: 800px) {
    .footer-top { grid-template-columns: 1fr; }
  }

  .footer-brand .brand-name {
    font-family: var(--font-display);
    font-size: 1.5rem;
    font-weight: 500;
    color: var(--color-cream);
    margin-bottom: 0.25rem;
  }
  .footer-brand .brand-tag {
    font-family: var(--font-display);
    font-style: italic;
    color: var(--color-gold-pale);
    font-size: 1.1rem;
    margin-bottom: 1rem;
  }
  .footer-brand .brand-motto {
    color: rgba(250, 247, 242, 0.75);
    font-size: 0.92rem;
    max-width: 28ch;
  }

  .footer-nav {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2rem;
  }
  @media (max-width: 640px) {
    .footer-nav { grid-template-columns: 1fr; }
  }

  .nav-col h4 {
    color: var(--color-gold-pale);
    font-family: var(--font-display);
    font-size: 1rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    margin-bottom: 1rem;
  }
  .nav-col ul li { margin-bottom: 0.5rem; }
  .nav-col a {
    color: rgba(250, 247, 242, 0.78);
    font-size: 0.9rem;
    transition: color var(--transition);
  }
  .nav-col a:hover { color: var(--color-gold-pale); }

  address {
    font-style: normal;
    color: rgba(250, 247, 242, 0.78);
    font-size: 0.9rem;
    line-height: 1.6;
    margin-bottom: 0.75rem;
  }
  .contact-line {
    margin-bottom: 0.4rem;
    font-size: 0.9rem;
    line-height: 1.4;
  }

  .social {
    display: flex;
    gap: 0.85rem;
    margin-top: 1rem;
    color: var(--color-gold-pale);
  }
  .social a {
    display: inline-flex;
    color: var(--color-gold-pale);
    opacity: 0.85;
    transition: opacity var(--transition);
  }
  .social a:hover { opacity: 1; }

  .footer-divider {
    border: none;
    height: 1px;
    background: rgba(201, 169, 110, 0.25);
    margin: 2.5rem 0 1.75rem;
  }

  .footer-disclaimer {
    background: rgba(250, 247, 242, 0.06);
    border-left: 2px solid var(--color-gold);
    padding: 1.25rem 1.5rem;
    margin-bottom: 1.5rem;
    border-radius: 0 4px 4px 0;
  }
  .footer-disclaimer p {
    color: rgba(250, 247, 242, 0.78);
    font-size: 0.82rem;
    line-height: 1.6;
    max-width: 75ch;
  }
  .footer-disclaimer strong { color: var(--color-gold-pale); font-weight: 500; }

  .footer-meta {
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: 1rem;
    font-size: 0.82rem;
  }
  .copy { color: rgba(250, 247, 242, 0.6); margin: 0; }
  .meta-nav { display: flex; gap: 1.5rem; }
  .meta-nav a { color: rgba(250, 247, 242, 0.7); }
  .meta-nav a:hover { color: var(--color-gold-pale); }
</style>
