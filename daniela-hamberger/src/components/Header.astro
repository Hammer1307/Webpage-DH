---
import { SITE, NAV } from '@/data/site';

const currentPath = Astro.url.pathname;
const isActive = (href: string) => {
  if (href === '/') return currentPath === '/';
  return currentPath.startsWith(href);
};
---
<header class="site-header" data-header>
  <a href="#main" class="skip-link">Zum Inhalt springen</a>

  <div class="container header-inner">
    <a href="/" class="brand" aria-label="Startseite — Daniela Britta Hamberger">
      <span class="brand-name">Daniela Britta Hamberger</span>
      <span class="brand-tag">Fokus Schöner Leben</span>
    </a>

    <nav class="nav-desktop" aria-label="Hauptnavigation">
      <ul>
        {NAV.map((item) => (
          <li>
            <a
              href={item.href}
              class:list={['nav-link', { active: isActive(item.href) }]}
              aria-current={isActive(item.href) ? 'page' : undefined}
            >
              {item.label}
            </a>
          </li>
        ))}
      </ul>
    </nav>

    <a href="/kontakt" class="btn btn-primary header-cta">Gespräch buchen</a>

    <button
      class="menu-toggle"
      aria-label="Menü öffnen"
      aria-expanded="false"
      aria-controls="mobile-nav"
      data-menu-toggle
    >
      <span></span><span></span><span></span>
    </button>
  </div>

  <nav
    class="nav-mobile"
    id="mobile-nav"
    aria-label="Mobile Navigation"
    data-mobile-nav
    hidden
  >
    <ul>
      {NAV.map((item) => (
        <li>
          <a
            href={item.href}
            class:list={['mobile-link', { active: isActive(item.href) }]}
          >
            {item.label}
          </a>
        </li>
      ))}
      <li class="mobile-cta-wrap">
        <a href="/kontakt" class="btn btn-primary">Kostenfreies Gespräch buchen</a>
      </li>
    </ul>
  </nav>
</header>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 100;
    background: rgba(245, 239, 230, 0.85);
    backdrop-filter: saturate(160%) blur(12px);
    -webkit-backdrop-filter: saturate(160%) blur(12px);
    border-bottom: 1px solid transparent;
    transition: border-color 280ms, background 280ms;
  }

  .site-header[data-scrolled='true'] {
    border-bottom-color: var(--color-line);
    background: rgba(245, 239, 230, 0.96);
  }

  .header-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1.5rem;
    padding-block: 1.1rem;
  }

  .brand {
    display: flex;
    flex-direction: column;
    line-height: 1.1;
    text-decoration: none;
    transition: opacity var(--transition);
  }

  .brand:hover { opacity: 0.7; }

  .brand-name {
    font-family: var(--font-display);
font-size: clamp(1rem, 0.95rem + 0.3vw, 1.2rem);
    letter-spacing: -0.01em;
    color: var(--color-ink);
  }

  .brand-tag {
    font-size: 0.72rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--color-sage);
    margin-top: 0.15rem;
    font-weight: 500;
  }

  .nav-desktop {
    flex: 1;
    display: flex;
    justify-content: center;
  }

  .nav-desktop ul {
    display: flex;
    gap: clamp(0.5rem, 1.5vw, 1.75rem);
    align-items: center;
  }

  .nav-link {
    position: relative;
    font-size: 0.92rem;
    font-weight: 500;
    color: var(--color-ink-soft);
    padding: 0.5rem 0;
    transition: color var(--transition);
    letter-spacing: 0.01em;
  }

  .nav-link::after {
    content: '';
    position: absolute;
    left: 0;
    bottom: 0.2em;
    width: 100%;
    height: 1px;
    background: currentColor;
    transform: scaleX(0);
    transform-origin: right center;
    transition: transform 400ms var(--ease-out);
  }

  .nav-link:hover {
    color: var(--color-ink);
  }

  .nav-link:hover::after,
  .nav-link.active::after {
    transform: scaleX(1);
    transform-origin: left center;
  }

  .nav-link.active {
    color: var(--color-sage-deep);
  }

  .header-cta {
    padding: 0.7em 1.3em;
    font-size: 0.85rem;
  }

  .menu-toggle {
    display: none;
    width: 44px;
    height: 44px;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    gap: 5px;
    cursor: pointer;
    background: transparent;
    border: 1px solid var(--color-line);
    border-radius: var(--radius-pill);
  }

  .menu-toggle span {
    display: block;
    width: 18px;
    height: 1.5px;
    background: var(--color-ink);
    transition: all 300ms var(--ease-out);
    transform-origin: center;
  }

  .menu-toggle[aria-expanded='true'] span:nth-child(1) {
    transform: translateY(6.5px) rotate(45deg);
  }
  .menu-toggle[aria-expanded='true'] span:nth-child(2) { opacity: 0; }
  .menu-toggle[aria-expanded='true'] span:nth-child(3) {
    transform: translateY(-6.5px) rotate(-45deg);
  }

  .nav-mobile {
    background: var(--color-cream);
    border-top: 1px solid var(--color-line);
  }

  .nav-mobile ul {
    display: flex;
    flex-direction: column;
    padding: 1rem clamp(1.25rem, 4vw, 2.5rem) 2rem;
  }

  .mobile-link {
    display: block;
    padding: 1rem 0;
    font-family: var(--font-display);
font-size: 1.5rem;
    color: var(--color-ink);
    border-bottom: 1px solid var(--color-line-soft);
  }

  .mobile-link.active { color: var(--color-sage-deep); }

  .mobile-cta-wrap {
    margin-top: 1.5rem;
  }

  .mobile-cta-wrap .btn { width: 100%; justify-content: center; }

  @media (max-width: 960px) {
    .nav-desktop, .header-cta { display: none; }
    .menu-toggle { display: flex; }
  }
</style>

<script>
  // Sticky header scroll-state
  const header = document.querySelector('[data-header]') as HTMLElement | null;
  if (header) {
    const onScroll = () => {
      header.dataset.scrolled = window.scrollY > 12 ? 'true' : 'false';
    };
    onScroll();
    window.addEventListener('scroll', onScroll, { passive: true });
  }

  // Mobile menu toggle
  const toggle = document.querySelector('[data-menu-toggle]') as HTMLButtonElement | null;
  const mobileNav = document.querySelector('[data-mobile-nav]') as HTMLElement | null;
  if (toggle && mobileNav) {
    toggle.addEventListener('click', () => {
      const isOpen = toggle.getAttribute('aria-expanded') === 'true';
      toggle.setAttribute('aria-expanded', String(!isOpen));
      toggle.setAttribute('aria-label', isOpen ? 'Menü öffnen' : 'Menü schließen');
      if (isOpen) {
        mobileNav.setAttribute('hidden', '');
      } else {
        mobileNav.removeAttribute('hidden');
      }
    });

    // Close on link click
    mobileNav.querySelectorAll('a').forEach((link) => {
      link.addEventListener('click', () => {
        toggle.setAttribute('aria-expanded', 'false');
        mobileNav.setAttribute('hidden', '');
      });
    });
  }
</script>
