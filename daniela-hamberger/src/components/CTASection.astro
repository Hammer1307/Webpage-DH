---
export interface Props {
  eyebrow?: string;
  title: string;
  text?: string;
  primaryCta?: { label: string; href: string };
  secondaryCta?: { label: string; href: string };
  variant?: 'cream' | 'sage' | 'paper';
  note?: string;
}

const {
  eyebrow,
  title,
  text,
  primaryCta = { label: 'Kostenfreies Orientierungsgespräch buchen', href: '/kontakt' },
  secondaryCta,
  variant = 'sage',
  note = '15–30 Minuten · unverbindlich · online oder telefonisch',
} = Astro.props;
---
<section class:list={['cta-section', `variant-${variant}`]}>
  <div class="container">
    <div class="cta-inner">
      {eyebrow && <span class="eyebrow">{eyebrow}</span>}
      <h2 class="cta-title">{title}</h2>
      {text && <p class="cta-text">{text}</p>}

      <div class="cta-buttons">
        <a href={primaryCta.href} class="btn btn-primary">{primaryCta.label}</a>
        {secondaryCta && (
          <a href={secondaryCta.href} class="btn btn-secondary">{secondaryCta.label}</a>
        )}
      </div>

      <p class="cta-note">{note}</p>
    </div>
  </div>
</section>

<style>
  .cta-section { position: relative; overflow: hidden; }

  .variant-sage {
    background: var(--color-sage-deep);
    color: var(--color-cream);
  }

  .variant-sage::before {
    content: '';
    position: absolute;
    inset: 0;
    background:
      radial-gradient(circle at 80% 20%, rgba(245, 239, 230, 0.06), transparent 40%),
      radial-gradient(circle at 10% 90%, rgba(185, 127, 90, 0.08), transparent 50%);
    pointer-events: none;
  }

  .variant-cream { background: var(--color-cream-deep); }
  .variant-paper { background: var(--color-paper); }

  .cta-inner {
    text-align: center;
    max-width: 56rem;
    margin: 0 auto;
    position: relative;
  }

  .variant-sage .eyebrow {
    color: var(--color-sage-pale);
  }

  .variant-sage .eyebrow::before {
    background: var(--color-sage-pale);
  }

  .cta-title {
    font-size: var(--step-4);
    margin: 0.6rem auto 1.5rem;
    max-width: 22ch;
  }

  .variant-sage .cta-title { color: var(--color-cream); }

  .cta-text {
    font-size: var(--step-1);
    line-height: 1.55;
    color: inherit;
    opacity: 0.85;
    max-width: 38rem;
    margin: 0 auto var(--space-l);
    font-weight: 300;
  }

  .cta-buttons {
    display: flex;
    gap: 1rem;
    justify-content: center;
    flex-wrap: wrap;
    margin-bottom: 1.25rem;
  }

  .variant-sage .btn-primary {
    background: var(--color-cream);
    color: var(--color-ink);
  }
  .variant-sage .btn-primary:hover {
    background: var(--color-clay-soft);
    color: var(--color-ink);
  }

  .variant-sage .btn-secondary {
    color: var(--color-cream);
    border-color: var(--color-cream);
  }
  .variant-sage .btn-secondary:hover {
    background: var(--color-cream);
    color: var(--color-ink);
  }

  .cta-note {
    font-size: 0.85rem;
    opacity: 0.7;
    margin: 0;
    letter-spacing: 0.02em;
  }
</style>
