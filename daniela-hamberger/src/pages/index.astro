---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { SITE, IMAGES, METHODEN_LISTE, VENUE } from '@/data/site';

const description =
  'Daniela Britta Hamberger — Mentorin mit pädagogischer Expertise für innere Stabilität, bewusste Entwicklung und gelingendes Miteinander. Fokus Schöner Leben: Innere Ordnung. Neue Klarheit. Freude am Leben.';
---
<BaseLayout
  title={`${SITE.name} · ${SITE.brand}`}
  description={description}
>
  {/* ============== HERO — Split: Text + Portrait Daniela ============== */}
  <section class="hero">
    <div class="container hero-inner">
      <div class="hero-text">
        <span class="eyebrow">Mentoring für Frauen · Workshops für Teams</span>

        <h1 class="hero-title">Wenn du spürst:<br /><em>Es darf wieder klarer werden</em></h1>

        <p class="hero-lead">
          Innere Ordnung. Neue Klarheit. Freude am Leben.
        </p>

        <p class="hero-body">
          Ich begleite <strong>Frauen in 1:1-Sessions</strong> und <strong>Teams in Workshops</strong> dabei,
          wieder mehr Klarheit, Stabilität und Lebensfreude zu finden — online oder
          vor Ort in Wiesbaden.
        </p>

        <div class="hero-actions">
          <a href="/kontakt" class="btn btn-primary">Kostenfreies Orientierungsgespräch buchen</a>
          <a href="/1-zu-1-begleitung" class="btn btn-secondary">1:1 Begleitung für Frauen entdecken</a>
        </div>

        <p class="price-hint">
          <strong>Kostenfreies Erstgespräch</strong> · Sitzungen ab 160 € · online oder in Wiesbaden
        </p>
      </div>

      <div class="hero-visual">
        <img src={IMAGES.danielaHeroPortrait} alt="Daniela Britta Hamberger — Mentorin für innere Stabilität und bewusste Entwicklung" class="hero-photo" loading="eager" fetchpriority="high" />
      </div>
    </div>
  </section>

  {/* ============== SERVICE-STRIP — Was bietet Daniela konkret? ============== */}
  <section class="section-tight service-strip">
    <div class="container">
      <div class="service-strip-head">
        <span class="eyebrow">Drei Wege, miteinander zu arbeiten</span>
      </div>
      <div class="service-strip-grid">
        <article class="service-card">
          <span class="service-card-label">01 — Für Frauen</span>
          <h3>1:1 Begleitung</h3>
          <p>Für Frauen, die wieder bei sich selbst ankommen, neu sortieren oder klarer entscheiden möchten. Online oder in Wiesbaden.</p>
          <p class="service-card-price">Erstgespräch kostenfrei · <strong>Sitzungen ab 160 €</strong></p>
          <a href="/1-zu-1-begleitung" class="service-card-link">Zur 1:1 Begleitung →</a>
        </article>

        <article class="service-card">
          <span class="service-card-label">02 — Für Teams</span>
          <h3>Workshops &amp; Vorträge</h3>
          <p>TeamBalance, TeamReset und Impulsvorträge für Teams, Einrichtungen und Organisationen, die ihr Miteinander stärken möchten.</p>
          <p class="service-card-price">Impulsvortrag <strong>ab 450 €</strong> · TeamBalance <strong>ab 890 €</strong></p>
          <a href="/teams-workshops" class="service-card-link">Zu Teams &amp; Workshops →</a>
        </article>

        <article class="service-card">
          <span class="service-card-label">03 — Zum Mitnehmen</span>
          <h3>Bücher &amp; Karten</h3>
          <p>Selbstcoaching-Buch <em>Zurück zu dir</em>, mythologische Weisheitsgeschichte <em>Das Vermächtnis des Herzens</em> und Coaching-Karten — in Vorbereitung.</p>
          <p class="service-card-price">Bei Erscheinen informieren lassen</p>
          <a href="/publikationen-materialien" class="service-card-link">Zu den Publikationen →</a>
        </article>
      </div>
    </div>
  </section>

  {/* ============== ICH BIN DANIELA — Teaser ============== */}
  <section class="section daniela-teaser">
    <div class="container daniela-teaser-grid">
      <div class="daniela-teaser-image">
        <img src={IMAGES.danielaPortrait} alt="Daniela Britta Hamberger" loading="lazy" />
      </div>
      <div class="daniela-teaser-text">
        <span class="eyebrow">Schön, dass du da bist</span>
        <h2>Ich bin <em>Daniela</em></h2>
        <p class="lead">
          Mentorin mit pädagogischer Expertise für innere Stabilität,
          bewusste Entwicklung und gelingendes Miteinander.
        </p>
        <p>
          Viele Jahre war ich als Pädagogin und Lehrerin in der Sekundarstufe&nbsp;I
          tätig. Heute verbinde ich diese Erfahrung mit Mentaltraining, Hypnose,
          Achtsamkeit, positiver Psychologie, einem systemischen Blick und weiteren
          ganzheitlichen Ansätzen.
        </p>
        <p>
          Im Mittelpunkt steht für mich der Mensch — mit seiner Geschichte,
          seinen Bedürfnissen und seinem Wunsch nach mehr Klarheit, Selbstvertrauen
          und Lebensfreude.
        </p>
        <div class="btn-group">
          <a href="/ueber-mich" class="btn btn-secondary">Mehr über mich erfahren</a>
        </div>
      </div>
    </div>
  </section>

  {/* ============== METHODENLEISTE — nur einmal ============== */}
  <section class="section-tight methoden-leiste">
    <div class="container">
      <div class="ornament"><span>Mein Begleitansatz</span></div>
      <ul class="methoden-list">
        {METHODEN_LISTE.map((m) => <li>{m}</li>)}
      </ul>
    </div>
  </section>

  {/* ============== RAUM (Wiesbaden / Schöne Aussichten) ============== */}
  <section class="section bg-cream raum-section">
    <div class="container raum-grid">
      <div class="raum-text">
        <span class="eyebrow">Ein Raum, der Entwicklung unterstützt</span>
        <h2>Ein stimmiger Rahmen für <em>innere Ordnung und bewusste Entwicklung</em></h2>
        <p>Manchmal braucht Veränderung nicht nur Zeit, sondern auch einen passenden Rahmen.</p>
        <p>Für ausgewählte Begleitungen, Workshops und Teamformate arbeite ich nach Absprache in stimmigen Räumlichkeiten in Wiesbaden. Der <strong>{VENUE.name}</strong> bietet dafür eine ruhige, wertschätzende Atmosphäre, in der Abstand zum Alltag entstehen darf.</p>
        <p>Mir ist wichtig, dass ganzheitliches Wohlbefinden nicht nur im Inneren beginnt, sondern auch durch eine passende äußere Umgebung unterstützt wird: durch Ruhe, Klarheit, eine angenehme Atmosphäre und einen Raum, in dem Menschen ankommen, sich öffnen und neu sortieren können.</p>
        <p>Hier darf entstehen, was im Alltag oft zu kurz kommt: Innehalten, bewusster Austausch, neue Perspektiven und ein geschützter Rahmen für innere Ordnung und Entwicklung.</p>
        <aside class="raum-note">
          <strong>Wichtig:</strong> Der Seminarraum wird nicht extern über die Website gebucht. Termine, Workshops und Vor-Ort-Formate werden ausschließlich über Daniela Britta Hamberger abgestimmt.
        </aside>
        <div class="btn-group">
          <a href="/kontakt" class="btn btn-primary">Gespräch buchen</a>
        </div>
      </div>
      <div class="raum-gallery">
        <img src={IMAGES.raumMeditation} alt={`Meditationskreis im ${VENUE.name}, Wiesbaden`} loading="lazy" class="raum-img raum-img-large" />
        <img src={IMAGES.raumBestuhlung} alt="Lichtdurchfluteter Dachraum mit zwei türkisen Stühlen und gemütlichem Ambiente" loading="lazy" class="raum-img" />
        <img src={IMAGES.raumEingang} alt="Detail im Eingangsbereich — Mosaikspiegel, Libelle und natürliche Akzente" loading="lazy" class="raum-img" />
      </div>
    </div>
  </section>

  {/* ============== FINAL CTA ============== */}
  <section class="section bg-sage final-cta">
    <div class="container-narrow" style="text-align: center;">
      <h2>Lass uns kennenlernen</h2>
      <p style="margin: 1rem auto 2rem; max-width: 50ch;">
        Wenn du spürst, dass du dir mehr Klarheit, innere Stabilität oder neue Orientierung wünschst, lade ich dich herzlich zu einem kostenfreien Orientierungsgespräch ein. 15–30 Minuten · unverbindlich · online oder telefonisch.
      </p>
      <div class="btn-group btn-group-center">
        <a href="/kontakt" class="btn btn-gold">Kostenfreies Orientierungsgespräch buchen</a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  /* ============== HERO ============== */
  .hero {
    padding-top: clamp(2rem, 4vw, 3.5rem);
    padding-bottom: clamp(3.5rem, 7vw, 6rem);
    background: var(--color-cream);
  }
  .hero-inner {
    display: grid;
    grid-template-columns: 1fr;
    gap: clamp(1.5rem, 4vw, 3rem);
    align-items: start;
  }
  /* Logo prominent zentral oben */
  .hero-text { max-width: 38rem; }
  .hero-title {
    font-size: var(--step-5);
    line-height: 1.02;
    letter-spacing: -0.025em;
    margin: 0 0 1.5rem;
    color: var(--color-ink);
  }
  .hero-title em { color: var(--color-sage-deep); font-style: italic; display: block; margin-top: 0.1em; }
  .hero-lead {
    font-family: var(--font-display);
    font-size: var(--step-2);
    line-height: 1.3;
    color: var(--color-ink);
    font-weight: 400;
    font-style: italic;
    max-width: 30ch;
    margin-bottom: 1.25rem;
  }
  .hero-body {
    color: var(--color-ink-soft);
    line-height: 1.65;
    margin-bottom: 1rem;
    max-width: 44ch;
  }
  .hero-actions {
    display: flex;
    gap: 0.85rem;
    flex-wrap: wrap;
    margin-top: 2rem;
  }
  .price-hint {
    margin-top: 1.5rem;
    font-size: 0.9rem;
    color: var(--color-ink-muted);
    letter-spacing: 0.01em;
    max-width: none;
  }
  .price-hint strong { color: var(--color-sage-deep); font-weight: 600; }
  .hero-visual { position: relative; }
  .hero-photo {
    aspect-ratio: 4 / 5;
    max-width: 30rem;
    width: 100%;
    margin-inline: auto;
    display: block;
    border-radius: var(--radius-l);
    object-fit: cover;
    object-position: center 30%;
    box-shadow: var(--shadow-lift);
  }
  @media (min-width: 960px) {
    .hero-inner {
      grid-template-columns: 1.05fr 0.95fr;
      column-gap: clamp(2.5rem, 5vw, 4rem);
    }
  }
  @media (max-width: 859px) {
    .hero-visual { order: -1; margin-bottom: 1.5rem; }
    .hero-photo { aspect-ratio: 3 / 2; max-width: 24rem; }
  }

  /* ============== SERVICE-STRIP — kompakte 3 Angebote ============== */
  .service-strip { background: var(--color-cream); padding-block: clamp(2rem, 4vw, 3rem); border-top: 1px solid var(--color-line-soft); }
  .service-strip-head { text-align: center; margin-bottom: 1.75rem; }
  .service-strip-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.25rem;
  }
  .service-card {
    background: var(--color-paper);
    border: 1px solid var(--color-line);
    border-radius: var(--radius-m);
    padding: 1.75rem 1.5rem 1.5rem;
    display: flex;
    flex-direction: column;
    transition: transform 280ms, box-shadow 280ms, border-color 280ms;
  }
  .service-card:hover {
    transform: translateY(-2px);
    box-shadow: var(--shadow-card);
    border-color: var(--color-clay-pale);
  }
  .service-card-label {
    font-size: 0.72rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--color-clay);
    font-weight: 600;
    margin-bottom: 0.5rem;
  }
  .service-card h3 {
    font-family: var(--font-display);
    font-size: 1.75rem;
    color: var(--color-ink);
    margin-bottom: 0.75rem;
    line-height: 1.1;
    font-weight: 400;
  }
  .service-card > p {
    font-size: 0.93rem;
    color: var(--color-ink-soft);
    line-height: 1.55;
    margin-bottom: 1rem;
    flex: 1;
  }
  .service-card-price {
    font-size: 0.85rem;
    color: var(--color-ink-muted) !important;
    border-top: 1px solid var(--color-line-soft);
    padding-top: 0.75rem;
    margin-top: auto;
    margin-bottom: 0.75rem !important;
    flex: 0 0 auto !important;
  }
  .service-card-price strong { color: var(--color-sage-deep); font-weight: 600; }
  .service-card-link {
    color: var(--color-sage-deep);
    font-weight: 500;
    font-size: 0.9rem;
    text-decoration: none;
    transition: gap 280ms, color 280ms;
    display: inline-flex;
    gap: 0.3rem;
  }
  .service-card-link:hover { color: var(--color-ink); gap: 0.55rem; }
  @media (max-width: 960px) {
    .service-strip-grid { grid-template-columns: 1fr; gap: 1rem; }
  }

  /* ============== ICH BIN DANIELA — Teaser ============== */
  .daniela-teaser {
    background: var(--color-cream-soft);
    border-top: 1px solid var(--color-line-soft);
  }
  .daniela-teaser-grid {
    display: grid;
    grid-template-columns: 0.9fr 1.1fr;
    gap: clamp(2rem, 5vw, 4rem);
    align-items: center;
  }
  .daniela-teaser-image img {
    aspect-ratio: 4 / 5;
    width: 100%;
    max-width: 24rem;
    object-fit: cover;
    object-position: center top;
    border-radius: var(--radius-l);
    box-shadow: var(--shadow-card);
    margin-inline: auto;
    display: block;
  }
  .daniela-teaser-text h2 { margin: 0.5rem 0 1.25rem; }
  .daniela-teaser-text .lead { margin-bottom: 1.5rem; max-width: 38ch; }
  .daniela-teaser-text p { margin-bottom: 1rem; max-width: 50ch; }
  @media (max-width: 859px) {
    .daniela-teaser-grid { grid-template-columns: 1fr; }
    .daniela-teaser-image img { max-width: 20rem; }
  }

  /* ============== METHODENLEISTE ============== */
  .methoden-leiste { background: var(--color-cream-soft); border-top: 1px solid var(--color-line-soft); border-bottom: 1px solid var(--color-line-soft); }
  .methoden-leiste .ornament { color: var(--color-sage); font-family: var(--font-display); font-style: italic; font-size: var(--step-1); margin-bottom: 1.25rem; }
  .methoden-list {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 0.5rem 0.75rem;
    list-style: none;
    padding: 0;
  }
  .methoden-list li {
    display: inline-block;
    padding: 0.55em 1.15em;
    background: var(--color-paper);
    color: var(--color-sage-deep);
    border: 1px solid var(--color-line);
    border-radius: var(--radius-pill);
    font-size: 0.85rem;
    letter-spacing: 0.02em;
    font-weight: 500;
  }

  /* ============== 3 WEGE ============== */
  .wege-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(min(100%, 18rem), 1fr)); gap: 1.5rem; }
  .weg-card {
    background: var(--color-paper);
    border: 1px solid var(--color-line);
    border-top: 4px solid var(--color-clay);
    border-radius: var(--radius-l);
    padding: clamp(1.75rem, 3vw, 2.5rem);
    transition: all var(--transition);
    position: relative;
    display: flex;
    flex-direction: column;
  }
  .weg-card:hover { box-shadow: var(--shadow-card); transform: translateY(-3px); }
  .weg-number { font-family: var(--font-display); font-style: italic; color: var(--color-clay); font-size: 1.25rem; letter-spacing: 0.08em; margin-bottom: 0.5rem; }
  .weg-card h3 { margin-bottom: 0.75rem; }
  .weg-sub { color: var(--color-sage-deep); margin-bottom: 1rem; font-size: 0.95rem; line-height: 1.5; max-width: none; }
  .weg-sub em { color: var(--color-sage-deep); }
  .weg-card p { margin-bottom: 1.25rem; flex: 1; font-size: 0.95rem; max-width: none; }
  .weg-card .btn { align-self: flex-start; margin-top: auto; }

  /* ============== RAUM-SECTION ============== */
  .raum-grid { display: grid; grid-template-columns: 1fr; gap: clamp(2rem, 4vw, 3rem); align-items: start; }
  @media (min-width: 900px) { .raum-grid { grid-template-columns: 1fr 0.95fr; } }
  .raum-text h2 { margin: 0.5rem 0 1.25rem; }
  .raum-text p { margin-bottom: 1rem; }
  .raum-note { background: var(--color-cream-deep); border-left: 3px solid var(--color-sage); padding: 1rem 1.25rem; margin: 1.25rem 0; font-size: 0.92rem; border-radius: 0 var(--radius-s) var(--radius-s) 0; color: var(--color-ink-soft); }
  .raum-note strong { color: var(--color-sage-deep); }
  .raum-gallery { display: grid; grid-template-columns: 1fr 1fr; grid-template-rows: auto auto; gap: 0.75rem; }
  .raum-img { width: 100%; height: 100%; object-fit: cover; border-radius: var(--radius-m); box-shadow: var(--shadow-soft); }
  .raum-img-large { grid-column: 1 / -1; aspect-ratio: 16/9; }
  .raum-img:not(.raum-img-large) { aspect-ratio: 1/1; }
</style>
