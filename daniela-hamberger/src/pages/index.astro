---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { SITE, IMAGES, METHODEN_LISTE, VENUE } from '@/data/site';

const description =
  'Mentorin & Coach in Wiesbaden, Idstein und online. Fokus Schöner Leben: innere Stabilität, Klarheit und gelingendes Miteinander für Frauen & Teams.';
---
<BaseLayout
  title={`${SITE.name} · ${SITE.brand}`}
  description={description}
>
  {/* ============== HERO — Split: Text + Portrait Daniela ============== */}
  <section class="hero">
    <div class="container hero-inner">
      <div class="hero-text">
        <span class="eyebrow">Mentoring für Frauen · Mentoring, Workshops und Vorträge für Teams</span>

        <h1 class="hero-title">Wenn du spürst:<br /><em>Es darf wieder klarer werden</em></h1>

        <p class="hero-lead">
          Innere Ordnung. Neue Klarheit. Freude am Leben.
        </p>

        <p class="hero-body">
          Ich begleite <strong>Frauen in 1:1-Sessions</strong> und <strong>Teams</strong> dabei,
          wieder mehr Klarheit, Bewusstsein und innere Stabilität zu finden — online sowie vor Ort
          in Wiesbaden, Idstein oder nach Absprache bei euch im Rhein-Main-Gebiet.
        </p>

        <div class="hero-actions">
          <button type="button" class="btn btn-primary" data-modal-open="1zu1" data-format="orientierung">Kostenfreies Orientierungsgespräch buchen</button>
        </div>

        <p class="price-hint">
          <strong>Kostenfreies Erstgespräch</strong> · Sitzungen ab 160 € · online oder vor Ort in Wiesbaden / Idstein
        </p>
      </div>

      <div class="hero-visual">
        <img src={IMAGES.danielaHeroPortrait} alt="Daniela Britta Hamberger — Mentorin für innere Stabilität und bewusste Entwicklung" class="hero-photo" loading="eager" fetchpriority="high" />
      </div>
    </div>
  </section>

  {/* ============== SERVICE-STRIP — Was bietet Daniela konkret? ============== */}
  <section class="section-tight service-strip">
    <div class="container">
      <div class="service-strip-head">
        <span class="eyebrow">Drei Wege, miteinander zu arbeiten</span>
      </div>
      <div class="service-strip-grid">
        <article class="service-card">
          <span class="service-card-label">01 — Für Frauen</span>
          <h3>1:1 Begleitung</h3>
          <p>Für Frauen, die wieder bei sich selbst ankommen, neu sortieren oder klarer entscheiden möchten. Online oder in Wiesbaden.</p>
          <p class="service-card-price">Erstgespräch kostenfrei · <strong>Sitzungen ab 160 €</strong></p>
          <a href="/1-zu-1-begleitung" class="service-card-link">Zur 1:1 Begleitung →</a>
        </article>

        <article class="service-card">
          <span class="service-card-label">02 — Für Teams</span>
          <h3>Workshops &amp; Vorträge</h3>
          <p>TeamBalance, Team Reset Mentoring und Impulsvorträge für Teams, Einrichtungen und Organisationen, die ihr Miteinander stärken möchten.</p>
          <p class="service-card-price">Impulsvortrag <strong>ab 450 €</strong> · TeamBalance <strong>ab 890 €</strong></p>
          <a href="/teams-workshops" class="service-card-link">Zu Teams &amp; Workshops →</a>
        </article>

        <article class="service-card">
          <span class="service-card-label">03 — Zum Mitnehmen</span>
          <h3>Bücher &amp; Karten</h3>
          <p>Selbstcoaching-Buch <em>Zurück zu dir</em>, mythologische Weisheitsgeschichte <em>Das Vermächtnis des Herzens</em> und Coaching-Karten — in Vorbereitung.</p>
          <p class="service-card-price">Bei Erscheinen informieren lassen</p>
          <a href="/publikationen-materialien" class="service-card-link">Zu den Publikationen →</a>
        </article>
      </div>
    </div>
  </section>

  {/* ============== ICH BIN DANIELA — Teaser ============== */}
  <section class="section daniela-teaser">
    <div class="container daniela-teaser-grid">
      <div class="daniela-teaser-image">
        <img src={IMAGES.danielaWieseBluse} alt="Daniela Britta Hamberger — sitzend in einer sommerlichen Wiese" loading="lazy" />
      </div>
      <div class="daniela-teaser-text">
        <span class="eyebrow">Schön, dass du da bist</span>
        <h2>Ich bin <em>Daniela</em></h2>
        <p class="lead">
          Mentorin mit pädagogischer Expertise für <strong>Bewusstsein</strong>,
          innere Stabilität und gelingendes Miteinander.
        </p>
        <p>
          Viele Jahre war ich als Pädagogin und Lehrerin in der Sekundarstufe&nbsp;I
          tätig. Heute verbinde ich diese Erfahrung mit Mentaltraining,
          Bewusstseinsarbeit, positiver Psychologie, einem systemischen Blick und weiteren
          ganzheitlichen Ansätzen.
        </p>
        <p>
          In meiner Arbeit geht es darum, Bewusstsein zu schaffen — für sich selbst, für
          das eigene Denken und Fühlen, für Beziehungen und für die feinen Dynamiken, die
          unser Leben und Miteinander prägen.
        </p>
        <div class="btn-group">
          <a href="/ueber-mich" class="btn btn-secondary">Mehr über mich erfahren</a>
        </div>
      </div>
    </div>
  </section>

  {/* ============== METHODENLEISTE — nur einmal ============== */}
  <section class="section-tight methoden-leiste">
    <div class="container">
      <div class="ornament"><span>Mein Begleitansatz</span></div>
      <ul class="methoden-list">
        {METHODEN_LISTE.map((m) => <li>{m}</li>)}
      </ul>
      <p class="methoden-link">
        <a href="/ueber-mich#methoden">Mehr zu meinen Methoden →</a>
      </p>
    </div>
  </section>

  {/* ============== STANDORTE — kompakt, nicht venue-fokussiert ============== */}
  <section class="section bg-cream standorte-section">
    <div class="container">
      <div class="standorte-head">
        <span class="eyebrow">Wo wir uns begegnen</span>
        <h2>Online sowie vor Ort in <em>Wiesbaden, Idstein oder bei euch</em></h2>
        <p class="lead">
          Begleitungen, Coachings und Workshops finden online, in geeigneten Räumlichkeiten in
          Wiesbaden oder Idstein oder nach Absprache direkt bei euch vor Ort im Rhein-Main-Gebiet
          statt.
        </p>
      </div>
      <div class="standorte-grid">
        <div class="standort-card">
          <h3>Online</h3>
          <p>Per Video oder Telefon — ortsunabhängig, flexibel und für viele Anliegen genauso wirksam wie ein Vor-Ort-Termin.</p>
        </div>
        <div class="standort-card">
          <h3>Wiesbaden &amp; Idstein</h3>
          <p>Für 1:1 Begleitungen und kleinere Gruppen nutze ich nach Absprache ruhige Räumlichkeiten — unter anderem den Seminarraum Schöne Aussichten in Wiesbaden.</p>
        </div>
        <div class="standort-card">
          <h3>Bei euch vor Ort</h3>
          <p>Für Teams und Organisationen im Rhein-Main-Gebiet komme ich nach Absprache zu euch — in eure Räume oder an einen geeigneten externen Ort.</p>
        </div>
      </div>
    </div>
  </section>

  {/* ============== FINAL CTA ============== */}
  <section class="section bg-sage final-cta">
    <div class="container-narrow" style="text-align: center;">
      <h2>Lass uns kennenlernen</h2>
      <p style="margin: 1rem auto 2rem; max-width: 50ch;">
        Wenn du spürst, dass du dir mehr Klarheit, innere Stabilität oder neue Orientierung wünschst, lade ich dich herzlich zu einem kostenfreien Orientierungsgespräch ein. 15–30 Minuten · unverbindlich · online sowie vor Ort in Wiesbaden, Idstein oder telefonisch.
      </p>
      <div class="btn-group btn-group-center">
        <button type="button" class="btn btn-gold" data-modal-open="1zu1" data-format="orientierung">Kostenfreies Orientierungsgespräch buchen</button>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  /* ============== HERO ============== */
  .hero {
    padding-top: clamp(2rem, 4vw, 3.5rem);
    padding-bottom: clamp(3.5rem, 7vw, 6rem);
    background: var(--color-cream);
  }
  .hero-inner {
    display: grid;
    grid-template-columns: 1fr;
    gap: clamp(1.5rem, 4vw, 3rem);
    align-items: start;
  }
  /* Logo prominent zentral oben */
  .hero-text { max-width: 38rem; }
  .hero-title {
    font-size: var(--step-5);
    line-height: 1.02;
    letter-spacing: -0.025em;
    margin: 0 0 1.5rem;
    color: var(--color-ink);
  }
  .hero-title em { color: var(--color-sage-deep); font-style: italic; display: block; margin-top: 0.1em; }
  .hero-lead {
    font-family: var(--font-display);
    font-size: var(--step-2);
    line-height: 1.3;
    color: var(--color-ink);
    font-weight: 400;
    font-style: italic;
    max-width: 30ch;
    margin-bottom: 1.25rem;
  }
  .hero-body {
    color: var(--color-ink-soft);
    line-height: 1.65;
    margin-bottom: 1rem;
    max-width: 44ch;
  }
  .hero-actions {
    display: flex;
    gap: 0.85rem;
    flex-wrap: wrap;
    margin-top: 2rem;
  }
  .price-hint {
    margin-top: 1.5rem;
    font-size: 0.9rem;
    color: var(--color-ink-muted);
    letter-spacing: 0.01em;
    max-width: none;
  }
  .price-hint strong { color: var(--color-sage-deep); font-weight: 600; }
  .hero-visual { position: relative; }
  .hero-photo {
    aspect-ratio: 4 / 5;
    max-width: 30rem;
    width: 100%;
    margin-inline: auto;
    display: block;
    border-radius: var(--radius-l);
    object-fit: cover;
    object-position: center 30%;
    box-shadow: var(--shadow-lift);
  }
  @media (min-width: 960px) {
    .hero-inner {
      grid-template-columns: 1.05fr 0.95fr;
      column-gap: clamp(2.5rem, 5vw, 4rem);
    }
  }
  @media (max-width: 859px) {
    .hero-visual { order: -1; margin-bottom: 1.5rem; }
    .hero-photo { aspect-ratio: 3 / 2; max-width: 24rem; }
  }

  /* ============== SERVICE-STRIP — kompakte 3 Angebote ============== */
  .service-strip { background: var(--color-cream); padding-block: clamp(2rem, 4vw, 3rem); border-top: 1px solid var(--color-line-soft); }
  .service-strip-head { text-align: center; margin-bottom: 1.75rem; }
  .service-strip-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.25rem;
  }
  .service-card {
    background: var(--color-paper);
    border: 1px solid var(--color-line);
    border-radius: var(--radius-m);
    padding: 1.75rem 1.5rem 1.5rem;
    display: flex;
    flex-direction: column;
    transition: transform 280ms, box-shadow 280ms, border-color 280ms;
  }
  .service-card:hover {
    transform: translateY(-2px);
    box-shadow: var(--shadow-card);
    border-color: var(--color-clay-pale);
  }
  .service-card-label {
    font-size: 0.72rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--color-clay);
    font-weight: 600;
    margin-bottom: 0.5rem;
  }
  .service-card h3 {
    font-family: var(--font-display);
    font-size: 1.75rem;
    color: var(--color-ink);
    margin-bottom: 0.75rem;
    line-height: 1.1;
    font-weight: 400;
  }
  .service-card > p {
    font-size: 0.93rem;
    color: var(--color-ink-soft);
    line-height: 1.55;
    margin-bottom: 1rem;
    flex: 1;
  }
  .service-card-price {
    font-size: 0.85rem;
    color: var(--color-ink-muted) !important;
    border-top: 1px solid var(--color-line-soft);
    padding-top: 0.75rem;
    margin-top: auto;
    margin-bottom: 0.75rem !important;
    flex: 0 0 auto !important;
  }
  .service-card-price strong { color: var(--color-sage-deep); font-weight: 600; }
  .service-card-link {
    color: var(--color-sage-deep);
    font-weight: 500;
    font-size: 0.9rem;
    text-decoration: none;
    transition: gap 280ms, color 280ms;
    display: inline-flex;
    gap: 0.3rem;
  }
  .service-card-link:hover { color: var(--color-ink); gap: 0.55rem; }
  @media (max-width: 960px) {
    .service-strip-grid { grid-template-columns: 1fr; gap: 1rem; }
  }

  /* ============== ICH BIN DANIELA — Teaser ============== */
  .daniela-teaser {
    background: var(--color-cream-soft);
    border-top: 1px solid var(--color-line-soft);
  }
  .daniela-teaser-grid {
    display: grid;
    grid-template-columns: 0.9fr 1.1fr;
    gap: clamp(2rem, 5vw, 4rem);
    align-items: center;
  }
  .daniela-teaser-image img {
    aspect-ratio: 4 / 5;
    width: 100%;
    max-width: 24rem;
    object-fit: cover;
    object-position: center top;
    border-radius: var(--radius-l);
    box-shadow: var(--shadow-card);
    margin-inline: auto;
    display: block;
  }
  .daniela-teaser-text h2 { margin: 0.5rem 0 1.25rem; }
  .daniela-teaser-text .lead { margin-bottom: 1.5rem; max-width: 38ch; }
  .daniela-teaser-text p { margin-bottom: 1rem; max-width: 50ch; }
  @media (max-width: 859px) {
    .daniela-teaser-grid { grid-template-columns: 1fr; }
    .daniela-teaser-image img { max-width: 20rem; }
  }

  /* ============== METHODENLEISTE ============== */
  .methoden-leiste { background: var(--color-cream-soft); border-top: 1px solid var(--color-line-soft); border-bottom: 1px solid var(--color-line-soft); }
  .methoden-leiste .ornament { color: var(--color-sage); font-family: var(--font-display); font-style: italic; font-size: var(--step-1); margin-bottom: 1.25rem; }
  .methoden-list {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 0.5rem 0.75rem;
    list-style: none;
    padding: 0;
  }
  .methoden-list li {
    display: inline-block;
    padding: 0.55em 1.15em;
    background: var(--color-paper);
    color: var(--color-sage-deep);
    border: 1px solid var(--color-line);
    border-radius: var(--radius-pill);
    font-size: 0.85rem;
    letter-spacing: 0.02em;
    font-weight: 500;
  }

  /* ============== 3 WEGE ============== */
  .wege-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(min(100%, 18rem), 1fr)); gap: 1.5rem; }
  .weg-card {
    background: var(--color-paper);
    border: 1px solid var(--color-line);
    border-top: 4px solid var(--color-clay);
    border-radius: var(--radius-l);
    padding: clamp(1.75rem, 3vw, 2.5rem);
    transition: all var(--transition);
    position: relative;
    display: flex;
    flex-direction: column;
  }
  .weg-card:hover { box-shadow: var(--shadow-card); transform: translateY(-3px); }
  .weg-number { font-family: var(--font-display); font-style: italic; color: var(--color-clay); font-size: 1.25rem; letter-spacing: 0.08em; margin-bottom: 0.5rem; }
  .weg-card h3 { margin-bottom: 0.75rem; }
  .weg-sub { color: var(--color-sage-deep); margin-bottom: 1rem; font-size: 0.95rem; line-height: 1.5; max-width: none; }
  .weg-sub em { color: var(--color-sage-deep); }
  .weg-card p { margin-bottom: 1.25rem; flex: 1; font-size: 0.95rem; max-width: none; }
  .weg-card .btn { align-self: flex-start; margin-top: auto; }

  /* ============== STANDORTE-SECTION ============== */
  .standorte-head { text-align: center; max-width: 50rem; margin: 0 auto 2.5rem; }
  .standorte-head h2 { margin: 0.5rem 0 1.25rem; }
  .standorte-head .lead { max-width: 44ch; margin: 0 auto; }
  .standorte-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.25rem;
  }
  .standort-card {
    background: var(--color-paper);
    border: 1px solid var(--color-line);
    border-top: 3px solid var(--color-sage);
    border-radius: var(--radius-m);
    padding: 1.5rem 1.5rem 1.25rem;
  }
  .standort-card h3 {
    font-family: var(--font-display);
    font-size: 1.45rem;
    font-weight: 400;
    color: var(--color-ink);
    margin: 0 0 0.6rem;
    letter-spacing: -0.01em;
  }
  .standort-card p {
    font-size: 0.93rem;
    color: var(--color-ink-soft);
    line-height: 1.6;
    margin: 0;
    max-width: none;
  }
  @media (max-width: 860px) {
    .standorte-grid { grid-template-columns: 1fr; }
  }
</style>
