---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { SITE, IMAGES, METHODEN_LISTE, VENUE } from '@/data/site';

const description =
  'Daniela Britta Hamberger — Mentorin mit pädagogischer Expertise für innere Stabilität, bewusste Entwicklung und gelingendes Miteinander. Fokus Schöner Leben: Innere Ordnung. Neue Klarheit. Freude am Leben.';
---
<BaseLayout
  title={`${SITE.name} · ${SITE.brand}`}
  description={description}
>
  {/* ============== HERO — Logo oben prominent, kein Text-Doppel ============== */}
  <section class="hero">
    <div class="container hero-inner">
      <div class="hero-logo-wrap">
        <img src={IMAGES.logo} alt="Daniela Britta Hamberger — Fokus Schöner Leben (Phönix und Lotus)" class="hero-logo" loading="eager" fetchpriority="high" />
      </div>

      <div class="hero-text">
        <h1 class="hero-title">Wenn du spürst:<br /><em>Es darf wieder klarer werden</em></h1>

        <p class="hero-lead">
          Vielleicht hast du lange funktioniert, getragen, organisiert oder dich angepasst. Vielleicht stehst du vor einer Entscheidung, bist innerlich unruhig oder merkst: So wie bisher möchte ich nicht weitermachen.
        </p>

        <p class="hero-body">
          Ich begleite dich dabei, wieder mehr bei dir selbst anzukommen — mit innerer Ordnung, neuer Klarheit und mehr Vertrauen in deinen eigenen Weg.
        </p>

        <p class="hero-body">
          Mit langjähriger Erfahrung als <strong>Pädagogin und ehemalige Lehrerin in der Sekundarstufe&nbsp;I</strong> verbinde ich Mentaltraining, Hypnose, Achtsamkeit, positive Psychologie, Entspannungspädagogik, einen systemischen Blick auf Beziehungsdynamiken, PSYCH-K® sowie bioenergetische Zugänge.
        </p>

        <div class="hero-actions">
          <a href="/kontakt" class="btn btn-primary">Kostenfreies Orientierungsgespräch buchen</a>
          <a href="/1-zu-1-begleitung" class="btn btn-secondary">1:1 Begleitung für Frauen entdecken</a>
          <a href="/teams-workshops" class="btn btn-ghost">Teams &amp; Workshops ansehen</a>
        </div>
      </div>

      <div class="hero-visual">
        <img src={IMAGES.heroStartseite} alt="Stille Frühlingswiese mit Apfelbaum und einer einladenden Holzbank — Ankommen und innere Ordnung" class="hero-photo" loading="eager" />
      </div>
    </div>
  </section>

  {/* ============== METHODENLEISTE — nur einmal ============== */}
  <section class="section-tight methoden-leiste">
    <div class="container">
      <div class="ornament"><span>Mein Begleitansatz</span></div>
      <ul class="methoden-list">
        {METHODEN_LISTE.map((m) => <li>{m}</li>)}
      </ul>
    </div>
  </section>

  {/* ============== 3 WEGE ============== */}
  <section class="section bg-cream-soft">
    <div class="container">
      <header class="section-head">
        <span class="eyebrow">Wege, wie wir in Verbindung kommen können</span>
        <h2>Begleitung, Workshops, Bücher, <em>Impulse und kreative Arbeiten</em></h2>
        <p class="lead">
          Meine Arbeit zeigt sich auf unterschiedliche Weise: in der persönlichen 1:1 Begleitung, in Team-Workshops, in Büchern, Workbooks, Coaching-Karten, kreativen Arbeiten und Impulsen. Der rote Faden bleibt derselbe: innere Ordnung, neue Klarheit, Lebensfreude und ein wertschätzendes Miteinander.
        </p>
      </header>

      <div class="wege-grid">
        <article class="weg-card fade-up">
          <span class="weg-number">01</span>
          <h3>1:1 Begleitung</h3>
          <p class="weg-sub"><em>Besonders für Frauen, die wieder bei sich selbst ankommen möchten</em></p>
          <p>Vielleicht fühlst du dich müde vom Funktionieren. Vielleicht hast du lange für andere mitgedacht, dich angepasst oder deine eigenen Bedürfnisse übergangen. In meiner 1:1 Begleitung findest du einen geschützten Raum, in dem du dich sortieren, spüren und neu ausrichten kannst. Oft ist vieles bereits in dir angelegt: Kraft, Klarheit, Selbstwert, Lebensfreude und ein feines Gefühl für deinen nächsten Schritt.</p>
          <a href="/1-zu-1-begleitung" class="btn btn-ghost">Zur 1:1 Begleitung</a>
        </article>

        <article class="weg-card fade-up delay-1">
          <span class="weg-number">02</span>
          <h3>Teams &amp; Workshops</h3>
          <p class="weg-sub"><em>Wenn ihr wieder klarer, wertschätzender und menschlicher miteinander arbeiten möchtet</em></p>
          <p>Vielleicht arbeitet ihr zusammen, aber nicht immer wirklich miteinander. Kommunikation läuft aneinander vorbei. Wertschätzung ist eigentlich da, wird aber im Alltag zu selten spürbar. Ich begleite euch dabei, euer Miteinander bewusster wahrzunehmen und neue Wege für mehr Klarheit, Vertrauen, Empathie und Wertschätzung zu entwickeln.</p>
          <a href="/teams-workshops" class="btn btn-ghost">Zu Teams &amp; Workshops</a>
        </article>

        <article class="weg-card fade-up delay-2">
          <span class="weg-number">03</span>
          <h3>Publikationen, Kunst &amp; Impulse</h3>
          <p class="weg-sub"><em>Bücher, Workbooks, Coaching-Karten und kreative Arbeiten</em></p>
          <p>Als Autorin und Künstlerin beschäftige ich mich mit Themen, die auch meine Begleitung prägen: innere Ordnung, Menschlichkeit, Naturverbundenheit, Empathie, Lebensfreude, Sinnsuche und gelingendes Miteinander. Geplant sind unter anderem das Selbstcoachingbuch <em>Zurück zu dir</em>, das mythologische Buchprojekt <em>Das Vermächtnis des Herzens</em>, Coaching- und Impulskarten sowie ausgewählte kreative Arbeiten.</p>
          <a href="/publikationen-materialien" class="btn btn-ghost">Publikationen ansehen</a>
        </article>
      </div>
    </div>
  </section>

  {/* ============== RAUM (Wiesbaden / Schöne Aussichten) ============== */}
  <section class="section bg-cream raum-section">
    <div class="container raum-grid">
      <div class="raum-text">
        <span class="eyebrow">Ein Raum, der Entwicklung unterstützt</span>
        <h2>Ein stimmiger Rahmen für <em>innere Ordnung und bewusste Entwicklung</em></h2>
        <p>Manchmal braucht Veränderung nicht nur Zeit, sondern auch einen passenden Rahmen.</p>
        <p>Für ausgewählte Begleitungen, Workshops und Teamformate arbeite ich nach Absprache in stimmigen Räumlichkeiten in Wiesbaden. Der <strong>{VENUE.name}</strong> bietet dafür eine ruhige, wertschätzende Atmosphäre, in der Abstand zum Alltag entstehen darf.</p>
        <p>Mir ist wichtig, dass ganzheitliches Wohlbefinden nicht nur im Inneren beginnt, sondern auch durch eine passende äußere Umgebung unterstützt wird: durch Ruhe, Klarheit, eine angenehme Atmosphäre und einen Raum, in dem Menschen ankommen, sich öffnen und neu sortieren können.</p>
        <p>Hier darf entstehen, was im Alltag oft zu kurz kommt: Innehalten, bewusster Austausch, neue Perspektiven und ein geschützter Rahmen für innere Ordnung und Entwicklung.</p>
        <aside class="raum-note">
          <strong>Wichtig:</strong> Der Seminarraum wird nicht extern über die Website gebucht. Termine, Workshops und Vor-Ort-Formate werden ausschließlich über Daniela Britta Hamberger abgestimmt.
        </aside>
        <div class="btn-group">
          <a href="/kontakt" class="btn btn-primary">Gespräch buchen</a>
        </div>
      </div>
      <div class="raum-gallery">
        <img src={IMAGES.raumMeditation} alt={`Meditationskreis im ${VENUE.name}, Wiesbaden`} loading="lazy" class="raum-img raum-img-large" />
        <img src={IMAGES.raumBestuhlung} alt="Lichtdurchfluteter Dachraum mit zwei türkisen Stühlen und gemütlichem Ambiente" loading="lazy" class="raum-img" />
        <img src={IMAGES.raumEingang} alt="Detail im Eingangsbereich — Mosaikspiegel, Libelle und natürliche Akzente" loading="lazy" class="raum-img" />
      </div>
    </div>
  </section>

  {/* ============== FINAL CTA ============== */}
  <section class="section bg-sage final-cta">
    <div class="container-narrow" style="text-align: center;">
      <h2>Lass uns kennenlernen</h2>
      <p style="margin: 1rem auto 2rem; max-width: 50ch;">
        Wenn du spürst, dass du dir mehr Klarheit, innere Stabilität oder neue Orientierung wünschst, lade ich dich herzlich zu einem kostenfreien Orientierungsgespräch ein. 15–30 Minuten · unverbindlich · online oder telefonisch.
      </p>
      <div class="btn-group btn-group-center">
        <a href="/kontakt" class="btn btn-gold">Kostenfreies Orientierungsgespräch buchen</a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  /* ============== HERO ============== */
  .hero {
    padding-top: clamp(2rem, 4vw, 3.5rem);
    padding-bottom: clamp(3.5rem, 7vw, 6rem);
    background: var(--color-cream);
  }
  .hero-inner {
    display: grid;
    grid-template-columns: 1fr;
    gap: clamp(1.5rem, 4vw, 3rem);
    align-items: start;
  }
  /* Logo prominent zentral oben */
  .hero-logo-wrap {
    grid-column: 1 / -1;
    display: flex;
    justify-content: center;
    margin-bottom: 0.5rem;
  }
  .hero-logo {
    width: clamp(180px, 22vw, 280px);
    height: auto;
    display: block;
  }
  .hero-text { max-width: 42rem; }
  .hero-title {
    font-size: var(--step-5);
    line-height: 1.02;
    letter-spacing: -0.025em;
    margin: 0 0 1.5rem;
    color: var(--color-ink);
  }
  .hero-title em { color: var(--color-sage-deep); font-style: italic; display: block; margin-top: 0.1em; }
  .hero-lead {
    font-family: var(--font-display);
    font-size: var(--step-2);
    line-height: 1.3;
    color: var(--color-ink);
    font-weight: 400;
    font-style: italic;
    max-width: 34ch;
    margin-bottom: 1.25rem;
  }
  .hero-body {
    color: var(--color-ink-soft);
    line-height: 1.65;
    margin-bottom: 1rem;
    max-width: 44ch;
  }
  .hero-actions {
    display: flex;
    gap: 0.85rem;
    flex-wrap: wrap;
    margin-top: 2rem;
  }
  .hero-visual { position: relative; }
  .hero-photo {
    aspect-ratio: 4 / 3;
    width: 100%;
    display: block;
    border-radius: var(--radius-l);
    object-fit: cover;
    box-shadow: var(--shadow-lift);
  }
  @media (min-width: 960px) {
    .hero-inner {
      grid-template-columns: 1.15fr 0.85fr;
      column-gap: clamp(2.5rem, 5vw, 4rem);
    }
    .hero-logo-wrap { grid-column: 1 / -1; justify-content: flex-start; }
    .hero-photo { aspect-ratio: 4 / 5; }
  }

  /* ============== METHODENLEISTE ============== */
  .methoden-leiste { background: var(--color-cream-soft); border-top: 1px solid var(--color-line-soft); border-bottom: 1px solid var(--color-line-soft); }
  .methoden-leiste .ornament { color: var(--color-sage); font-family: var(--font-display); font-style: italic; font-size: var(--step-1); margin-bottom: 1.25rem; }
  .methoden-list {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 0.5rem 0.75rem;
    list-style: none;
    padding: 0;
  }
  .methoden-list li {
    display: inline-block;
    padding: 0.55em 1.15em;
    background: var(--color-paper);
    color: var(--color-sage-deep);
    border: 1px solid var(--color-line);
    border-radius: var(--radius-pill);
    font-size: 0.85rem;
    letter-spacing: 0.02em;
    font-weight: 500;
  }

  /* ============== 3 WEGE ============== */
  .wege-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(min(100%, 18rem), 1fr)); gap: 1.5rem; }
  .weg-card {
    background: var(--color-paper);
    border: 1px solid var(--color-line);
    border-top: 4px solid var(--color-clay);
    border-radius: var(--radius-l);
    padding: clamp(1.75rem, 3vw, 2.5rem);
    transition: all var(--transition);
    position: relative;
    display: flex;
    flex-direction: column;
  }
  .weg-card:hover { box-shadow: var(--shadow-card); transform: translateY(-3px); }
  .weg-number { font-family: var(--font-display); font-style: italic; color: var(--color-clay); font-size: 1.25rem; letter-spacing: 0.08em; margin-bottom: 0.5rem; }
  .weg-card h3 { margin-bottom: 0.75rem; }
  .weg-sub { color: var(--color-sage-deep); margin-bottom: 1rem; font-size: 0.95rem; line-height: 1.5; max-width: none; }
  .weg-sub em { color: var(--color-sage-deep); }
  .weg-card p { margin-bottom: 1.25rem; flex: 1; font-size: 0.95rem; max-width: none; }
  .weg-card .btn { align-self: flex-start; margin-top: auto; }

  /* ============== RAUM-SECTION ============== */
  .raum-grid { display: grid; grid-template-columns: 1fr; gap: clamp(2rem, 4vw, 3rem); align-items: start; }
  @media (min-width: 900px) { .raum-grid { grid-template-columns: 1fr 0.95fr; } }
  .raum-text h2 { margin: 0.5rem 0 1.25rem; }
  .raum-text p { margin-bottom: 1rem; }
  .raum-note { background: var(--color-cream-deep); border-left: 3px solid var(--color-sage); padding: 1rem 1.25rem; margin: 1.25rem 0; font-size: 0.92rem; border-radius: 0 var(--radius-s) var(--radius-s) 0; color: var(--color-ink-soft); }
  .raum-note strong { color: var(--color-sage-deep); }
  .raum-gallery { display: grid; grid-template-columns: 1fr 1fr; grid-template-rows: auto auto; gap: 0.75rem; }
  .raum-img { width: 100%; height: 100%; object-fit: cover; border-radius: var(--radius-m); box-shadow: var(--shadow-soft); }
  .raum-img-large { grid-column: 1 / -1; aspect-ratio: 16/9; }
  .raum-img:not(.raum-img-large) { aspect-ratio: 1/1; }
</style>
