---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { SITE, IMPULSE_BEITRAEGE } from '@/data/site';

export async function getStaticPaths() {
  return IMPULSE_BEITRAEGE.map((b) => ({ params: { slug: b.id }, props: { b } }));
}

const { b } = Astro.props;
const paragraphs = ('body' in b && b.body) ? b.body : [b.teaser];
const isPoem = ('poem' in b && b.poem) ? true : false;

const description = b.teaser.length > 155 ? b.teaser.slice(0, 152) + '…' : b.teaser;

const schemas = [
  {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Start', item: `${SITE.url}/` },
      { '@type': 'ListItem', position: 2, name: 'Fokus Impulse', item: `${SITE.url}/impulse` },
      { '@type': 'ListItem', position: 3, name: b.title, item: `${SITE.url}/impulse/${b.id}` },
    ],
  },
  {
    '@context': 'https://schema.org',
    '@type': isPoem ? 'CreativeWork' : 'Article',
    headline: b.title,
    author: { '@type': 'Person', name: SITE.name },
    inLanguage: 'de',
    isPartOf: { '@type': 'Blog', name: 'Fokus Impulse', url: `${SITE.url}/impulse` },
  },
];
---
<BaseLayout title={b.title} description={description} schema={schemas}>
  <section class="section bg-cream">
    <div class="container-narrow">
      <nav class="breadcrumb" aria-label="Breadcrumb">
        <a href="/">Start</a><span>/</span>
        <a href="/impulse">Fokus Impulse</a><span>/</span>
        <span>{b.title}</span>
      </nav>

      <article class="beitrag-detail">
        <span class="beitrag-cat">{b.category}</span>
        <h1>{b.title}</h1>

        <div class:list={['beitrag-body', { 'is-poem': isPoem }]}>
          {paragraphs.map((p) => <p>{p}</p>)}
        </div>

        <p class="beitrag-author">— Daniela Britta Hamberger</p>

        <div class="btn-group">
          <a href="/impulse#beitraege" class="btn btn-secondary">← Zurück zu den Impulsen</a>
          <button type="button" class="btn btn-primary" data-modal-open="1zu1" data-format="orientierung">Kostenfreies Orientierungsgespräch</button>
        </div>
      </article>
    </div>
  </section>
</BaseLayout>

<style>
  .beitrag-detail { margin-top: 1.5rem; }
  .beitrag-cat {
    font-size: 0.72rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--color-clay);
    font-weight: 600;
  }
  .beitrag-detail h1 { margin: 0.5rem 0 1.5rem; }
  .beitrag-body p { margin-bottom: 1.1rem; max-width: 60ch; }
  .beitrag-body.is-poem p {
    white-space: pre-line;
    font-family: var(--font-display);
    font-size: 1.2rem;
    line-height: 1.7;
    color: var(--color-ink);
    margin-bottom: 1.6rem;
  }
  .beitrag-author {
    font-style: italic;
    color: var(--color-ink-muted);
    margin: 1.5rem 0 2rem;
  }
</style>
