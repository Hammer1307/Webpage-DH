---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { SITE } from '@/data/site';
---
<BaseLayout
  title={`TeamBalance · ${SITE.brand}`}
  description="Halbtags-Workshop für Teams, die innehalten, ehrlich hinschauen und konkrete Impulse für mehr Wertschätzung und Klarheit mitnehmen möchten."
>

  <section class="page-hero">
    <div class="container ph-grid">
      <div class="ph-text">
        <nav class="breadcrumb"><a href="/">Start</a><span>/</span><a href="/teams-workshops">Teams & Workshops</a><span>/</span><span>TeamBalance</span></nav>
        <span class="eyebrow">Workshop · Halbtags · 3–3,5 Std.</span>
        <h1><em>TeamBalance.</em><br />Wenn das Miteinander wieder<br />klarer werden darf.</h1>
        <p class="lead">
          Ein halbtägiger Workshop, in dem ihr als Team innehaltet,
          ehrlich hinschaut und konkrete Impulse mitnehmt.
        </p>
        <div class="meta-card">
          <div><span class="ml">Dauer</span><span class="mv">3–3,5 Std.</span></div>
          <div><span class="ml">Format</span><span class="mv">Vor Ort & online</span></div>
          <div><span class="ml">Investition</span><span class="mv">ab 1.500 €<small> zzgl. MwSt.</small></span></div>
        </div>
      </div>
    </div>
  </section>

  <section class="content">
    <div class="container">
      <header class="section-head">
        <span class="eyebrow">Was wir im Workshop tun</span>
        <h2>Vier <em>Bewegungen</em> im Workshop</h2>
      </header>
      <div class="content-grid">
        <div class="content-card">
          <div class="num">01</div>
          <h3>Wahrnehmung der Teamdynamik</h3>
          <p>Wir schauen, was im Team gerade lebt — sichtbar und unsichtbar. Ohne Bewertung, mit Wertschätzung.</p>
        </div>
        <div class="content-card">
          <div class="num">02</div>
          <h3>Kommunikation reflektieren</h3>
          <p>Welche Muster wiederholen sich? Wo entstehen Missverständnisse? Wir lernen, sie zu erkennen.</p>
        </div>
        <div class="content-card">
          <div class="num">03</div>
          <h3>Wertschätzung konkret üben</h3>
          <p>Wertschätzung wird in praktischen Übungen erfahrbar. Nichts Theoretisches, sondern erlebbar im Hier und Jetzt.</p>
        </div>
        <div class="content-card">
          <div class="num">04</div>
          <h3>Impulse für den Alltag</h3>
          <p>Drei bis fünf konkrete Werkzeuge, die ab der nächsten Teamsitzung greifen — ohne Mehrarbeit.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="flow">
    <div class="container container-narrow">
      <header class="section-head section-head-left">
        <span class="eyebrow">Ablauf</span>
        <h2>So läuft ein <em>TeamBalance</em> Workshop</h2>
      </header>
      <ol class="flow-list">
        <li><strong>Vorgespräch (kostenfrei, ca. 30 Min.)</strong> — Wir klären, worum es geht und welcher Schwerpunkt für euer Team Sinn macht.</li>
        <li><strong>Workshop (3–3,5 Std.)</strong> — Konzentrierte Arbeit mit klarer Struktur: Reflexion, Impuls, Übung, Verankerung.</li>
        <li><strong>Take-aways</strong> — Ihr nehmt konkrete Werkzeuge und Vereinbarungen mit, an denen ihr weiterarbeiten könnt.</li>
        <li><strong>Optional: Nachklang-Session</strong> — Vier bis sechs Wochen später ein Online-Check-in zur Justierung.</li>
      </ol>
    </div>
  </section>

  <section class="final-cta">
    <div class="container final-cta-inner">
      <span class="eyebrow">Anfragen</span>
      <h2>Bringen wir euer Team wieder in <em>Balance</em>.</h2>
      <p>Ein kostenfreies Vorgespräch klärt, ob TeamBalance der richtige Rahmen für euch ist.</p>
      <a href="/kontakt" class="btn btn-primary">Workshop anfragen</a>
    </div>
  </section>

<style>
.page-hero { padding-top: clamp(2rem, 5vw, 4rem); padding-bottom: clamp(3rem, 7vw, 5rem); background: var(--color-cream); }
.ph-grid { max-width: 42rem; margin-inline: auto; text-align: center; }
.breadcrumb { display: flex; gap: 0.5rem; font-size: 0.78rem; color: var(--color-ink-muted); margin-bottom: 1.5rem; justify-content: center; flex-wrap: wrap; }
.breadcrumb a { color: var(--color-ink-muted); }
.breadcrumb a:hover { color: var(--color-sage-deep); }
.ph-text h1 { font-size: clamp(2.4rem, 4.5vw, 4rem); line-height: 1.02; letter-spacing: -0.03em; margin: 1rem 0 1.5rem; font-weight: 400; }
.ph-text h1 em { color: var(--color-sage-deep); font-style: italic; }
.ph-text .lead { font-family: var(--font-display); font-style: italic; font-size: 1.35rem; color: var(--color-ink-soft); margin-bottom: 2rem; max-width: 38ch; margin-inline: auto; }
.meta-card { background: var(--color-paper); border: 1px solid var(--color-line); border-radius: var(--radius-l); display: grid; grid-template-columns: repeat(3, 1fr); gap: 1rem; padding: 1.5rem; max-width: 32rem; margin: 0 auto; text-align: left; }
.ml { display: block; font-size: 0.65rem; text-transform: uppercase; letter-spacing: 0.1em; color: var(--color-ink-muted); margin-bottom: 0.25rem; }
.mv { display: block; font-family: var(--font-display); font-size: 1.1rem; color: var(--color-ink); }
.mv small { color: var(--color-ink-muted); font-size: 0.7em; }

.content { padding-block: clamp(4rem, 8vw, 7rem); background: var(--color-paper); }
.section-head { text-align: center; max-width: 42rem; margin: 0 auto 3rem; }
.section-head-left { text-align: left; margin-inline: 0; }
.section-head h2 { margin-top: 0.5rem; font-size: clamp(2rem, 4vw, 3rem); line-height: 1.1; font-weight: 400; letter-spacing: -0.02em; }
.section-head em { color: var(--color-sage-deep); font-style: italic; }
.content-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(min(100%, 18rem), 1fr)); gap: 1.5rem; max-width: 56rem; margin: 0 auto; }
.content-card { background: var(--color-cream-soft); border-radius: var(--radius-l); padding: 1.75rem; border: 1px solid var(--color-line); }
.content-card .num { font-family: var(--font-display); font-size: 1.5rem; color: var(--color-clay); font-style: italic; margin-bottom: 0.85rem; }
.content-card h3 { font-size: 1.15rem; font-family: var(--font-body); font-weight: 600; margin-bottom: 0.5rem; }
.content-card p { color: var(--color-ink-soft); line-height: 1.55; font-size: 0.92rem; }

.flow { padding-block: clamp(4rem, 8vw, 7rem); background: var(--color-cream); }
.flow-list { list-style: none; padding: 0; display: flex; flex-direction: column; gap: 0.85rem; }
.flow-list li { background: var(--color-paper); border-left: 3px solid var(--color-sage); padding: 1.25rem 1.5rem; color: var(--color-ink-soft); line-height: 1.6; border-radius: 0 var(--radius-m) var(--radius-m) 0; }
.flow-list strong { color: var(--color-ink); font-weight: 600; }

.final-cta { padding-block: clamp(4rem, 8vw, 7rem); background: var(--color-ink); color: var(--color-cream); }
.final-cta-inner { text-align: center; max-width: 36rem; margin: 0 auto; }
.final-cta .eyebrow { color: var(--color-clay-soft); }
.final-cta .eyebrow::before { background: var(--color-clay-soft); }
.final-cta h2 { font-size: clamp(2rem, 4vw, 3rem); line-height: 1.1; margin: 0.5rem 0 1rem; color: var(--color-cream); font-weight: 400; }
.final-cta em { color: var(--color-clay-soft); font-style: italic; }
.final-cta p { color: rgba(245, 239, 230, 0.8); margin-bottom: 2rem; line-height: 1.5; }
.final-cta .btn-primary { background: var(--color-cream); color: var(--color-ink); }
.final-cta .btn-primary:hover { background: white; }

@media (max-width: 800px) { .meta-card { grid-template-columns: 1fr; gap: 0.5rem; } }
</style>
</BaseLayout>
