---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { SITE, IMAGES } from '@/data/site';

const description =
  'TeamBalance Workshop — 3–3,5-stündiger Workshop für Klarheit, Wertschätzung und stabile Zusammenarbeit. Ab 890 € zzgl. MwSt. Online oder vor Ort.';

const schemas = [
  {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Start', item: `${SITE.url}/` },
      { '@type': 'ListItem', position: 2, name: 'Teams & Workshops', item: `${SITE.url}/teams-workshops` },
      { '@type': 'ListItem', position: 3, name: 'TeamBalance', item: `${SITE.url}/teambalance` },
    ],
  },
  {
    '@context': 'https://schema.org',
    '@type': 'Service',
    name: 'TeamBalance Workshop',
    provider: { '@type': 'Person', name: SITE.name },
    description: 'Halbtags-Workshop (3–3,5 Stunden) für Klarheit, Wertschätzung und stabile Zusammenarbeit in Teams.',
    offers: { '@type': 'Offer', price: '890', priceCurrency: 'EUR', description: 'ab 890 € zzgl. MwSt.' },
  },
];

const wirkungen = [
  { title: 'Mehr Klarheit', text: 'über Kommunikationsmuster und Teamdynamiken' },
  { title: 'Konkrete Impulse', text: 'für wertschätzenderes Miteinander' },
  { title: 'Geschützter Raum', text: 'für offene Reflexion' },
  { title: 'Stärkung', text: 'von Vertrauen, Rollen und gemeinsamer Ausrichtung' },
  { title: 'Praktische Methoden', text: 'für den Arbeitsalltag' },
];
---
<BaseLayout
  title="TeamBalance Workshop"
  description={description}
  schema={schemas}
>
  <img class="image-accent" src={IMAGES.teamsWorkshop} alt="Workshop-Atmosphäre: gemeinsames Sortieren und neue Perspektiven" loading="eager" />

  <section class="section section-cream">
    <div class="container-narrow">
      <nav class="breadcrumb" aria-label="Breadcrumb">
        <a href="/">Start</a><span>/</span>
        <a href="/teams-workshops">Teams &amp; Workshops</a><span>/</span>
        <span>TeamBalance</span>
      </nav>
      <header class="page-intro">
        <span class="tag tag-gold">Workshop für Teams</span>
        <h1>Team<em>Balance</em></h1>
        <p class="lead">
          Klarheit, Wertschätzung und stabile Zusammenarbeit für Teams
        </p>
      </header>

      <p>
        Wenn Kommunikation schwieriger wird, Rollen unklar sind oder Wertschätzung im Alltag
        verloren geht, braucht es Raum für Reflexion.
      </p>
      <p>
        TeamBalance ist ein Workshopformat für Teams, die ihr Miteinander bewusster gestalten
        möchten. Es geht um Kommunikation, Selbst- und Fremdwahrnehmung, Bedürfnisse,
        Wertschätzung und konkrete Impulse für den Arbeitsalltag.
      </p>

      <div class="tb-facts">
        <div class="fact">
          <h4>Dauer</h4>
          <p>ca. 3–3,5 Stunden</p>
        </div>
        <div class="fact">
          <h4>Format</h4>
          <p>online oder vor Ort</p>
        </div>
        <div class="fact">
          <h4>Investition</h4>
          <p>ab 890 € zzgl. MwSt.</p>
        </div>
        <div class="fact">
          <h4>Geeignet für</h4>
          <p>pädagogische Teams, soziale Einrichtungen, Praxisteams, kleinere Unternehmen, Projektteams</p>
        </div>
      </div>
    </div>
  </section>

  <section class="section section-cream-deep">
    <div class="container">
      <header class="section-head">
        <span class="eyebrow">Was im Workshop entsteht</span>
        <h2>Was der Workshop <em>bewirkt</em></h2>
      </header>
      <div class="wirkung-grid">
        {wirkungen.map((w) => (
          <article class="wirkung">
            <h3>{w.title}</h3>
            <p>{w.text}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section section-bordeaux">
    <div class="container-narrow" style="text-align: center;">
      <h2>Interesse an TeamBalance?</h2>
      <p style="margin: 1rem auto 2rem; max-width: 50ch;">
        Ich freue mich auf ein erstes Gespräch. In einem kurzen Vorgespräch (30 Min.) klären
        wir, ob und wie TeamBalance zu eurem Team passt.
      </p>
      <div class="btn-group btn-group-center">
        <button type="button" class="btn btn-gold" data-modal-open="teams" data-format="teambalance">TeamBalance anfragen</button>
        <button type="button" class="btn btn-outline" style="color: var(--color-cream); border-color: var(--color-gold-pale);" data-modal-open="teams" data-format="teamvorgespraech">Team-Vorgespräch buchen</button>
      </div>
      <p style="margin-top: 1.5rem; font-size: 0.85rem; opacity: 0.75;">
        Unverbindlich · Individuell konzipiert · Online oder vor Ort
      </p>
    </div>
  </section>
</BaseLayout>

<style>
  .page-intro { text-align: center; margin-bottom: 2.5rem; }
  .page-intro .tag { margin-bottom: 1.25rem; display: inline-block; }
  .page-intro h1 { margin: 0.25rem 0 1rem; }
  .page-intro h1 em { color: var(--color-gold-deep); }
  .page-intro .lead { margin: 0 auto; }

  .tb-facts {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(13rem, 1fr));
    gap: 1rem;
    margin-top: 2.5rem;
  }
  .fact {
    background: var(--color-paper);
    border: 1px solid var(--color-line);
    padding: 1.25rem;
    border-radius: var(--radius-m);
    border-top: 3px solid var(--color-gold);
  }
  .fact h4 {
    font-size: 0.75rem; text-transform: uppercase; letter-spacing: 0.15em;
    color: var(--color-gold-deep); font-family: var(--font-body);
    font-weight: 500; margin-bottom: 0.5rem;
  }
  .fact p {
    color: var(--color-bordeaux);
    font-family: var(--font-display);
    font-size: 1rem;
    margin: 0; line-height: 1.4;
  }

  .wirkung-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(15rem, 1fr));
    gap: 1.5rem;
  }
  .wirkung {
    background: var(--color-paper);
    padding: 1.75rem;
    border: 1px solid var(--color-line);
    border-radius: var(--radius-m);
    border-top: 3px solid var(--color-gold);
    text-align: center;
  }
  .wirkung h3 {
    font-style: italic;
    font-size: 1.25rem;
    margin-bottom: 0.75rem;
  }
  .wirkung p { font-size: 0.93rem; margin: 0; }
</style>
