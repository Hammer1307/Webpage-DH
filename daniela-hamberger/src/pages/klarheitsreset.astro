---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { SITE, IMAGES } from '@/data/site';

const description =
  'Fokus KlarheitsReset: intensive Begleitung für Frauen in Krisen- oder Umbruchphasen — zwei Online-Sitzungen, Intensivzeit vor Ort in Idstein/Wiesbaden, Nachbegleitung. 2.111 €.';

const schemas = [
  {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Start', item: `${SITE.url}/` },
      { '@type': 'ListItem', position: 2, name: '1:1 Begleitung', item: `${SITE.url}/1-zu-1-begleitung` },
      { '@type': 'ListItem', position: 3, name: 'Fokus KlarheitsReset', item: `${SITE.url}/klarheitsreset` },
    ],
  },
  {
    '@context': 'https://schema.org',
    '@type': 'Service',
    name: 'Fokus KlarheitsReset',
    provider: { '@type': 'Person', name: SITE.name },
    description: 'Intensive Begleitung für Frauen in Krisen- oder Umbruchphasen: zwei vorbereitende Online-Sitzungen, Intensivzeit vor Ort in Idstein bzw. im Raum Wiesbaden, ein bis zwei Online-Nachbegleitungen.',
    areaServed: ['Idstein', 'Wiesbaden', 'Rhein-Main-Gebiet', 'Online'],
    offers: { '@type': 'Offer', price: '2111', priceCurrency: 'EUR', description: '2.111 €' },
  },
];
---
<BaseLayout
  title="Fokus KlarheitsReset"
  description={description}
  schema={schemas}
>
  <section class="kr-hero">
    <div class="container-narrow">
      <nav class="breadcrumb" aria-label="Breadcrumb">
        <a href="/">Start</a><span>/</span>
        <a href="/1-zu-1-begleitung">1:1 Begleitung</a><span>/</span>
        <span>Fokus KlarheitsReset</span>
      </nav>
      <span class="tag tag-gold">Intensivbegleitung für Frauen</span>
      <h1>Fokus Klarheits<em>Reset</em></h1>
      <h2 class="kr-subhead">Intensive Begleitung für Frauen in Krisen- oder Umbruchphasen.</h2>
    </div>
  </section>

  <section class="section section-cream">
    <div class="container-narrow">
      <blockquote class="kr-quote">
        <p>Du hast den Boden unter den Füßen verloren?</p>
        <p>Beruflich, privat oder in dir selbst ist gerade vieles in Bewegung?</p>
        <p>Du wünschst dir wieder Fokus, Halt und eine klare Richtung?</p>
      </blockquote>

      <p>
        Der Fokus KlarheitsReset ist für dich geeignet, wenn du gerade den Boden unter den Füßen,
        deinen inneren Fokus oder deine Orientierung verloren hast — beruflich, privat oder in dir selbst.
      </p>
      <p>
        In zwei vorbereitenden Online-Sitzungen schauen wir gemeinsam, wo deine wichtigsten
        Stellschrauben liegen. Anschließend arbeiten wir vor Ort in Idstein oder im Raum Wiesbaden
        intensiv mit dem, was sich bei dir zeigt — achtsam, empathisch und individuell, mit Gespräch,
        Körperwahrnehmung, inneren Bildern, hypnotherapeutisch inspirierten und energetischen Impulsen.
      </p>
      <p>
        Danach begleiten dich ein bis zwei Online-Coachings dabei, das Erlebte zu integrieren und
        nächste Schritte klarer zu setzen.
      </p>

      {/* TODO Bildrunde: hier Bild einfügen — Frau im Kornfeld sitzend, Arme ausgebreitet, Rucksack auf dem Rücken, wirkt glücklich und befreit */}

      <div class="kr-facts">
        <div class="fact">
          <h4>Rhythmus</h4>
          <p>2 Online-Sitzungen · Intensivzeit vor Ort · 1–2 Online-Nachbegleitungen</p>
        </div>
        <div class="fact">
          <h4>Ort</h4>
          <p>Idstein / Raum Wiesbaden</p>
        </div>
        <div class="fact">
          <h4>Investition</h4>
          <p>2.111 €</p>
        </div>
        <div class="fact">
          <h4>Unterkunft</h4>
          <p>separat · Empfehlungen möglich</p>
        </div>
      </div>
    </div>
  </section>

  <section class="section section-bordeaux">
    <div class="container-narrow" style="text-align: center;">
      <h2>Bereit für deinen Fokus KlarheitsReset?</h2>
      <p style="margin: 1rem auto 2rem; max-width: 50ch;">
        Starte mit einem kostenfreien Orientierungsgespräch. Wir schauen gemeinsam, ob der
        Fokus KlarheitsReset das Richtige für dich ist.
      </p>
      <div class="btn-group btn-group-center">
        <button type="button" class="btn btn-gold" data-modal-open="1zu1" data-format="klarheitsreset">Fokus KlarheitsReset anfragen</button>
        <button type="button" class="btn btn-outline" style="color: var(--color-cream); border-color: var(--color-gold-pale);" data-modal-open="1zu1" data-format="orientierung">Kostenfreies Gespräch buchen</button>
      </div>
      <p style="margin-top: 1.5rem; font-size: 0.85rem; opacity: 0.75;">
        Unverbindlich · Online oder vor Ort · Antwort innerhalb von 1–2 Werktagen
      </p>
    </div>
  </section>
</BaseLayout>

<style>
  .kr-hero {
    background: var(--color-cream-deep);
    padding: clamp(4rem, 8vw, 6rem) 0 clamp(2.5rem, 5vw, 3.5rem);
    text-align: center;
    border-bottom: 1px solid var(--color-line-gold);
  }
  .kr-hero .breadcrumb { text-align: left; }
  .kr-hero .tag { margin-bottom: 1.5rem; }
  .kr-hero h1 {
    font-size: clamp(2.5rem, 6vw, 4.5rem);
    margin: 0.5rem 0 1rem;
  }
  .kr-hero h1 em {
    font-style: italic;
    color: var(--color-gold-deep);
  }
  .kr-subhead {
    font-family: var(--font-display);
    font-style: italic;
    font-size: var(--step-2);
    color: var(--color-ink);
    margin: 0 auto;
    max-width: 30ch;
    font-weight: 400;
  }

  .kr-quote {
    background: var(--color-cream-soft);
    border-left: 3px solid var(--color-gold);
    padding: 1.5rem 1.75rem;
    margin: 2rem 0 2.5rem;
    border-radius: 0 var(--radius-s) var(--radius-s) 0;
  }
  .kr-quote p {
    font-family: var(--font-display);
    font-style: italic;
    color: var(--color-bordeaux);
    font-size: 1.1rem;
    margin: 0 0 0.75rem;
  }
  .kr-quote p:last-child { margin-bottom: 0; }

  .kr-facts {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(12rem, 1fr));
    gap: 1rem;
    margin: 2.5rem 0 0;
  }
  .fact {
    background: var(--color-paper);
    border: 1px solid var(--color-line);
    padding: 1.25rem 1.25rem;
    border-radius: var(--radius-m);
    border-top: 3px solid var(--color-gold);
  }
  .fact h4 {
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: var(--color-gold-deep);
    font-family: var(--font-body);
    font-weight: 500;
    margin-bottom: 0.5rem;
  }
  .fact p {
    color: var(--color-bordeaux);
    font-family: var(--font-display);
    font-size: 1.1rem;
    margin: 0;
    line-height: 1.4;
  }
</style>
