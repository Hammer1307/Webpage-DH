---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { SITE, IMAGES } from '@/data/site';

const description =
  'KlarheitsReset — eine intensive 1:1 Session (2,5–3 Std., ab 490 €) für Menschen, die sich konzentriert mit einem konkreten Thema auseinandersetzen möchten. Online oder vor Ort.';

const schemas = [
  {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Start', item: `${SITE.url}/` },
      { '@type': 'ListItem', position: 2, name: '1:1 Begleitung', item: `${SITE.url}/1-zu-1-begleitung` },
      { '@type': 'ListItem', position: 3, name: 'KlarheitsReset', item: `${SITE.url}/klarheitsreset` },
    ],
  },
  {
    '@context': 'https://schema.org',
    '@type': 'Service',
    name: 'KlarheitsReset — Intensive 1:1 Session',
    provider: { '@type': 'Person', name: SITE.name },
    description: 'Intensive 1:1 Session (2,5–3 Std.) für tiefere Klärung eines konkreten Themas.',
    offers: { '@type': 'Offer', price: '490', priceCurrency: 'EUR', description: 'ab 490 €' },
  },
];
---
<BaseLayout
  title="KlarheitsReset — Intensive 1:1 Session"
  description={description}
  schema={schemas}
>
  <section class="kr-hero">
    <div class="container-narrow">
      <nav class="breadcrumb" aria-label="Breadcrumb">
        <a href="/">Start</a><span>/</span>
        <a href="/1-zu-1-begleitung">1:1 Begleitung</a><span>/</span>
        <span>KlarheitsReset</span>
      </nav>
      <span class="tag tag-gold">1:1 Intensiv-Session</span>
      <h1>Klarheits<em>Reset</em></h1>
      <h2 class="kr-subhead">Wenn du spürst, dass sich etwas klären muss.</h2>
    </div>
  </section>

  <section class="section section-cream">
    <div class="container-narrow">
      <blockquote class="kr-quote">
        <p>Du denkst viel nach, aber kommst innerlich nicht weiter?</p>
        <p>Du fühlst dich erschöpft, unruhig oder blockiert?</p>
        <p>Du stehst vor einer Entscheidung und wünschst dir mehr Klarheit?</p>
      </blockquote>

      <p>
        Der KlarheitsReset ist eine intensive 1:1 Session für Menschen, die sich konzentriert
        mit einem konkreten Thema auseinandersetzen möchten.
      </p>
      <p>
        In einem geschützten Rahmen sortieren wir deine aktuelle Situation, betrachten innere
        Muster und öffnen Raum für neue Perspektiven. Je nach Anliegen arbeiten wir mit
        Gespräch, mentaler Klärung, kreativen Methoden, hypnotherapeutischen Impulsen und
        intuitiver Prozessarbeit.
      </p>

      <div class="kr-facts">
        <div class="fact">
          <h4>Dauer</h4>
          <p>ca. 2,5–3 Stunden</p>
        </div>
        <div class="fact">
          <h4>Format</h4>
          <p>online oder vor Ort<br />nach Absprache</p>
        </div>
        <div class="fact">
          <h4>Investition</h4>
          <p>ab 490 €</p>
        </div>
        <div class="fact">
          <h4>Vorab</h4>
          <p>kostenfreies Orientierungs­gespräch (20 Min.)</p>
        </div>
      </div>
    </div>
  </section>

  <section class="section section-bordeaux">
    <div class="container-narrow" style="text-align: center;">
      <h2>Bereit für mehr Klarheit?</h2>
      <p style="margin: 1rem auto 2rem; max-width: 50ch;">
        Starte mit einem kostenfreien Orientierungsgespräch. Wir schauen gemeinsam, ob der
        KlarheitsReset das Richtige für dich ist.
      </p>
      <div class="btn-group btn-group-center">
        <a href="/kontakt" class="btn btn-gold">KlarheitsReset anfragen</a>
        <a href="/kontakt" class="btn btn-outline" style="color: var(--color-cream); border-color: var(--color-gold-pale);">Kostenfreies Gespräch buchen</a>
      </div>
      <p style="margin-top: 1.5rem; font-size: 0.85rem; opacity: 0.75;">
        Unverbindlich · Online oder vor Ort · Antwort innerhalb von 1–2 Werktagen
      </p>
    </div>
  </section>
</BaseLayout>

<style>
  .kr-hero {
    background: var(--color-cream-deep);
    padding: clamp(4rem, 8vw, 6rem) 0 clamp(2.5rem, 5vw, 3.5rem);
    text-align: center;
    border-bottom: 1px solid var(--color-line-gold);
  }
  .kr-hero .breadcrumb { text-align: left; }
  .kr-hero .tag { margin-bottom: 1.5rem; }
  .kr-hero h1 {
    font-size: clamp(2.5rem, 6vw, 4.5rem);
    margin: 0.5rem 0 1rem;
  }
  .kr-hero h1 em {
    font-style: italic;
    color: var(--color-gold-deep);
  }
  .kr-subhead {
    font-family: var(--font-display);
    font-style: italic;
    font-size: var(--step-2);
    color: var(--color-ink);
    margin: 0 auto;
    max-width: 30ch;
    font-weight: 400;
  }

  .kr-quote {
    background: var(--color-cream-soft);
    border-left: 3px solid var(--color-gold);
    padding: 1.5rem 1.75rem;
    margin: 2rem 0 2.5rem;
    border-radius: 0 var(--radius-s) var(--radius-s) 0;
  }
  .kr-quote p {
    font-family: var(--font-display);
    font-style: italic;
    color: var(--color-bordeaux);
    font-size: 1.1rem;
    margin: 0 0 0.75rem;
  }
  .kr-quote p:last-child { margin-bottom: 0; }

  .kr-facts {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(12rem, 1fr));
    gap: 1rem;
    margin: 2.5rem 0 0;
  }
  .fact {
    background: var(--color-paper);
    border: 1px solid var(--color-line);
    padding: 1.25rem 1.25rem;
    border-radius: var(--radius-m);
    border-top: 3px solid var(--color-gold);
  }
  .fact h4 {
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: var(--color-gold-deep);
    font-family: var(--font-body);
    font-weight: 500;
    margin-bottom: 0.5rem;
  }
  .fact p {
    color: var(--color-bordeaux);
    font-family: var(--font-display);
    font-size: 1.1rem;
    margin: 0;
    line-height: 1.4;
  }
</style>
