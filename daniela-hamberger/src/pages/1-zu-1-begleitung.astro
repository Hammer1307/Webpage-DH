---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { SITE, IMAGES, COACHING_FORMATS } from '@/data/site';

const description =
  'Persönliche 1:1 Begleitung mit Daniela Britta Hamberger — KlarheitsSitzung, KlarheitsStart, KlarheitsReset und Fokus Schöner Leben Intensiv. Für innere Stabilität, Klarheit und neue Ausrichtung.';

const breadcrumb = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Start', item: `${SITE.url}/` },
    { '@type': 'ListItem', position: 2, name: '1:1 Begleitung', item: `${SITE.url}/1-zu-1-begleitung` },
  ],
};
---
<BaseLayout
  title="1:1 Begleitung"
  description={description}
  schema={breadcrumb}
>
  <img class="image-accent" src={IMAGES.begleitung1zu1} alt="" loading="eager" />

  <section class="section section-cream">
    <div class="container-narrow">
      <nav class="breadcrumb" aria-label="Breadcrumb">
        <a href="/">Start</a><span>/</span><span>1:1 Begleitung</span>
      </nav>
      <header class="page-intro">
        <span class="eyebrow">1:1 Begleitung</span>
        <h1>1:1 <em>Begleitung</em></h1>
        <p class="lead">
          Wenn du spürst: Ich möchte wieder klarer, freier und stabiler werden.
        </p>
      </header>

      <h2>Vielleicht kennst du das:</h2>
      <ul class="check-list">
        <li>Du funktionierst viel, aber innerlich bist du erschöpft.</li>
        <li>Du spürst, dass sich etwas verändern möchte, aber du weißt noch nicht genau, wie.</li>
        <li>Du stehst vor einer Entscheidung und drehst dich gedanklich im Kreis.</li>
        <li>Du merkst, dass du deine eigenen Bedürfnisse zu oft übergehst.</li>
        <li>Du fühlst dich angepasst, fremdbestimmt oder nicht mehr ganz verbunden mit dem, was dich eigentlich ausmacht.</li>
      </ul>

      <p>
        In meiner 1:1 Begleitung geht es nicht darum, dir fertige Antworten überzustülpen.
        Es geht darum, dass du wieder Zugang zu deiner eigenen inneren Klarheit findest.
      </p>
      <p>
        Oft liegt die Antwort nicht irgendwo im Außen. Sie ist bereits in dir angelegt —
        vielleicht nur verschüttet durch alte Erfahrungen, Erwartungen, Druck, innere Unruhe
        oder die Gewohnheit, es anderen recht machen zu wollen.
      </p>
      <p>
        Ich begleite dich dabei, wieder mehr Ordnung, Stabilität, Selbstvertrauen und
        Lebensfreude in dir freizulegen.
      </p>
    </div>
  </section>

  <section class="section section-cream-deep">
    <div class="container-narrow">
      <h2 class="text-center">Was in der Begleitung entstehen darf</h2>
      <ul class="benefits-grid">
        <li>mehr innere Ruhe und Stabilität</li>
        <li>ein klarerer Blick auf dich und deine Situation</li>
        <li>mehr Verbindung zu deinen Bedürfnissen</li>
        <li>neue Perspektiven auf alte Muster</li>
        <li>mehr Selbstwert und Abgrenzung</li>
        <li>ein bewussterer Umgang mit Entscheidungen</li>
        <li>mehr Vertrauen in deinen eigenen Weg</li>
        <li>ein Lebensgefühl, das wieder stimmiger, freier und lebendiger wird</li>
      </ul>
    </div>
  </section>

  <section class="section section-cream">
    <div class="container">
      <header class="section-head">
        <span class="eyebrow">Die Formate im Überblick</span>
        <h2>Fünf Wege, miteinander zu arbeiten</h2>
      </header>

      <div class="format-grid">
        {COACHING_FORMATS.map((f) => (
          <article class:list={['format-card', { 'card-featured': f.featured }]}>
            {f.featured && <span class="tag tag-gold format-badge">Empfohlen</span>}
            <h3>{f.name}</h3>
            <p class="format-duration">{f.duration}</p>
            <p class="format-desc">{f.description}</p>
            {f.suitableFor && <p class="format-meta">{f.suitableFor}</p>}
            <div class="format-foot">
              <p class="format-price">
                <span class="label">Investition</span>
                <strong>{f.price}</strong>
              </p>
              <a href={f.href} class="btn btn-outline">{f.cta}</a>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section section-cream-deep">
    <div class="container-text">
      <blockquote class="disclaimer">
        <strong>Wichtiger Hinweis:</strong> Meine Arbeit versteht sich als ganzheitliche
        Begleitung zur persönlichen Klärung, Stabilisierung und bewussten Entwicklung. Sie
        ersetzt keine ärztliche, psychotherapeutische oder heilkundliche Diagnose oder
        Behandlung. Ich stelle keine medizinischen Diagnosen, gebe keine Heilversprechen
        und behandle keine Krankheiten. Wenn du körperliche oder psychische Beschwerden hast,
        dich in einer akuten Krise befindest oder medizinische Fragen hast, wende dich bitte
        an eine Ärztin, einen Arzt, eine Psychotherapeutin, einen Psychotherapeuten oder
        eine entsprechend qualifizierte Fachperson.
      </blockquote>
    </div>
  </section>

  <section class="section section-bordeaux">
    <div class="container-narrow" style="text-align: center;">
      <h2>Ein Gespräch — und mehr nicht.</h2>
      <p style="margin: 1rem auto 2rem; max-width: 50ch;">
        Buche ein kostenfreies Orientierungsgespräch (15–30 Minuten). Unverbindlich, ohne
        Verpflichtung — einfach als erster klarer Schritt.
      </p>
      <a href="/kontakt" class="btn btn-gold">Orientierungsgespräch buchen</a>
    </div>
  </section>
</BaseLayout>

<style>
  .page-intro {
    text-align: center;
    margin-bottom: 3rem;
  }
  .page-intro h1 { margin: 0.5rem 0 1rem; }
  .page-intro .lead { margin: 0 auto; }

  .check-list,
  .benefits-grid {
    list-style: none;
    padding: 0;
    margin: 1.5rem 0 2rem;
  }
  .check-list li {
    padding: 0.7rem 0 0.7rem 1.75rem;
    border-bottom: 1px solid var(--color-line);
    position: relative;
    color: var(--color-ink);
  }
  .check-list li::before {
    content: '·';
    position: absolute;
    left: 0;
    top: 0.4rem;
    color: var(--color-gold-deep);
    font-size: 1.75rem;
    line-height: 1;
  }

  .benefits-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(15rem, 1fr));
    gap: 0.5rem 2rem;
  }
  .benefits-grid li {
    padding: 0.6rem 0 0.6rem 1.5rem;
    position: relative;
    color: var(--color-ink);
  }
  .benefits-grid li::before {
    content: '✓';
    position: absolute;
    left: 0;
    top: 0.6rem;
    color: var(--color-sage-deep);
    font-weight: 500;
  }

  .text-center { text-align: center; margin-bottom: 2rem; }

  .format-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(18rem, 1fr));
    gap: 1.5rem;
  }
  .format-card {
    background: var(--color-paper);
    border: 1px solid var(--color-line);
    border-radius: var(--radius-m);
    padding: 2rem 1.75rem 1.75rem;
    transition: all var(--transition);
    position: relative;
    display: flex;
    flex-direction: column;
  }
  .format-card.card-featured {
    background: var(--color-cream-soft);
    border-color: var(--color-gold);
  }
  .format-card:hover {
    box-shadow: var(--shadow-card);
    transform: translateY(-2px);
  }
  .format-badge {
    position: absolute;
    top: 1rem;
    right: 1rem;
  }
  .format-card h3 { margin-bottom: 0.5rem; font-size: 1.4rem; }
  .format-duration {
    color: var(--color-bordeaux);
    font-style: italic;
    font-family: var(--font-display);
    font-size: 1rem;
    margin-bottom: 1rem;
  }
  .format-desc {
    font-size: 0.92rem;
    color: var(--color-ink-soft);
    margin-bottom: 1rem;
  }
  .format-meta {
    font-size: 0.85rem;
    color: var(--color-ink-muted);
    background: var(--color-cream);
    padding: 0.75rem 1rem;
    border-radius: var(--radius-s);
    margin-bottom: 1rem;
    border-left: 2px solid var(--color-gold);
  }
  .format-foot {
    margin-top: auto;
    padding-top: 1.25rem;
    border-top: 1px solid var(--color-line);
    display: flex;
    flex-direction: column;
    gap: 1rem;
    align-items: flex-start;
  }
  .format-price {
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
  }
  .format-price .label {
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: var(--color-ink-muted);
  }
  .format-price strong {
    font-family: var(--font-display);
    font-size: 1.15rem;
    color: var(--color-bordeaux);
    font-weight: 500;
  }
</style>
