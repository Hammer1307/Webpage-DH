---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { SITE, IMAGES, IMPULSE_TOPICS, IMPULSE_BEITRAEGE, SOCIAL } from '@/data/site';

const description =
  'Fokus Impulse — Blogbeiträge, Gedanken, Audio, Video und Social-Media-Impulse von Daniela Britta Hamberger für innere Ordnung, Klarheit und gelingendes Miteinander.';

const breadcrumb = {
  '@context': 'https://schema.org', '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Start', item: `${SITE.url}/` },
    { '@type': 'ListItem', position: 2, name: 'Fokus Impulse', item: `${SITE.url}/impulse` },
  ],
};
---
<BaseLayout title="Fokus Impulse" description={description} schema={breadcrumb}>
  <img class="image-accent image-accent--portrait-source" src={IMAGES.impulseLebensfreude} alt="Lebensfreude — ein leichter Moment voller Freude" loading="eager" />

  <section class="section bg-cream">
    <div class="container-narrow">
      <nav class="breadcrumb" aria-label="Breadcrumb"><a href="/">Start</a><span>/</span><span>Fokus Impulse</span></nav>
      <header class="page-intro">
        <span class="eyebrow">Gedanken &amp; Impulse</span>
        <h1>Kleine Impulse,<br /><em>die etwas öffnen</em></h1>
        <p class="lead">Für innere Ordnung, Klarheit und gelingendes Miteinander.</p>
      </header>

      <p>Hier teile ich Gedanken, Texte und Impulse zu Themen, die mich bewegen und meine Arbeit prägen: innere Stabilität, Achtsamkeit, Stressresilienz, Wertschätzung, Empathie, Naturverbundenheit, Bewusstsein, Lebensfreude und gelingendes Miteinander.</p>
      <p>Manche Beiträge entstehen aus meiner Arbeit als Mentorin. Andere aus meinen Buchprojekten, aus Alltagssituationen, gesellschaftlichen Beobachtungen oder Gedanken, die ich auch auf LinkedIn und Instagram teile.</p>
      <p>Es geht um kleine Impulse, die etwas öffnen können: einen neuen Gedanken, einen Perspektivwechsel, einen Moment von Verbindung oder die Erinnerung daran, dass Veränderung oft leise beginnt.</p>
      <p>Künftig können hier neben Texten auch <strong>Audio-Impulse, kurze Videos, Reflexionsübungen oder geführte Fantasiereisen</strong> erscheinen.</p>

      <div class="btn-group">
        <a href="#beitraege" class="btn btn-primary">Neueste Beiträge lesen</a>
        <a href="#audio" class="btn btn-secondary">Audio-Impulse anhören</a>
        <a href="#audio" class="btn btn-secondary">Videos ansehen</a>
        <a href="#themen" class="btn btn-ghost">Themen entdecken</a>
      </div>
    </div>
  </section>

  <section class="section bg-cream-deep" id="themen">
    <div class="container">
      <header class="section-head">
        <span class="eyebrow">Kategorien</span>
        <h2>Themen, die <em>diese Seite tragen</em></h2>
      </header>

      <div class="topic-grid">
        {IMPULSE_TOPICS.map((t) => (
          <article class="topic-card">
            <h3>{t.name}</h3>
            <p>{t.text}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section bg-cream" id="beitraege">
    <div class="container">
      <header class="section-head">
        <span class="eyebrow">Impulse zum Mitnehmen</span>
        <h2>Gedanken, die <em>nachklingen</em></h2>
        <p class="lead" style="margin: 0 auto;">
          Kleine Texte zu Themen, die mich bewegen — und die hoffentlich auch dich
          berühren, zum Nachdenken anregen oder etwas in dir öffnen.
        </p>
      </header>

      <div class="beitrag-grid">
        {IMPULSE_BEITRAEGE.map((b) => (
          <article class="beitrag-card">
            <span class="beitrag-cat">{b.category}</span>
            <h3>{b.title}</h3>
            <p>{b.teaser}</p>
            <p class="beitrag-source">{b.source}</p>
          </article>
        ))}
      </div>

      <div class="beitrag-foot">
        <p>Weitere Gedanken und Impulse findest du auf meinen Social-Media-Kanälen:</p>
        <div class="btn-group">
          <a href={SOCIAL.instagram} target="_blank" rel="noopener noreferrer" class="btn btn-secondary">Instagram besuchen</a>
          <a href={SOCIAL.linkedin} target="_blank" rel="noopener noreferrer" class="btn btn-secondary">LinkedIn besuchen</a>
        </div>
      </div>
    </div>
  </section>

  <section class="section bg-cream-soft" id="audio">
    <div class="container split-grid">
      <div>
        <span class="eyebrow">Audio &amp; Video</span>
        <h2>Geführte Audio-Impulse, <em>Fantasiereisen und Videos</em></h2>
        <p>
          Geführte <strong>Audio-Impulse, Fantasiereisen und innere Reisen</strong>
          unterstützen dich dabei, zur Ruhe zu kommen, Stabilität zu finden und
          wieder mehr Verbindung zu dir selbst aufzubauen.
        </p>
        <p>
          Elemente aus der <strong>Progressiven Muskelentspannung nach Jacobson</strong>
          und verwandten Entspannungsverfahren können helfen, körperliche Anspannung
          bewusster wahrzunehmen und Schritt für Schritt mehr innere und äußere
          Entspannung zu entwickeln.
        </p>
        <p>
          Geplante Formate: kurze Audio-Impulse für den Alltag, geführte
          Fantasiereisen für Ruhe und Klarheit, Reflexionsübungen und Videos zu
          Bewusstsein und innerer Stabilität.
        </p>
        <p><span class="tag tag-outline">In Vorbereitung</span></p>
        <div class="btn-group">
          <button type="button" class="btn btn-secondary" data-modal-open="vormerken" data-publication="audio-video">Bei Erscheinen informieren lassen</button>
        </div>
      </div>
      <figure class="split-image">
        <img src={IMAGES.impulseAufbruch} alt="Lebendige Aufbruchsstimmung im Abendlicht" loading="lazy" />
      </figure>
    </div>
  </section>
</BaseLayout>

<style>
  .page-intro { text-align: center; margin-bottom: 1.5rem; }
  .page-intro h1 { margin: 0.5rem 0 1rem; }
  .page-intro .lead { margin: 0 auto; }
  .muted { color: var(--color-ink-muted); font-style: italic; }

  .topic-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(17rem, 1fr)); gap: 1rem; }
  .topic-card { background: var(--color-paper); border: 1px solid var(--color-line); border-radius: var(--radius-m); border-top: 3px solid var(--color-clay); padding: 1.25rem 1.5rem; transition: all var(--transition); }
  .topic-card:hover { box-shadow: var(--shadow-soft); }
  .topic-card h3 { font-size: 1.05rem; margin-bottom: 0.5rem; color: var(--color-sage-deep); font-family: var(--font-display); font-weight: 500; }
  .topic-card p { font-size: 0.88rem; line-height: 1.55; color: var(--color-ink-muted); margin: 0; max-width: none; }

  .split-grid { display: grid; grid-template-columns: 1fr; gap: clamp(2rem, 4vw, 3rem); align-items: center; }
  @media (min-width: 860px) { .split-grid { grid-template-columns: 1fr 1fr; } }
  .split-image { margin: 0; }
  .split-image img { width: 100%; aspect-ratio: 4/3; object-fit: cover; border-radius: var(--radius-l); box-shadow: var(--shadow-lift); }

  /* Impulse-Beiträge */
  .beitrag-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(18rem, 1fr));
    gap: 1.5rem;
    margin-bottom: 2.5rem;
  }
  .beitrag-card {
    background: var(--color-paper);
    border: 1px solid var(--color-line);
    border-radius: var(--radius-m);
    padding: 1.75rem 1.6rem;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    transition: transform 260ms, box-shadow 260ms;
  }
  .beitrag-card:hover {
    transform: translateY(-3px);
    box-shadow: var(--shadow-card);
  }
  .beitrag-cat {
    font-size: 0.72rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--color-clay);
    font-weight: 600;
  }
  .beitrag-card h3 {
    font-family: var(--font-display);
    font-size: 1.4rem;
    font-weight: 400;
    line-height: 1.2;
    color: var(--color-ink);
    margin: 0;
    letter-spacing: -0.005em;
  }
  .beitrag-card > p {
    font-size: 0.95rem;
    line-height: 1.6;
    color: var(--color-ink-soft);
    margin: 0;
    flex: 1;
    max-width: none;
  }
  .beitrag-source {
    font-size: 0.78rem !important;
    color: var(--color-ink-muted) !important;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    border-top: 1px solid var(--color-line-soft);
    padding-top: 0.75rem;
    margin-top: 0.5rem !important;
    flex: 0 0 auto !important;
  }
  .beitrag-foot {
    text-align: center;
    padding-top: 1.25rem;
    border-top: 1px solid var(--color-line-soft);
  }
  .beitrag-foot p {
    margin: 0 auto 1rem;
    color: var(--color-ink-soft);
    font-style: italic;
  }
  .beitrag-foot .btn-group {
    justify-content: center;
  }
</style>
