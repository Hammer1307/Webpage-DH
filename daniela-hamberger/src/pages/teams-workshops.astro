---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { SITE, IMAGES, TEAM_FORMATS } from '@/data/site';

const description =
  'Workshops und Teamcoaching für gelingendes Miteinander — Impulsvortrag, TeamBalance, TeamReset, Team-Starterpaket und intensives Teamcoaching mit Daniela Britta Hamberger.';

const breadcrumb = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Start', item: `${SITE.url}/` },
    { '@type': 'ListItem', position: 2, name: 'Teams & Workshops', item: `${SITE.url}/teams-workshops` },
  ],
};
---
<BaseLayout
  title="Teams & Workshops"
  description={description}
  schema={breadcrumb}
>
  <img class="image-accent" src={IMAGES.teamsWorkshop} alt="" loading="eager" />

  <section class="section section-cream">
    <div class="container-narrow">
      <nav class="breadcrumb" aria-label="Breadcrumb">
        <a href="/">Start</a><span>/</span><span>Teams &amp; Workshops</span>
      </nav>
      <header class="page-intro">
        <span class="eyebrow">Workshops &amp; Teamcoaching</span>
        <h1>Für gelingendes <em>Miteinander</em></h1>
        <p class="lead">
          Wenn ihr wieder klarer, wertschätzender und menschlicher miteinander arbeiten möchtet
        </p>
      </header>

      <h2>Vielleicht kennt ihr das:</h2>
      <ul class="check-list">
        <li>Ihr arbeitet zusammen, aber nicht immer wirklich miteinander.</li>
        <li>Kommunikation wird schneller, aber nicht klarer.</li>
        <li>Missverständnisse wiederholen sich.</li>
        <li>Manches bleibt unausgesprochen.</li>
        <li>Wertschätzung ist eigentlich da, wird aber im Alltag zu selten spürbar.</li>
        <li>Jeder funktioniert — aber das gemeinsame Gefühl geht verloren.</li>
      </ul>

      <p>
        Genau hier setzen meine Teamformate an. Ich begleite euch dabei, euer Miteinander
        bewusster wahrzunehmen, Kommunikation zu reflektieren und neue Wege für mehr Klarheit,
        Vertrauen, Empathie und Wertschätzung zu entwickeln.
      </p>
      <p>
        Dabei geht es nicht darum, dass alle gleich werden. Es geht darum, Unterschiedlichkeit
        besser zu verstehen, Brücken zu bauen und wieder mehr Verbindung im Team entstehen
        zu lassen.
      </p>
    </div>
  </section>

  <section class="section section-cream-deep">
    <div class="container-narrow">
      <h2 class="text-center">Was in euren Teamprozessen entstehen darf</h2>
      <ul class="benefits-grid">
        <li>mehr Vertrauen und Offenheit</li>
        <li>klarere Kommunikation</li>
        <li>mehr Wertschätzung im Alltag</li>
        <li>bewussterer Umgang mit Rollen und Erwartungen</li>
        <li>mehr Verständnis für unterschiedliche Perspektiven</li>
        <li>weniger Gegeneinander, mehr Miteinander</li>
        <li>mehr Leichtigkeit, Menschlichkeit und gemeinsames Verantwortungsgefühl</li>
        <li>ein Teamgefühl, das nicht nur funktioniert, sondern trägt</li>
      </ul>
    </div>
  </section>

  <section class="section section-cream">
    <div class="container">
      <header class="section-head">
        <span class="eyebrow">Teamformate</span>
        <h2>Fünf Wege, mit eurem Team <em>zu arbeiten</em></h2>
      </header>

      <div class="format-grid">
        {TEAM_FORMATS.map((f) => (
          <article class:list={['format-card', { 'card-featured': f.featured }]}>
            <span class="tag tag-outline format-badge">{f.label}</span>
            <h3>{f.name}</h3>
            <p class="format-duration">{f.duration}</p>
            <p class="format-desc">{f.description}</p>
            {f.topics && <p class="format-meta">{f.topics}</p>}
            {f.suitableFor && <p class="format-meta">{f.suitableFor}</p>}
            <div class="format-foot">
              <p class="format-price">
                <span class="label">Investition</span>
                <strong>{f.price}</strong>
              </p>
              <a href={f.href} class="btn btn-outline">{f.cta}</a>
            </div>
          </article>
        ))}
      </div>

      <div class="cta-band">
        <h3>Interesse an einem Teamformat?</h3>
        <p>
          Ich freue mich auf ein erstes Gespräch. Gemeinsam schauen wir, welches Format zu
          eurem Team und eurem Anliegen passt.
        </p>
        <a href="/kontakt" class="btn btn-primary">Teamformat anfragen</a>
      </div>
    </div>
  </section>

  <section class="section section-cream-deep">
    <div class="container-text">
      <blockquote class="disclaimer">
        <strong>Wichtiger Hinweis:</strong> Meine Arbeit versteht sich als ganzheitliche
        Begleitung. Sie ersetzt keine ärztliche, psychotherapeutische oder heilkundliche
        Diagnose oder Behandlung.
      </blockquote>
    </div>
  </section>
</BaseLayout>

<style>
  .page-intro { text-align: center; margin-bottom: 3rem; }
  .page-intro h1 { margin: 0.5rem 0 1rem; }
  .page-intro .lead { margin: 0 auto; }
  .check-list { list-style: none; padding: 0; margin: 1.5rem 0 2rem; }
  .check-list li {
    padding: 0.7rem 0 0.7rem 1.75rem;
    border-bottom: 1px solid var(--color-line);
    position: relative;
    color: var(--color-ink);
  }
  .check-list li::before {
    content: '·';
    position: absolute; left: 0; top: 0.4rem;
    color: var(--color-gold-deep);
    font-size: 1.75rem;
    line-height: 1;
  }
  .benefits-grid {
    list-style: none; padding: 0;
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(15rem, 1fr));
    gap: 0.5rem 2rem;
  }
  .benefits-grid li {
    padding: 0.6rem 0 0.6rem 1.5rem;
    position: relative;
    color: var(--color-ink);
  }
  .benefits-grid li::before {
    content: '✓';
    position: absolute; left: 0; top: 0.6rem;
    color: var(--color-sage-deep);
  }
  .text-center { text-align: center; margin-bottom: 2rem; }

  .format-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(20rem, 1fr));
    gap: 1.5rem;
    margin-bottom: 3rem;
  }
  .format-card {
    background: var(--color-paper);
    border: 1px solid var(--color-line);
    border-radius: var(--radius-m);
    padding: 1.75rem;
    position: relative;
    display: flex;
    flex-direction: column;
    transition: all var(--transition);
  }
  .format-card.card-featured {
    background: var(--color-cream-soft);
    border-color: var(--color-gold);
  }
  .format-card:hover {
    box-shadow: var(--shadow-card);
    transform: translateY(-2px);
  }
  .format-badge {
    align-self: flex-start;
    margin-bottom: 0.75rem;
  }
  .format-card h3 { margin-bottom: 0.5rem; font-size: 1.4rem; }
  .format-duration {
    color: var(--color-bordeaux);
    font-style: italic;
    font-family: var(--font-display);
    font-size: 1rem;
    margin-bottom: 1rem;
  }
  .format-desc {
    font-size: 0.92rem;
    color: var(--color-ink-soft);
    margin-bottom: 1rem;
  }
  .format-meta {
    font-size: 0.85rem;
    color: var(--color-ink-muted);
    background: var(--color-cream);
    padding: 0.65rem 0.85rem;
    border-radius: var(--radius-s);
    margin-bottom: 0.75rem;
    border-left: 2px solid var(--color-gold);
  }
  .format-foot {
    margin-top: auto;
    padding-top: 1.25rem;
    border-top: 1px solid var(--color-line);
    display: flex;
    flex-direction: column;
    gap: 1rem;
    align-items: flex-start;
  }
  .format-price { margin: 0; display: flex; flex-direction: column; gap: 0.15rem; }
  .format-price .label {
    font-size: 0.7rem; text-transform: uppercase; letter-spacing: 0.15em;
    color: var(--color-ink-muted);
  }
  .format-price strong {
    font-family: var(--font-display); font-size: 1.15rem;
    color: var(--color-bordeaux); font-weight: 500;
  }

  .cta-band {
    text-align: center;
    padding: 3rem 2rem;
    background: var(--color-cream-soft);
    border-radius: var(--radius-l);
    border: 1px solid var(--color-line-gold);
  }
  .cta-band h3 { margin-bottom: 0.75rem; }
  .cta-band p { max-width: 50ch; margin: 0 auto 1.5rem; }
</style>
