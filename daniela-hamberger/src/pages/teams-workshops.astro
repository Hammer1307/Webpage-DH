---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { SITE, IMAGES, TEAM_FORMATS, WORKSHOP_TOPICS, VENUE } from '@/data/site';

const description =
  'Workshops und Teamcoaching für gelingendes Miteinander — Impulsvortrag, TeamBalance Workshop und TeamReset mit Daniela Britta Hamberger. Online sowie vor Ort in Wiesbaden, Idstein oder bei euch im Rhein-Main-Gebiet.';

const breadcrumb = {
  '@context': 'https://schema.org', '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Start', item: `${SITE.url}/` },
    { '@type': 'ListItem', position: 2, name: 'Teams & Workshops', item: `${SITE.url}/teams-workshops` },
  ],
};
---
<BaseLayout title="Teams & Workshops" description={description} schema={breadcrumb}>
  <img class="image-accent image-accent--portrait-source" src={IMAGES.danielaTeams} alt="Daniela Britta Hamberger am Flipchart — Klarheit und neue Perspektiven für Teams" loading="eager" />

  <section class="section bg-cream">
    <div class="container-narrow">
      <nav class="breadcrumb" aria-label="Breadcrumb"><a href="/">Start</a><span>/</span><span>Teams &amp; Workshops</span></nav>
      <header class="page-intro">
        <span class="eyebrow">Für Teams &amp; Organisationen</span>
        <h1>Miteinander, das <em>wieder wirkt</em></h1>
        <p class="lead">Wenn ihr wieder klarer, wertschätzender und menschlicher miteinander arbeiten möchtet.</p>
      </header>
    </div>
  </section>

  <section class="section bg-cream-deep">
    <div class="container split-grid">
      <figure class="split-image">
        <img src={IMAGES.teamsErschoepft} alt="Erschöpfte Person am Arbeitsplatz — wenn das Miteinander schwerer wird" loading="lazy" />
      </figure>
      <div>
        <h2>Vielleicht kennt ihr das:</h2>
        <ul class="check-list">
          <li>Ihr arbeitet zusammen, aber nicht immer wirklich miteinander.</li>
          <li>Kommunikation läuft aneinander vorbei.</li>
          <li>Wertschätzung ist eigentlich da, wird aber im Alltag zu selten spürbar.</li>
          <li>Manches bleibt unausgesprochen.</li>
          <li>Jeder funktioniert — aber das gemeinsame Gefühl geht verloren.</li>
        </ul>
        <p>
          Ich begleite euch dabei, euer Miteinander bewusster wahrzunehmen, Kommunikation zu reflektieren und neue Wege für mehr Klarheit, Vertrauen, Empathie und Wertschätzung zu entwickeln.
        </p>
        <p>
          Dabei geht es nicht darum, dass alle gleich werden. Es geht darum, Unterschiedlichkeit besser zu verstehen, Brücken zu bauen und wieder mehr Verbindung im Team entstehen zu lassen.
        </p>
      </div>
    </div>
  </section>

  <section class="section bg-cream-soft">
    <div class="container split-grid">
      <div>
        <span class="eyebrow">Wo wir zusammenarbeiten</span>
        <h2>Direkt bei euch, online oder <em>in einem stimmigen Raum</em></h2>
        <p>
          Workshops und Teamformate können je nach Anliegen online, in geeigneten Räumlichkeiten in
          Wiesbaden oder Idstein oder direkt <strong>bei euch vor Ort</strong> im Rhein-Main-Gebiet stattfinden.
        </p>
        <p>
          Für Teams und Organisationen komme ich nach Absprache auch zu euch — in eure Räume oder an
          einen geeigneten externen Ort. Für kleinere Gruppen und sehr kompakte Formate kann
          alternativ ein ruhiger Seminarraum in Wiesbaden genutzt werden, wenn das zum Anliegen passt.
        </p>
        <p>
          Gerade für Teamprozesse ist der Rahmen wichtig. Wenn Menschen einmal aus dem gewohnten
          Arbeitsumfeld heraustreten, wird ein anderer Blick möglich: auf Kommunikation, Rollen,
          Spannungen, Ressourcen und das, was im Miteinander wieder wachsen darf.
        </p>
        <div class="btn-group">
          <button type="button" class="btn btn-primary" data-modal-open="teams" data-format="teamvorgespraech">Teamvorgespräch buchen</button>
        </div>
      </div>
      <figure class="split-image">
        <img src={IMAGES.teamsWorkshop} alt="Team in Workshop-Situation — gemeinsames Arbeiten an Ideen" loading="lazy" />
      </figure>
    </div>
  </section>

  <section class="section bg-cream">
    <div class="container">
      <header class="section-head">
        <span class="eyebrow">Teamformate</span>
        <h2>Drei Wege, <em>mit eurem Team zu arbeiten</em></h2>
      </header>

      <div class="format-grid">
        {TEAM_FORMATS.map((f) => (
          <article class:list={['format-card', { 'card-featured': f.featured }]}>
            <span class="tag tag-outline format-badge">{f.label}</span>
            <h3>{f.name}</h3>
            <p class="format-duration">{f.duration}</p>
            <p class="format-desc">{f.description}</p>
            {f.topics && <p class="format-meta">{f.topics}</p>}
            {f.suitableFor && <p class="format-meta">{f.suitableFor}</p>}
            <div class="format-foot">
              <p class="format-price"><span class="label">Investition</span><strong>{f.price}</strong></p>
              <button type="button" class="btn btn-secondary" data-modal-open="teams" data-format={f.id}>{f.cta}</button>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section bg-cream-soft">
    <div class="container">
      <header class="section-head">
        <span class="eyebrow">Mögliche Workshop-Themen</span>
        <h2>Themen, die <em>im Miteinander wirken</em></h2>
        <p class="lead" style="margin: 0 auto;">
          Workshops und Teamformate gestalten wir gemeinsam — passend zu eurem Anliegen.
          Hier eine Auswahl an Themen, die ich häufig begleite. Was bei euch dran ist,
          klären wir im kostenfreien Teamvorgespräch.
        </p>
      </header>

      <div class="topics-grid">
        {WORKSHOP_TOPICS.map((t) => (
          <article class="topic-card">
            <h3>{t.title}</h3>
            <p>{t.text}</p>
          </article>
        ))}
      </div>

      <div class="topics-cta">
        <p>Auch andere Themen sind möglich. Ich gehe gern auf eure konkreten Anliegen ein.</p>
        <button type="button" class="btn btn-primary" data-modal-open="teams" data-format="teamvorgespraech">Kostenfreies Teamvorgespräch buchen</button>
      </div>
    </div>
  </section>

  <section class="section bg-cream-deep">
    <div class="container-text">
      <blockquote class="disclaimer">
        <strong>Wichtiger Hinweis:</strong> Meine Arbeit versteht sich als ganzheitliche Begleitung. Sie kann persönliche Entwicklungsprozesse unterstützen, ersetzt jedoch keine medizinische, psychotherapeutische oder heilkundliche Behandlung.
      </blockquote>
    </div>
  </section>

  <section class="section bg-sage">
    <div class="container-narrow" style="text-align: center;">
      <h2>Sprechen wir über <em>euer Team</em></h2>
      <p style="margin: 1rem auto 2rem; max-width: 50ch;">Ein kostenfreies Erstgespräch klärt, ob und in welcher Form eine Zusammenarbeit Sinn macht.</p>
      <button type="button" class="btn btn-gold" data-modal-open="teams" data-format="unklar">Anfrage senden</button>
    </div>
  </section>
</BaseLayout>

<style>
  .page-intro { text-align: center; margin-bottom: 2rem; }
  .page-intro h1 { margin: 0.5rem 0 1rem; }
  .page-intro .lead { margin: 0 auto; }
  .check-list { list-style: none; padding: 0; margin: 1rem 0 1.5rem; }
  .check-list li { padding: 0.6rem 0 0.6rem 1.5rem; border-bottom: 1px solid var(--color-line-soft); position: relative; color: var(--color-ink); }
  .check-list li::before { content: '·'; position: absolute; left: 0; top: 0.25rem; color: var(--color-clay); font-size: 1.6rem; line-height: 1; }

  .split-grid { display: grid; grid-template-columns: 1fr; gap: clamp(2rem, 4vw, 3rem); align-items: center; }
  @media (min-width: 860px) { .split-grid { grid-template-columns: 1fr 1fr; } }
  .split-image { margin: 0; }
  .split-image img { width: 100%; aspect-ratio: 4/3; object-fit: cover; border-radius: var(--radius-l); box-shadow: var(--shadow-lift); }

  .venue-card { font-style: normal; background: var(--color-paper); border-left: 3px solid var(--color-clay); padding: 1rem 1.25rem; margin: 1rem 0 0.5rem; border-radius: 0 var(--radius-s) var(--radius-s) 0; line-height: 1.55; }
  .venue-card strong { color: var(--color-sage-deep); }
  .venue-note { font-size: 0.85rem; color: var(--color-ink-muted); }

  .format-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(20rem, 1fr)); gap: 1.5rem; }
  .format-card { background: var(--color-paper); border: 1px solid var(--color-line); border-radius: var(--radius-l); padding: 1.75rem; position: relative; display: flex; flex-direction: column; transition: all var(--transition); }
  .format-card.card-featured { background: var(--color-cream-soft); border-color: var(--color-clay); }
  .format-card:hover { box-shadow: var(--shadow-card); transform: translateY(-2px); }
  .format-badge { align-self: flex-start; margin-bottom: 0.75rem; }
  .format-card h3 { margin-bottom: 0.5rem; font-size: 1.4rem; }
  .format-duration { color: var(--color-sage-deep); font-family: var(--font-display); font-style: italic; font-size: 1rem; margin-bottom: 1rem; max-width: none; }
  .format-desc { font-size: 0.92rem; color: var(--color-ink-soft); margin-bottom: 1rem; max-width: none; }
  .format-meta { font-size: 0.85rem; color: var(--color-ink-muted); background: var(--color-cream); padding: 0.65rem 0.85rem; border-radius: var(--radius-s); margin-bottom: 0.75rem; border-left: 2px solid var(--color-clay); max-width: none; }
  .format-foot { margin-top: auto; padding-top: 1.25rem; border-top: 1px solid var(--color-line-soft); display: flex; flex-direction: column; gap: 1rem; align-items: stretch; }
  .format-foot .btn { white-space: normal; line-height: 1.3; text-align: center; min-height: auto; padding-top: 0.75rem; padding-bottom: 0.75rem; }
  .format-price { margin: 0; display: flex; flex-direction: column; gap: 0.15rem; max-width: none; }
  .format-price .label { font-size: 0.7rem; text-transform: uppercase; letter-spacing: 0.15em; color: var(--color-ink-muted); }
  .format-price strong { font-family: var(--font-display); font-size: 1.25rem; color: var(--color-sage-deep); font-weight: 500; }

  /* Workshop-Themen */
  .topics-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(17rem, 1fr));
    gap: 1rem;
    margin-bottom: 2.5rem;
  }
  .topic-card {
    background: var(--color-paper);
    border: 1px solid var(--color-line);
    border-top: 3px solid var(--color-sage);
    border-radius: var(--radius-m);
    padding: 1.25rem 1.4rem;
    transition: transform 260ms, box-shadow 260ms;
  }
  .topic-card:hover {
    transform: translateY(-2px);
    box-shadow: var(--shadow-card);
  }
  .topic-card h3 {
    font-family: var(--font-display);
    font-size: 1.15rem;
    font-weight: 400;
    color: var(--color-ink);
    margin: 0 0 0.5rem;
    letter-spacing: -0.005em;
    line-height: 1.25;
  }
  .topic-card p {
    font-size: 0.9rem;
    color: var(--color-ink-soft);
    line-height: 1.55;
    margin: 0;
    max-width: none;
  }
  .topics-cta {
    text-align: center;
    padding-top: 1.5rem;
    border-top: 1px solid var(--color-line-soft);
  }
  .topics-cta p {
    margin: 0 auto 1.25rem;
    color: var(--color-ink-soft);
    font-style: italic;
    max-width: 40ch;
  }
</style>
