---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { SITE } from '@/data/site';

const title = 'Über mich — Daniela Britta Hamberger';
const description =
  'Mutter, Künstlerin, Pädagogin, Autorin, Coachin. Lerne mich als Mensch kennen — neben meiner Arbeit als ganzheitliche Mentorin.';
---
<BaseLayout title={`Über mich · ${SITE.brand}`} description={description}>

  <section class="page-hero">
    <div class="container ph-grid">
      <div class="ph-text">
        <nav class="breadcrumb"><a href="/">Start</a><span>/</span><span>Über mich</span></nav>
        <span class="eyebrow">Hi, ich bin</span>
        <h1>Daniela <em>Britta</em><br />Hamberger</h1>
        <p class="lead">Mentorin, Coachin, Autorin & Künstlerin</p>
        <p class="ph-welcome">
          Ich freue mich, dass du hier bist. Möchtest du mich als Mensch
          kennenlernen — neben meiner Arbeit als ganzheitliche Coachin,
          Künstlerin und Autorin?
        </p>
      </div>
      <div class="ph-photo">
        <img
          src="https://cdn.gamma.app/bwtiitetcy0uj9u/9c6c25e6510d4f06b98c5ac935e92629/original/Ich-Buisnesslook2.png"
          alt="Daniela Britta Hamberger"
          loading="eager"
        />
      </div>
    </div>
  </section>

  <section class="wer-ich-bin">
    <div class="container container-narrow">
      <header class="section-head section-head-left">
        <span class="eyebrow">Wer ich bin</span>
        <h2>Mehr als <em>eine Rolle</em></h2>
      </header>

      <div class="text-block">
        <p>
          Ich bin Daniela Hamberger — und ja, das mit den Rollen ist so eine Sache:
          <strong>Mutter, Künstlerin, Pädagogin, Autorin, Coachin, Seminarleiterin</strong>
          und stolze Halterin <em>dreier treuer Hundegefährten</em>. Mein Herz schlägt für
          die Natur und ich finde mein Glück in der Balance zwischen trubeligerem,
          harmonischem Miteinander und den stillen Momenten, in denen ich zur Ruhe
          kommen, meiner Kreativität nachgehen, ein gutes Buch lesen oder einfach
          meditativ innehalten und Inspirationen sammeln kann.
        </p>

        <p>
          Mein Interesse treibt mich dazu an, neue Orte, Menschen, Landschaften,
          Kunst, Kultur und Musik zu entdecken. Gleichzeitig liebe ich es, nach Hause
          zu kommen, es mir gemütlich zu machen und — ganz klischeehaft — die Seele
          baumeln zu lassen. Und Hand aufs Herz: So gerne ich mich auch mal verwöhnen
          lasse, genauso begeistert schlüpfe ich in die Rolle der Gastgeberin und
          heiße Familie und Gäste willkommen. Kulinarisch haben es mir vor allem die
          Aromen der <em>indischen, asiatischen und mediterranen Küche</em> angetan.
        </p>

        <div class="music-block">
          <h3>Musik & Inspiration</h3>
          <p>
            Musik ist für mich eine wichtige Quelle von energetischer Verstärkung
            durch Rhythmen und Texte. Sie gibt mir die Möglichkeit, mich auszudrücken.
            Auch musikalisch bin ich ein echtes Chamäleon, mein Geschmack ist breit
            gefächert:
          </p>
          <ul class="music-tags">
            <li>Robbie Williams</li>
            <li>P!nk</li>
            <li>Red Hot Chili Peppers</li>
            <li>Amy Winehouse</li>
            <li>Eros Ramazzotti</li>
            <li>Ed Sheeran</li>
            <li>Loreena McKennitt</li>
            <li>Alanis Morissette</li>
            <li>4 to the bar</li>
            <li>Buddha and Bonsai</li>
            <li>Lex van Someren</li>
            <li>Heilklänge</li>
          </ul>
          <p>
            So vielfältig meine musikalischen Vorlieben sind, so breit gefächert ist
            auch mein Interesse an Büchern, Filmen, der Schönheit der Kunst, Gärten,
            Architektur und den einzigartigen Begegnungen mit Menschen.
          </p>
        </div>

        <blockquote class="lifestyle-quote">
          <p>
            Diese Vielfalt ist meine <em>Würze des Lebens</em> — die Harmonie des
            Verbindenden und die Bereicherung des Unterschiedlichen. Und entscheidend
            ist für mich, dass mein Herz berührt wird.
          </p>
        </blockquote>
      </div>
    </div>
  </section>

  <section class="mein-wirken">
    <div class="container wirken-grid">
      <div class="wirken-photo">
        <img
          src="https://cdn.gamma.app/bwtiitetcy0uj9u/21437661fef64aa8b95e89df1094cd03/original/image.png"
          alt="Daniela bei der Arbeit"
          loading="lazy"
        />
      </div>
      <div class="wirken-text">
        <span class="eyebrow">Mein Wirken</span>
        <h2>Über <em>15 Jahre</em> Begleitung</h2>
        <p>
          Ich begleite seit über 15 Jahren Menschen dabei, Klarheit zu finden,
          innere Balance zu stärken und ihr Potenzial zu entfalten. Meine Arbeit
          verbindet ganzheitliches Coaching mit systemischem Fokus, sowie
          praxiserprobten, integrativen Methoden und auf Wunsch auch
          <strong>Hypnose, PSYCH-K® oder Akasha-Chronik-Reading</strong>.
        </p>
        <p>
          Durch meinen pädagogischen Hintergrund lege ich Wert auf verständliche,
          alltagsnahe und gut anwendbare Inhalte.
        </p>
        <p>
          Mein eigener Weg — geprägt von Umbrüchen und einem <em>Burn-out</em> —
          hat mich gelehrt, wie wichtig es ist, der inneren Stimme Raum zu geben.
          Diese Erfahrung bildet das Fundament meiner Arbeit.
        </p>
        <p>
          In einer Welt voller Leistungsdruck und reißerischem Medienkonsum
          verlieren viele Menschen den Kontakt zu sich selbst. Genau hier setze
          ich an: in Coachings, Workshops und in meinen Publikationen.
        </p>
      </div>
    </div>
  </section>

  <section class="als-autorin">
    <div class="container container-narrow">
      <header class="section-head">
        <span class="eyebrow">Auch als Autorin</span>
        <h2>Geschichten, die <em>berühren</em></h2>
      </header>
      <p>
        Ich schreibe bzw. plane Ratgeber zu Familie, Beziehungen, Kommunikation,
        Stressresilienz, Selbstfindung und Lebensfreude. Dazu kommen Kartensets,
        ein achtsamkeitsorientiertes Kinder-Eltern-Buch sowie ein Sachbuch mit
        inkludiertem Workbook zur Arbeit mit der Akasha-Chronik.
      </p>
      <p>
        Das Schreiben begleitet mich seit meiner Jugend — heute entstehen neben
        Jugendbüchern auch <em>Taunus-Krimis</em> unter Pseudonym. Meine Figuren
        werfen einen menschlichen Blick auf die Welt: ehrlich, nuanciert, berührbar.
      </p>
      <blockquote class="author-quote">
        <p>
          Hinter all meinen Werken steht ein Gedanke, der mich trägt:
          Menschen zu inspirieren — und auch selbst inspiriert zu werden.
          Räume zu öffnen für Höhenflüge, <em>Klarheit, Mut und Menschlichkeit</em>.
        </p>
      </blockquote>
    </div>
  </section>

  <section class="methoden">
    <div class="container">
      <header class="section-head">
        <span class="eyebrow">Mein Methodenspektrum</span>
        <h2>Womit ich <em>arbeite</em></h2>
        <p class="section-intro">
          Durch meine langjährige Erfahrung im Umgang mit Menschen verfüge ich
          über ein breites Methodenspektrum, das ich achtsam, individuell und
          passend zum jeweiligen Anliegen einsetze.
        </p>
      </header>

      <div class="method-grid">
        <div class="method-tile"><h3>Positive Psychologie</h3><p>Impulse aus der Glücksforschung — was Menschen wirklich stärkt.</p></div>
        <div class="method-tile"><h3>Achtsamkeit & Mentaltraining</h3><p>Übungen, die helfen, den eigenen Geist zu beruhigen und bewusst zu lenken.</p></div>
        <div class="method-tile"><h3>Bioenergetische Zugänge</h3><p>Arbeit mit der Verbindung von Körper und Gefühl.</p></div>
        <div class="method-tile"><h3>Hypnose & Hypnotherapie</h3><p>Sanfte Ansätze, um tiefere Schichten zu erreichen.</p></div>
        <div class="method-tile"><h3>PSYCH-K®</h3><p>Subkortikale Veränderungsarbeit für innere Glaubenssätze.</p></div>
        <div class="method-tile"><h3>Akasha-Chronik-Reading</h3><p>Auf Wunsch — als zusätzliche Perspektive für tiefere Klärung.</p></div>
        <div class="method-tile"><h3>Aufstellungsarbeit</h3><p>Systemische Perspektiven, die unsichtbare Dynamiken sichtbar machen.</p></div>
        <div class="method-tile"><h3>Symbol- & Bildarbeit</h3><p>Bild- und symbolgestützte Übungen für innere Klärung jenseits der Worte.</p></div>
        <div class="method-tile"><h3>Arbeit mit inneren Anteilen</h3><p>Begegnung mit dem inneren Kind und anderen Anteilen — wertschätzend.</p></div>
      </div>
    </div>
  </section>

  <section class="haltung">
    <div class="container container-narrow">
      <span class="eyebrow">Meine Haltung</span>
      <h2>Das <em>verbindende Element</em></h2>
      <p>
        Dabei geht es mir nicht um starre Methoden, sondern um den Menschen:
        Was braucht gerade Ordnung? Was möchte klarer werden? Wo darf wieder
        mehr Stabilität, Vertrauen und Lebensfreude entstehen?
      </p>
      <p>
        Meine Arbeit unterstützt Menschen dabei, innere Klarheit, Fokus und
        Lebensfreude zu stärken. Ich begleite sie darin, neue Perspektiven
        einzunehmen, sich selbst wertschätzender zu begegnen und eine
        harmonischere Beziehung zu sich selbst und ihrem Umfeld zu entwickeln.
      </p>
      <p class="signoff">
        Von Herz zu Herz<br /><em>Daniela</em>
      </p>
    </div>
  </section>

  <section class="final-cta">
    <div class="container final-cta-inner">
      <span class="eyebrow">Lass uns kennenlernen</span>
      <h2>Wenn dich meine Art zu arbeiten <em>anspricht</em></h2>
      <p>
        Ich freue mich darauf, dich in einem kostenfreien Orientierungsgespräch
        besser kennenzulernen.
      </p>
      <a href="/kontakt" class="btn btn-primary">Orientierungsgespräch buchen</a>
    </div>
  </section>

<style>
.page-hero {
  padding-top: clamp(2.5rem, 5vw, 4.5rem);
  padding-bottom: clamp(3.5rem, 8vw, 7rem);
  background: var(--color-cream);
}
.ph-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: clamp(2rem, 5vw, 4rem);
  align-items: stretch;
}
.ph-text {
  max-width: 34rem;
  display: flex;
  flex-direction: column;
  justify-content: center;
}
.breadcrumb {
  display: flex;
  gap: 0.5rem;
  font-size: 0.78rem;
  color: var(--color-ink-muted);
  margin-bottom: 1.5rem;
}
.breadcrumb a { color: var(--color-ink-muted); }
.breadcrumb a:hover { color: var(--color-sage-deep); }
.ph-text h1 {
  font-size: clamp(2.4rem, 4.5vw, 4rem);
  line-height: 1.02;
  letter-spacing: -0.03em;
  margin: 1rem 0 1.5rem;
  font-weight: 400;
}
.ph-text h1 em {
  color: var(--color-sage-deep);
  font-style: italic;
}
.ph-text .lead {
  font-family: var(--font-display);
  font-style: italic;
  font-size: 1.4rem;
  color: var(--color-sage-deep);
  margin-bottom: 1.5rem;
  max-width: none;
}
.ph-welcome {
  color: var(--color-ink-soft);
  line-height: 1.65;
  font-size: 1.02rem;
  max-width: 32rem;
}
.ph-photo {
  height: 100%;
  min-height: 28rem;
  display: flex;
  align-items: stretch;
}
.ph-photo img {
  width: 100%;
  height: 100%;
  min-height: 28rem;
  object-fit: cover;
  border-radius: var(--radius-l);
  box-shadow: var(--shadow-lift);
  display: block;
}

.wer-ich-bin {
  padding-block: clamp(4rem, 8vw, 7rem);
  background: var(--color-paper);
}
.section-head {
  text-align: center;
  max-width: 42rem;
  margin: 0 auto 3rem;
}
.section-head-left {
  text-align: left;
  margin-inline: 0;
}
.section-head h2 {
  margin-top: 0.5rem;
  font-size: clamp(2rem, 4vw, 3.2rem);
  line-height: 1.1;
  font-weight: 400;
  letter-spacing: -0.02em;
}
.section-head em {
  color: var(--color-sage-deep);
  font-style: italic;
}
.section-intro {
  margin-top: 1rem;
  color: var(--color-ink-soft);
  font-size: 1.02rem;
  line-height: 1.5;
}
.text-block p {
  color: var(--color-ink-soft);
  line-height: 1.75;
  margin-bottom: 1.5rem;
  font-size: 1.02rem;
}
.text-block strong {
  color: var(--color-ink);
  font-weight: 600;
}
.text-block em {
  color: var(--color-sage-deep);
}
.music-block {
  margin-top: 2.5rem;
  padding-top: 2.5rem;
  border-top: 1px solid var(--color-line);
}
.music-block h3 {
  font-size: 1.6rem;
  margin-bottom: 1rem;
  font-weight: 400;
}
.music-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 0.5rem;
  list-style: none;
  padding: 0;
  margin: 1.25rem 0 2rem;
}
.music-tags li {
  background: var(--color-cream);
  border: 1px solid var(--color-line);
  border-radius: var(--radius-pill);
  padding: 0.4rem 0.95rem;
  font-size: 0.82rem;
  color: var(--color-ink-soft);
}
.lifestyle-quote {
  margin-top: 2.5rem;
  padding: 1.75rem 2rem;
  background: var(--color-cream-soft);
  border-left: 3px solid var(--color-clay);
  border-radius: 0 var(--radius-m) var(--radius-m) 0;
}
.lifestyle-quote p {
  font-family: var(--font-display);
  font-size: 1.3rem;
  line-height: 1.45;
  font-style: italic;
  color: var(--color-ink);
  margin: 0;
  max-width: none;
}
.lifestyle-quote em {
  color: var(--color-clay);
}

.mein-wirken {
  padding-block: clamp(4rem, 8vw, 7rem);
  background: var(--color-cream);
}
.wirken-grid {
  display: grid;
  grid-template-columns: 0.85fr 1fr;
  gap: clamp(2rem, 5vw, 5rem);
  align-items: center;
}
.wirken-photo {
  width: 100%;
  max-width: 24rem;
  margin-inline: auto;
}
.wirken-photo img {
  aspect-ratio: 1;
  width: 100%;
  object-fit: cover;
  border-radius: var(--radius-l);
  box-shadow: var(--shadow-card);
}
.wirken-text { max-width: 34rem; }
.wirken-text h2 {
  font-size: clamp(2rem, 4vw, 3rem);
  line-height: 1.1;
  margin: 0.5rem 0 1.5rem;
  font-weight: 400;
  letter-spacing: -0.02em;
}
.wirken-text em {
  color: var(--color-sage-deep);
  font-style: italic;
}
.wirken-text p {
  color: var(--color-ink-soft);
  line-height: 1.7;
  margin-bottom: 1.25rem;
}
.wirken-text strong {
  color: var(--color-ink);
  font-weight: 600;
}

.als-autorin {
  padding-block: clamp(4rem, 8vw, 7rem);
  background: var(--color-paper);
}
.als-autorin p {
  color: var(--color-ink-soft);
  line-height: 1.7;
  margin-bottom: 1.25rem;
}
.als-autorin em {
  color: var(--color-sage-deep);
  font-style: italic;
}
.author-quote {
  margin-top: 2rem;
  padding: 2rem;
  background: var(--color-cream-soft);
  border-radius: var(--radius-l);
  text-align: center;
}
.author-quote p {
  font-family: var(--font-display);
  font-size: 1.4rem;
  line-height: 1.4;
  color: var(--color-ink);
  font-style: italic;
  margin: 0;
  max-width: none;
}
.author-quote em {
  color: var(--color-clay);
}

.methoden {
  padding-block: clamp(4rem, 8vw, 7rem);
  background: var(--color-cream-soft);
}
.method-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(min(100%, 16rem), 1fr));
  gap: 1rem;
}
.method-tile {
  background: var(--color-paper);
  border: 1px solid var(--color-line);
  border-radius: var(--radius-l);
  padding: 1.5rem;
  transition: all 0.25s ease;
}
.method-tile:hover {
  border-color: var(--color-sage-soft);
  transform: translateY(-2px);
}
.method-tile h3 {
  font-size: 1.1rem;
  font-family: var(--font-body);
  font-weight: 600;
  margin-bottom: 0.5rem;
  color: var(--color-ink);
}
.method-tile p {
  color: var(--color-ink-soft);
  font-size: 0.9rem;
  line-height: 1.55;
  margin: 0;
}

.haltung {
  padding-block: clamp(4rem, 8vw, 7rem);
  background: var(--color-paper);
  text-align: center;
}
.haltung h2 {
  margin: 0.5rem 0 1.5rem;
  font-size: clamp(2rem, 4vw, 3rem);
  line-height: 1.1;
  font-weight: 400;
  letter-spacing: -0.02em;
}
.haltung em {
  color: var(--color-sage-deep);
  font-style: italic;
}
.haltung p {
  color: var(--color-ink-soft);
  line-height: 1.7;
  margin: 0 auto 1.25rem;
  max-width: 38rem;
  font-size: 1.02rem;
}
.signoff {
  font-family: var(--font-display) !important;
  font-size: 1.4rem !important;
  font-style: italic;
  color: var(--color-ink) !important;
  margin-top: 2.5rem !important;
  padding-top: 2rem;
  border-top: 1px solid var(--color-line);
  max-width: 20rem !important;
}
.signoff em {
  color: var(--color-clay);
  font-size: 1.1em;
}

.final-cta {
  padding-block: clamp(4rem, 8vw, 7rem);
  background: var(--color-ink);
  color: var(--color-cream);
}
.final-cta-inner {
  text-align: center;
  max-width: 36rem;
  margin: 0 auto;
}
.final-cta .eyebrow { color: var(--color-clay-soft); }
.final-cta .eyebrow::before { background: var(--color-clay-soft); }
.final-cta h2 {
  font-size: clamp(2rem, 4vw, 3rem);
  line-height: 1.1;
  margin: 0.5rem 0 1rem;
  color: var(--color-cream);
  font-weight: 400;
  letter-spacing: -0.02em;
}
.final-cta em {
  color: var(--color-clay-soft);
  font-style: italic;
}
.final-cta p {
  color: rgba(245, 239, 230, 0.8);
  margin-bottom: 2rem;
  line-height: 1.5;
  font-size: 1.05rem;
}
.final-cta .btn-primary {
  background: var(--color-cream);
  color: var(--color-ink);
}
.final-cta .btn-primary:hover {
  background: white;
}

@media (max-width: 800px) {
  .ph-grid {
    grid-template-columns: 1fr;
  }
  .ph-photo {
    min-height: auto;
    max-width: 22rem;
    margin-inline: auto;
  }
  .ph-photo img {
    aspect-ratio: 4/5;
    min-height: auto;
    height: auto;
  }
  .wirken-grid {
    grid-template-columns: 1fr;
  }
  .wirken-photo {
    max-width: 18rem;
    order: -1;
  }
}
</style>
</BaseLayout>
