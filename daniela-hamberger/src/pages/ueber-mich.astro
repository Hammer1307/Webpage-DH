---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { SITE, IMAGES, METHODS } from '@/data/site';

const description =
  'Daniela Britta Hamberger — Mentorin für innere Stabilität, bewusste Entwicklung und gelingendes Miteinander. Pädagogische Erfahrung verbunden mit Hypnose, Mentaltraining, Achtsamkeit, positiver Psychologie, Aufstellungsarbeit und bioenergetischen Zugängen.';

const breadcrumb = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Start', item: `${SITE.url}/` },
    { '@type': 'ListItem', position: 2, name: 'Über mich', item: `${SITE.url}/ueber-mich` },
  ],
};
---
<BaseLayout
  title="Über mich"
  description={description}
  schema={breadcrumb}
>
  <section class="section section-cream">
    <div class="container">
      <nav class="breadcrumb" aria-label="Breadcrumb">
        <a href="/">Start</a><span>/</span><span>Über mich</span>
      </nav>

      <div class="um-grid">
        <div class="um-text">
          <span class="eyebrow">Über mich</span>
          <h1>Daniela Britta <em>Hamberger</em></h1>
          <p class="lead">
            Mentorin für innere Stabilität, bewusste Entwicklung und gelingendes Miteinander.
          </p>
          <p>
            <strong>Fokus Schöner Leben</strong> — Innere Ordnung. Neue Klarheit.
            Freude am Leben.
          </p>
          <p>
            In meiner Arbeit verbinde ich langjährige pädagogische Erfahrung mit Hypnose,
            Mentaltraining, Achtsamkeit, positiver Psychologie, Aufstellungsarbeit und
            bioenergetischen Zugängen.
          </p>
        </div>
        <figure class="um-portrait">
          <img src={IMAGES.portrait} alt="Daniela Britta Hamberger" loading="eager" />
          <figcaption><em>Daniela Britta Hamberger</em></figcaption>
        </figure>
      </div>
    </div>
  </section>

  <section class="section section-cream-deep">
    <div class="container-narrow">
      <p>
        Viele Jahre war ich als Pädagogin in der Sekundarstufe I tätig. Diese Zeit hat
        meinen Blick auf Menschen, Entwicklung und Beziehung tief geprägt. Wertschätzung,
        Kommunikation, Empathie, Klarheit, Perspektivwechsel und Motivation bilden bis heute
        die Grundlage meiner Arbeit.
      </p>
    </div>
  </section>

  <section class="section section-cream">
    <div class="container">
      <header class="section-head">
        <span class="eyebrow">Was mich besonders macht</span>
        <h2>Ein vielseitiger <em>Begleitansatz</em></h2>
        <p class="lead" style="margin: 0 auto;">
          Durch meine langjährige Erfahrung im Umgang mit Menschen verfüge ich über ein breites
          Methodenspektrum, das ich achtsam, individuell und passend zum jeweiligen Anliegen
          einsetze.
        </p>
      </header>

      <ul class="methoden-grid">
        {METHODS.map((m) => (
          <li class="methode">
            <h3>{m.name}</h3>
            {m.detail && <p>{m.detail}</p>}
          </li>
        ))}
      </ul>
    </div>
  </section>

  <section class="section section-cream-deep">
    <div class="container-narrow">
      <h2>Mein verbindendes Element</h2>
      <p>
        Meine Arbeit unterstützt Menschen dabei, innere Klarheit, Fokus und Lebensfreude zu
        stärken. Ich begleite sie darin, neue Perspektiven einzunehmen, sich selbst
        wertschätzender zu begegnen und eine harmonischere Beziehung zu sich selbst und ihrem
        Umfeld zu entwickeln.
      </p>
      <p>
        Im Mittelpunkt steht ein Leben, das bewusster, selbstbestimmter und stimmiger wird —
        mit mehr innerer Stabilität, mehr Verbindung zu den eigenen Bedürfnissen und mehr
        Vertrauen in den nächsten Schritt.
      </p>

      <h2 style="margin-top: 2.5rem;">Als Autorin</h2>
      <p>
        Auch in meinem Wirken als Autorin beschäftige ich mich mit Themen, die mich
        gesellschaftlich, sozial und persönlich prägen: Menschlichkeit, Naturverbundenheit,
        Wertevermittlung, Empathie, Resilienz, Achtsamkeit, Bewusstsein und gelingendes
        Miteinander.
      </p>
      <p>
        Diese Themen fließen in Workbooks, Selbstcoachingbücher, Kartensets, Romane,
        Erzählungen und Impulse für persönliche Entwicklung und Gruppenarbeit ein.
      </p>
      <p>
        Auch auf meinen Social-Media-Kanälen teile ich Gedanken, die zum Nachdenken anregen,
        verbinden und ermutigen sollen. Es geht mir darum, Wertschätzung sichtbar zu machen,
        Empathie zu stärken und Brücken zu bauen — zwischen Menschen, Perspektiven und
        Lebenswegen.
      </p>
    </div>
  </section>

  <section class="section section-bordeaux">
    <div class="container-narrow" style="text-align: center;">
      <h2>Lass uns kennenlernen</h2>
      <p style="margin: 1rem auto 2rem; max-width: 50ch;">
        Wenn du spürst, dass du dir mehr Klarheit, innere Stabilität oder neue Orientierung
        wünschst, lade ich dich herzlich zu einem kostenfreien Orientierungsgespräch ein.
        15–30 Minuten · unverbindlich · online oder telefonisch.
      </p>
      <a href="/kontakt" class="btn btn-gold">Kostenfreies Orientierungsgespräch buchen</a>
    </div>
  </section>
</BaseLayout>

<style>
  .um-grid {
    display: grid;
    grid-template-columns: 1.1fr 0.9fr;
    gap: clamp(2rem, 5vw, 4rem);
    align-items: center;
    margin-top: 1.5rem;
  }
  @media (max-width: 800px) {
    .um-grid { grid-template-columns: 1fr; }
  }
  .um-text h1 { margin: 0.5rem 0 1.25rem; }
  .um-text .lead { margin-bottom: 1rem; }
  .um-text p { margin-bottom: 1rem; }
  .um-portrait {
    margin: 0;
    aspect-ratio: 4/5;
    max-width: 26rem;
    margin-inline: auto;
    width: 100%;
  }
  .um-portrait img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    border-radius: var(--radius-l);
    box-shadow: var(--shadow-lift);
  }
  .um-portrait figcaption {
    margin-top: 1rem;
    text-align: center;
    color: var(--color-ink-muted);
    font-size: 0.9rem;
  }

  .methoden-grid {
    list-style: none;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(15rem, 1fr));
    gap: 1rem;
  }
  .methode {
    background: var(--color-paper);
    border: 1px solid var(--color-line);
    border-left: 3px solid var(--color-gold);
    padding: 1.25rem 1.5rem;
    border-radius: var(--radius-s);
    transition: all var(--transition);
  }
  .methode:hover {
    border-color: var(--color-gold);
    box-shadow: var(--shadow-soft);
  }
  .methode h3 {
    font-size: 1.05rem;
    margin: 0 0 0.25rem;
    color: var(--color-bordeaux);
    font-family: var(--font-display);
    font-weight: 500;
  }
  .methode p {
    margin: 0;
    font-size: 0.88rem;
    color: var(--color-ink-muted);
    font-style: italic;
  }
</style>
