---
import BaseLayout from '@/layouts/BaseLayout.astro';
---
<BaseLayout
  title="Seite nicht gefunden"
  description="Diese Seite konnte nicht gefunden werden."
  noindex
>
  <section class="section section-cream" style="text-align: center; padding-block: clamp(6rem, 12vw, 9rem);">
    <div class="container-narrow">
      <p class="eyebrow">404</p>
      <h1>Diese Seite konnte ich nicht <em>finden</em></h1>
      <p class="lead" style="margin: 1.5rem auto 2rem;">
        Vielleicht ist sie umgezogen oder nicht mehr da. Lass uns zurück zum Wesentlichen.
      </p>
      <div class="btn-group" style="justify-content: center;">
        <a href="/" class="btn btn-primary">Zur Startseite</a>
        <a href="/kontakt" class="btn btn-outline">Kontakt</a>
      </div>
    </div>
  </section>
</BaseLayout>
