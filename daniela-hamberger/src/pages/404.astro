---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { SITE } from '@/data/site';
---
<BaseLayout
  title={`Seite nicht gefunden · ${SITE.brand}`}
  description="Diese Seite existiert nicht — vielleicht hilft dir die Übersicht weiter."
>
  <section class="not-found">
    <div class="container container-narrow nf-inner">
      <span class="nf-num">404</span>
      <h1>Diese Seite gibt es <em>nicht</em>.</h1>
      <p>
        Vielleicht ist sie umgezogen, vielleicht hat sich ein Tippfehler in den
        Link geschlichen. Hier sind ein paar Wege zurück:
      </p>
      <ul class="nf-links">
        <li><a href="/">Zur Startseite</a></li>
        <li><a href="/ueber-mich">Über mich</a></li>
        <li><a href="/1-zu-1-begleitung">1:1 Begleitung</a></li>
        <li><a href="/teams-workshops">Teams & Workshops</a></li>
        <li><a href="/kontakt">Kontakt</a></li>
      </ul>
    </div>
  </section>

<style>
.not-found { padding-block: clamp(5rem, 10vw, 8rem); background: var(--color-cream); min-height: 60vh; display: flex; align-items: center; }
.nf-inner { text-align: center; max-width: 32rem; margin: 0 auto; }
.nf-num { font-family: var(--font-display); font-style: italic; font-size: clamp(5rem, 12vw, 10rem); color: var(--color-clay); line-height: 1; display: block; margin-bottom: 1rem; }
.not-found h1 { font-size: clamp(2rem, 4vw, 3rem); line-height: 1.1; margin-bottom: 1rem; font-weight: 400; letter-spacing: -0.02em; }
.not-found em { color: var(--color-sage-deep); font-style: italic; }
.not-found p { color: var(--color-ink-soft); line-height: 1.65; margin-bottom: 2rem; }
.nf-links { list-style: none; padding: 0; display: flex; flex-wrap: wrap; gap: 0.6rem; justify-content: center; }
.nf-links a { background: var(--color-paper); border: 1px solid var(--color-line); border-radius: var(--radius-pill); padding: 0.5rem 1rem; font-size: 0.88rem; color: var(--color-ink); transition: all 0.25s ease; }
.nf-links a:hover { background: var(--color-sage-pale); border-color: var(--color-sage-soft); }
</style>
</BaseLayout>
