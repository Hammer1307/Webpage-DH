---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { SITE, BOOKING_OPTIONS, CONTACT } from '@/data/site';

const description =
  'Kontakt und Buchung — kostenfreies Orientierungsgespräch, 1:1 Sitzung, KlarheitsReset oder Team-Vorgespräch mit Daniela Britta Hamberger.';

const breadcrumb = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Start', item: `${SITE.url}/` },
    { '@type': 'ListItem', position: 2, name: 'Kontakt', item: `${SITE.url}/kontakt` },
  ],
};
---
<BaseLayout
  title="Kontakt"
  description={description}
  schema={breadcrumb}
>
  <section class="page-hero">
    <div class="container">
      <nav class="breadcrumb" aria-label="Breadcrumb" style="text-align: left;">
        <a href="/">Start</a><span>/</span><span>Kontakt</span>
      </nav>
      <span class="eyebrow">Kontakt &amp; Buchung</span>
      <h1>Lass uns schauen, <em>was für dich passt</em></h1>
      <p class="lead">
        Du möchtest herausfinden, ob eine 1:1 Begleitung, ein KlarheitsReset oder ein
        Teamformat passend ist?
      </p>
    </div>
  </section>

  <section class="section section-cream">
    <div class="container-narrow">
      <p>
        Dann buche gerne ein kostenfreies Orientierungsgespräch. In 15–30 Minuten klären wir
        dein Anliegen, mögliche nächste Schritte und die passende Form der Zusammenarbeit.
      </p>
      <div class="btn-group">
        <a href="#kontaktformular" class="btn btn-primary">Kostenfreies Orientierungsgespräch buchen</a>
        <a href="#kontaktformular" class="btn btn-outline">Teamformat anfragen</a>
        <a href={`mailto:${CONTACT.email}`} class="btn btn-outline">Nachricht schreiben</a>
      </div>
    </div>
  </section>

  <section class="section section-cream-deep">
    <div class="container">
      <header class="section-head">
        <span class="eyebrow">Buchungsoptionen im Überblick</span>
        <h2>Vier Wege, <em>uns auszutauschen</em></h2>
      </header>
      <div class="booking-grid">
        {BOOKING_OPTIONS.map((b) => (
          <article class="booking-card">
            <h3>{b.title}</h3>
            <p class="duration">{b.duration}</p>
            <p>{b.text}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section section-cream" id="kontaktformular">
    <div class="container-narrow">
      <h2>Schreib mir eine Nachricht</h2>
      <p>
        Du kannst mir auch direkt schreiben. Ich melde mich in der Regel innerhalb von
        1–2 Werktagen.
      </p>

      <form class="contact-form" action={`mailto:${CONTACT.email}`} method="post" enctype="text/plain">
        <div class="field">
          <label for="name">Name</label>
          <input type="text" id="name" name="name" required />
        </div>
        <div class="field">
          <label for="email">E-Mail</label>
          <input type="email" id="email" name="email" required />
        </div>
        <div class="field">
          <label for="topic">Anliegen</label>
          <select id="topic" name="topic">
            <option>1:1 Begleitung</option>
            <option>Teamformat</option>
            <option>Publikationen / Interessentenliste</option>
            <option>Sonstiges</option>
          </select>
        </div>
        <div class="field">
          <label for="message">Nachricht</label>
          <textarea id="message" name="message" rows="6" required></textarea>
        </div>
        <div class="field-check">
          <input type="checkbox" id="impulsbrief" name="impulsbrief" />
          <label for="impulsbrief">
            Ich möchte den Impulsbrief von Daniela Britta Hamberger erhalten und über
            neue Publikationen, Materialien und Angebote informiert werden.
          </label>
        </div>
        <button type="submit" class="btn btn-primary">Nachricht senden</button>
      </form>

      <p class="form-note">
        Alle Angaben werden vertraulich behandelt. Du kannst dich jederzeit vom Impulsbrief
        abmelden.
      </p>

      <blockquote class="disclaimer">
        <strong>Wichtiger Hinweis:</strong> Die Angebote auf dieser Website ersetzen keine
        medizinische, psychotherapeutische oder psychiatrische Behandlung. Mentoring und
        Coaching sind keine Therapie. Bei psychischen Erkrankungen oder Krisen wende dich
        bitte an eine Ärztin, einen Arzt oder eine zugelassene Psychotherapeutin bzw. einen
        zugelassenen Psychotherapeuten.
      </blockquote>
    </div>
  </section>
</BaseLayout>

<style>
  .booking-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(14rem, 1fr));
    gap: 1.25rem;
  }
  .booking-card {
    background: var(--color-paper);
    border: 1px solid var(--color-line);
    border-top: 3px solid var(--color-gold);
    padding: 1.5rem;
    border-radius: var(--radius-m);
  }
  .booking-card h3 {
    font-size: 1.1rem;
    margin-bottom: 0.4rem;
  }
  .booking-card .duration {
    color: var(--color-gold-deep);
    font-family: var(--font-display);
    font-style: italic;
    margin-bottom: 0.85rem;
  }
  .booking-card p { font-size: 0.92rem; margin: 0; }

  .contact-form {
    margin-top: 1.5rem;
    background: var(--color-paper);
    padding: clamp(1.5rem, 4vw, 2.5rem);
    border: 1px solid var(--color-line);
    border-radius: var(--radius-m);
  }
  .field { margin-bottom: 1.25rem; }
  .field label,
  .field-check label {
    display: block;
    font-size: 0.88rem;
    font-weight: 500;
    color: var(--color-ink);
    margin-bottom: 0.4rem;
  }
  .field input,
  .field select,
  .field textarea {
    width: 100%;
    padding: 0.75rem 1rem;
    font: inherit;
    font-size: 0.95rem;
    background: var(--color-cream);
    border: 1px solid var(--color-line);
    border-radius: var(--radius-s);
    color: var(--color-ink);
  }
  .field input:focus,
  .field select:focus,
  .field textarea:focus {
    outline: 2px solid var(--color-gold);
    outline-offset: 1px;
    border-color: var(--color-gold);
  }
  .field-check {
    display: flex;
    gap: 0.65rem;
    margin: 1.25rem 0 1.5rem;
    align-items: flex-start;
  }
  .field-check input {
    margin-top: 0.25rem;
    accent-color: var(--color-bordeaux);
  }
  .field-check label {
    margin: 0;
    font-weight: 400;
    color: var(--color-ink-soft);
    font-size: 0.88rem;
    line-height: 1.5;
  }
  .form-note {
    font-size: 0.83rem;
    color: var(--color-ink-muted);
    font-style: italic;
    margin-top: 1rem;
  }
</style>
