---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { SITE, BOOKING_1ZU1, BOOKING_TEAM, CONTACT, VENUE, IMAGES } from '@/data/site';

const description =
  'Kontakt und Buchung — kostenfreies Orientierungsgespräch, 1:1 Sitzung, KlarheitsReset oder Team-Vorgespräch mit Daniela Britta Hamberger.';

const breadcrumb = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Start', item: `${SITE.url}/` },
    { '@type': 'ListItem', position: 2, name: 'Kontakt', item: `${SITE.url}/kontakt` },
  ],
};
---
<BaseLayout
  title="Kontakt"
  description={description}
  schema={breadcrumb}
>
  <section class="page-hero">
    <div class="container">
      <nav class="breadcrumb" aria-label="Breadcrumb" style="text-align: left;">
        <a href="/">Start</a><span>/</span><span>Kontakt</span>
      </nav>
      <span class="eyebrow">Kontakt &amp; Buchung</span>
      <h1>Lass uns schauen, <em>was für dich passt</em></h1>
      <p class="lead">
        Du möchtest herausfinden, ob eine 1:1 Begleitung, ein KlarheitsReset oder ein
        Teamformat passend ist?
      </p>
    </div>
  </section>

  <section class="section section-cream">
    <div class="container-narrow">
      <p>
        Dann buche gerne ein kostenfreies Orientierungsgespräch. In 15–30 Minuten klären wir
        dein Anliegen, mögliche nächste Schritte und die passende Form der Zusammenarbeit.
      </p>
      <div class="btn-group">
        <button type="button" class="btn btn-primary" data-modal-open="1zu1" data-format="orientierung">Kostenfreies Orientierungsgespräch buchen</button>
        <button type="button" class="btn btn-outline" data-modal-open="teams" data-format="teamvorgespraech">Teamformat anfragen</button>
        <a href={`mailto:${CONTACT.email}`} class="btn btn-outline">Nachricht schreiben</a>
      </div>
    </div>
  </section>

  <section class="section section-cream-deep">
    <div class="container">
      <header class="section-head">
        <span class="eyebrow">Buchungsoptionen im Überblick</span>
        <h2>Zwei Bereiche, <em>klar getrennt</em></h2>
        <p class="lead" style="margin: 0 auto;">
          Für Einzelpersonen einerseits, für Teams und Organisationen andererseits.
          Wähle den Bereich, der zu deinem Anliegen passt.
        </p>
      </header>

      <h3 class="booking-group-title">Für Einzelpersonen — 1:1 Begleitung</h3>
      <div class="booking-grid">
        {BOOKING_1ZU1.map((b) => (
          <article class="booking-card">
            <h3>{b.title}</h3>
            <p class="duration">{b.duration}</p>
            <p>{b.text}</p>
          </article>
        ))}
      </div>

      <h3 class="booking-group-title">Für Teams &amp; Organisationen</h3>
      <div class="booking-grid">
        {BOOKING_TEAM.map((b) => (
          <article class="booking-card">
            <h3>{b.title}</h3>
            <p class="duration">{b.duration}</p>
            <p>{b.text}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  {/* ============== RÄUMLICHKEITEN WIESBADEN ============== */}
  <section class="section bg-cream-soft venue-section">
    <div class="container venue-grid">
      <div class="venue-text">
        <span class="eyebrow">Kontakt &amp; Räumlichkeiten</span>
        <h2>Vor Ort in <em>Wiesbaden</em></h2>
        <p class="lead">
          Termine finden online, telefonisch oder nach Absprache vor Ort statt.
        </p>
        <p>
          Für ausgewählte Begleitungen, Workshops und Teamformate nutze ich stimmige
          Räumlichkeiten in Wiesbaden, unter anderem den <strong>{VENUE.name}</strong>.
        </p>
        <address class="venue-address">
          <strong>{VENUE.name}</strong><br />
          {VENUE.street}<br />
          {VENUE.postalCode} {VENUE.city}
        </address>
        <aside class="venue-note">
          <strong>Hinweis:</strong> Vor-Ort-Termine und Workshops werden ausschließlich
          über Daniela Britta Hamberger abgestimmt und gebucht — nicht extern über
          den Seminarraum.
        </aside>
        <div class="btn-group">
          <button type="button" class="btn btn-primary" data-modal-open="1zu1" data-format="orientierung">Gespräch buchen</button>
          <a href={`mailto:${CONTACT.email}`} class="btn btn-secondary">E-Mail schreiben</a>
        </div>
      </div>
      <div class="venue-visual">
        <img
          src={IMAGES.raumMeditation}
          alt={`Meditationskreis im ${VENUE.name}, Wiesbaden`}
          loading="lazy"
          class="venue-img"
        />
      </div>
    </div>
  </section>

  <section class="section section-cream" id="kontaktformular">
    <div class="container-narrow">
      <h2>So erreichst du mich</h2>
      <p>
        Wähle den Bereich, der zu deinem Anliegen passt — du landest in einem kurzen
        Anfrageformular. Ich melde mich in der Regel innerhalb von 1–2 Werktagen.
      </p>

      <div class="kontakt-cta-grid">
        <button type="button" class="btn btn-primary" data-modal-open="1zu1" data-format="orientierung">
          1:1 Begleitung anfragen
        </button>
        <button type="button" class="btn btn-primary" data-modal-open="teams" data-format="teamvorgespraech">
          Teamformat anfragen
        </button>
        <a href={`mailto:${CONTACT.email}`} class="btn btn-secondary">
          Direkt per E-Mail schreiben
        </a>
      </div>

      <p class="form-note">
        Alle Angaben werden vertraulich behandelt und ausschließlich zur Bearbeitung
        deiner Anfrage verwendet — Details findest du in der
        <a href="/datenschutz">Datenschutzerklärung</a>.
      </p>

      <blockquote class="disclaimer">
        <strong>Wichtiger Hinweis:</strong> Die Angebote auf dieser Website ersetzen keine
        medizinische, psychotherapeutische oder psychiatrische Behandlung. Mentoring und
        Coaching sind keine Therapie. Bei psychischen Erkrankungen oder Krisen wende dich
        bitte an eine Ärztin, einen Arzt oder eine zugelassene Psychotherapeutin bzw. einen
        zugelassenen Psychotherapeuten.
      </blockquote>
    </div>
  </section>
</BaseLayout>

<style>
  .booking-group-title {
    font-family: var(--font-display);
    font-size: 1.4rem;
    font-weight: 400;
    color: var(--color-sage-deep);
    margin: 2rem 0 1.25rem;
    padding-bottom: 0.5rem;
    border-bottom: 1px solid var(--color-line-soft);
    letter-spacing: -0.005em;
  }
  .booking-group-title:first-of-type { margin-top: 0.5rem; }
  .booking-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(14rem, 1fr));
    gap: 1.25rem;
    margin-bottom: 1.5rem;
  }
  .booking-card {
    background: var(--color-paper);
    border: 1px solid var(--color-line);
    border-top: 3px solid var(--color-gold);
    padding: 1.5rem;
    border-radius: var(--radius-m);
  }
  .booking-card h3 {
    font-size: 1.1rem;
    margin-bottom: 0.4rem;
  }
  .booking-card .duration {
    color: var(--color-gold-deep);
    font-family: var(--font-display);
    font-style: italic;
    margin-bottom: 0.85rem;
  }
  .booking-card p { font-size: 0.92rem; margin: 0; }

  .kontakt-cta-grid {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    margin: 1.5rem 0 1.25rem;
    align-items: stretch;
  }
  .kontakt-cta-grid .btn {
    justify-content: center;
    text-align: center;
  }
  @media (min-width: 640px) {
    .kontakt-cta-grid {
      flex-direction: row;
      flex-wrap: wrap;
    }
    .kontakt-cta-grid .btn {
      flex: 1 1 calc(33% - 0.5rem);
      min-width: 180px;
    }
  }
  .form-note {
    font-size: 0.85rem;
    color: var(--color-ink-muted);
    margin-top: 1rem;
    line-height: 1.55;
  }
  .form-note a { color: var(--color-sage-deep); text-decoration: underline; text-underline-offset: 2px; }

  /* ============== VENUE WIESBADEN ============== */
  .venue-grid {
    display: grid;
    grid-template-columns: 1.05fr 0.95fr;
    gap: clamp(2rem, 5vw, 4rem);
    align-items: center;
  }
  .venue-text h2 { margin: 0.5rem 0 1rem; }
  .venue-text .lead { margin-bottom: 1.25rem; max-width: 38ch; }
  .venue-text p { margin-bottom: 1.25rem; max-width: 46ch; }
  .venue-address {
    background: var(--color-paper);
    border-left: 3px solid var(--color-clay);
    padding: 1.25rem 1.5rem;
    font-style: normal;
    line-height: 1.7;
    border-radius: 0 var(--radius-s) var(--radius-s) 0;
    margin-bottom: 1.25rem;
    color: var(--color-ink);
  }
  .venue-note {
    background: var(--color-cream-deep);
    padding: 1rem 1.25rem;
    font-size: 0.9rem;
    color: var(--color-ink-soft);
    border-radius: var(--radius-s);
    margin-bottom: 0.5rem;
  }
  .venue-note strong { color: var(--color-sage-deep); }
  .venue-img {
    aspect-ratio: 4 / 5;
    max-width: 28rem;
    width: 100%;
    object-fit: cover;
    border-radius: var(--radius-l);
    box-shadow: var(--shadow-lift);
    margin-inline: auto;
  }
  @media (max-width: 860px) {
    .venue-grid { grid-template-columns: 1fr; }
    .venue-img { max-width: 22rem; aspect-ratio: 4 / 3; }
  }
</style>
