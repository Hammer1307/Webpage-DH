---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { SITE, IMAGES, PUBLICATIONS } from '@/data/site';

const description =
  'Bücher, Workbooks, Coaching-Karten und kreative Arbeiten von Daniela Britta Hamberger. Selbstcoachingbuch "Zurück zu dir", mythologische Reise "Das Vermächtnis des Herzens" und mehr.';

const breadcrumb = {
  '@context': 'https://schema.org', '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Start', item: `${SITE.url}/` },
    { '@type': 'ListItem', position: 2, name: 'Publikationen', item: `${SITE.url}/publikationen-materialien` },
  ],
};
---
<BaseLayout title="Publikationen, Bücher & kreative Arbeiten" description={description} schema={breadcrumb}>
  <img class="image-accent" src={IMAGES.publikationenSchreiben} alt="Schreiben am Tablet — Worte, die Räume öffnen können" loading="eager" />

  <section class="section bg-cream">
    <div class="container-narrow">
      <nav class="breadcrumb" aria-label="Breadcrumb"><a href="/">Start</a><span>/</span><span>Publikationen</span></nav>
      <header class="page-intro">
        <span class="eyebrow">Als Autorin &amp; Künstlerin</span>
        <h1>Geschichten, Karten und Kunst, die <em>berühren</em></h1>
        <p class="lead">Für innere Ordnung, Lebensfreude und ein wertschätzendes Miteinander.</p>
      </header>

      <p>
        Als Autorin und Künstlerin greife ich Themen auf, die mich seit Jahren bewegen: Menschlichkeit, Naturverbundenheit, Empathie, Werte, innere Entwicklung, Sinnsuche, Lebensfreude und gelingendes Miteinander.
      </p>
      <p>
        Meine Bücher, Workbooks, Karten und kreativen Arbeiten sollen berühren, stärken und zum Nachdenken einladen. Manche Projekte sind erzählerisch. Andere unterstützen Selbstreflexion, Coaching, Gruppenarbeit oder persönliche Entwicklung.
      </p>
      <p>
        Dabei geht es nicht nur um Inhalte, sondern auch um Atmosphäre: um Räume, Bilder und Worte, die Menschen wieder näher zu sich selbst führen können.
      </p>
    </div>
  </section>

  <section class="section bg-cream-deep">
    <div class="container">
      <header class="section-head">
        <span class="eyebrow">Projekte in Vorbereitung</span>
        <h2>Geplante und entstehende <em>Projekte</em></h2>
      </header>
      <div class="pub-grid">
        {PUBLICATIONS.map((p) => (
          <article class="pub-card">
            <span class="tag tag-outline">{p.label}</span>
            <h3>{p.name}</h3>
            {p.subtitle && <p class="pub-sub"><em>{p.subtitle}</em></p>}
            <p class="pub-desc">{p.description}</p>
            {p.meta && <p class="pub-meta">{p.meta}</p>}
            <div class="btn-group">
              <a href="/kontakt" class="btn btn-secondary">Vormerken</a>
              <a href="/kontakt" class="btn btn-ghost">Mehr erfahren</a>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section bg-cream">
    <div class="container-narrow" style="text-align: center;">
      <h2>Bleib auf dem <em>Laufenden</em></h2>
      <p style="margin: 1rem auto 1.5rem; max-width: 55ch;">Wenn du über neue Bücher, Workbooks, Karten, kreative Arbeiten oder ausgewählte Impulse informiert werden möchtest, kannst du mir gerne schreiben.</p>
      <div class="btn-group btn-group-center">
        <a href="/kontakt" class="btn btn-primary">Interesse an Publikationen mitteilen</a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .page-intro { text-align: center; margin-bottom: 2.5rem; }
  .page-intro h1 { margin: 0.5rem 0 1rem; }
  .page-intro .lead { margin: 0 auto; }
  .pub-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(20rem, 1fr)); gap: 1.5rem; }
  .pub-card { background: var(--color-paper); border: 1px solid var(--color-line); border-radius: var(--radius-l); padding: 1.75rem; display: flex; flex-direction: column; transition: all var(--transition); }
  .pub-card:hover { box-shadow: var(--shadow-card); transform: translateY(-2px); }
  .pub-card .tag { align-self: flex-start; margin-bottom: 0.85rem; }
  .pub-card h3 { margin-bottom: 0.5rem; font-size: 1.35rem; }
  .pub-sub { color: var(--color-clay); font-family: var(--font-display); font-size: 1rem; margin-bottom: 1rem; font-style: italic; max-width: none; }
  .pub-desc { font-size: 0.92rem; margin-bottom: 1rem; color: var(--color-ink-soft); max-width: none; }
  .pub-meta { font-size: 0.83rem; color: var(--color-ink-muted); background: var(--color-cream); padding: 0.65rem 0.85rem; border-left: 2px solid var(--color-clay); margin-bottom: 1rem; max-width: none; }
  .pub-card .btn-group { margin-top: auto; }
</style>
