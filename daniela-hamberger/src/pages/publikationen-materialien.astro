---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { SITE, IMAGES, PUBLICATIONS } from '@/data/site';

const description =
  'Selbstcoaching-Bücher, Workbooks, Coaching-Karten und Materialien von Daniela Britta Hamberger — für innere Ordnung, Klarheit und gelingendes Miteinander.';

const breadcrumb = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Start', item: `${SITE.url}/` },
    { '@type': 'ListItem', position: 2, name: 'Publikationen', item: `${SITE.url}/publikationen-materialien` },
  ],
};
---
<BaseLayout
  title="Publikationen & Materialien"
  description={description}
  schema={breadcrumb}
>
  <img class="image-accent" src={IMAGES.publikationen} alt="" loading="eager" />

  <section class="section section-cream">
    <div class="container-narrow">
      <nav class="breadcrumb" aria-label="Breadcrumb">
        <a href="/">Start</a><span>/</span><span>Publikationen &amp; Materialien</span>
      </nav>
      <header class="page-intro">
        <span class="eyebrow">Publikationen &amp; Materialien</span>
        <h1>Bücher, Karten &amp; <em>Materialien</em></h1>
        <p class="lead">
          Selbstcoaching, Weisheitsgeschichten und Impulse für innere Ordnung, Klarheit und
          gelingendes Miteinander
        </p>
      </header>

      <p>
        Unter Fokus Schöner Leben entstehen Bücher, Workbooks, Coaching-Karten und Materialien,
        die meine Arbeit über persönliche Begleitung, Workshops und Teamprozesse hinaus
        erweitern. Sie richten sich an ältere Jugendliche, Erwachsene, Einzelpersonen, Gruppen
        und Teams, die sich mit innerer Stabilität, Selbstwahrnehmung, Sinnfragen, Wertschätzung,
        Empathie und bewusster Entwicklung beschäftigen möchten.
      </p>
      <p>
        Meine Publikationen verbinden pädagogische Erfahrung, Mentaltraining, Achtsamkeit,
        positive Psychologie, Elemente der Persönlichkeitsentwicklung, symbolische Bildsprache
        und Impulse für ein wertschätzendes Miteinander. Ziel ist es, Menschen dabei zu
        unterstützen, sich selbst besser wahrzunehmen, Gedanken zu ordnen, neue Perspektiven
        zu entwickeln und wieder mehr Verbindung zu sich, zu anderen und zur Natur zu spüren.
      </p>
    </div>
  </section>

  <section class="section section-cream-deep">
    <div class="container">
      <h2 class="text-center">Geplante und entstehende Projekte</h2>
      <div class="pub-grid">
        {PUBLICATIONS.map((p) => (
          <article class="pub-card">
            <span class="tag tag-outline">{p.label}</span>
            <h3>{p.name}</h3>
            {p.subtitle && <p class="pub-sub"><em>{p.subtitle}</em></p>}
            <p class="pub-desc">{p.description}</p>
            {p.meta && <p class="pub-meta">{p.meta}</p>}
            <div class="btn-group">
              <a href="/kontakt" class="btn btn-outline">Vormerken</a>
              <a href="/kontakt" class="btn btn-outline">Mehr erfahren</a>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section section-cream">
    <div class="container-narrow" style="text-align: center;">
      <h2>Bleib auf dem Laufenden</h2>
      <p style="margin: 1rem auto 1.5rem; max-width: 50ch;">
        Trag dich in die Interessentenliste ein und erfahre als Erstes, wenn neue Materialien
        erscheinen.
      </p>
      <div class="btn-group btn-group-center">
        <a href="/kontakt" class="btn btn-primary">Interessentenliste eintragen</a>
        <a href="/kontakt" class="btn btn-outline">Buchprojekte vormerken</a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .page-intro { text-align: center; margin-bottom: 2.5rem; }
  .page-intro h1 { margin: 0.5rem 0 1rem; }
  .page-intro .lead { margin: 0 auto; }
  .text-center { text-align: center; margin-bottom: 2.5rem; }

  .pub-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(20rem, 1fr));
    gap: 1.5rem;
  }
  .pub-card {
    background: var(--color-paper);
    border: 1px solid var(--color-line);
    border-radius: var(--radius-m);
    padding: 1.75rem;
    display: flex;
    flex-direction: column;
    transition: all var(--transition);
  }
  .pub-card:hover {
    border-color: var(--color-gold);
    box-shadow: var(--shadow-card);
    transform: translateY(-2px);
  }
  .pub-card .tag { align-self: flex-start; margin-bottom: 0.85rem; }
  .pub-card h3 { margin-bottom: 0.5rem; font-size: 1.35rem; }
  .pub-sub {
    color: var(--color-gold-deep);
    font-family: var(--font-display);
    font-size: 1rem;
    margin-bottom: 1rem;
    font-style: italic;
  }
  .pub-desc {
    font-size: 0.92rem;
    margin-bottom: 1rem;
    color: var(--color-ink-soft);
  }
  .pub-meta {
    font-size: 0.83rem;
    color: var(--color-ink-muted);
    background: var(--color-cream);
    padding: 0.65rem 0.85rem;
    border-left: 2px solid var(--color-gold);
    margin-bottom: 1rem;
  }
  .pub-card .btn-group { margin-top: auto; }
</style>
